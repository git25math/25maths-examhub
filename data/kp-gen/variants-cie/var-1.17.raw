[{"id":"cv1519","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 5% increase?","o":["1.5","1.05","0.05","0.95"],"a":1,"e":"A 5% increase means you have 100% + 5% = 105%, which is 1.05 as a decimal multiplier.","d":2,"s":"1.17"},{"id":"cv1520","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 2.5% increase?","o":["1.25","1.025","0.025","0.975"],"a":1,"e":"A 2.5% increase means you have 100% + 2.5% = 102.5%, which is 1.025 as a decimal multiplier.","d":2,"s":"1.17"},{"id":"cv1521","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 15% increase?","o":["1.5","1.15","0.15","0.85"],"a":1,"e":"A 15% increase means you have 100% + 15% = 115%, which is 1.15 as a decimal multiplier.","d":2,"s":"1.17"},{"id":"cv1522","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 7% decrease?","o":["0.07","1.07","0.93","0.093"],"a":2,"e":"A 7% decrease means you have 100% - 7% = 93%, which is 0.93 as a decimal multiplier.","d":2,"s":"1.17"},{"id":"cv1523","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 4.5% decrease?","o":["0.45","1.045","0.955","0.045"],"a":2,"e":"A 4.5% decrease means you have 100% - 4.5% = 95.5%, which is 0.955 as a decimal multiplier.","d":2,"s":"1.17"},{"id":"cv1524","cat":"number","topic":"Exponential Growth And Decay","q":"What is the single multiplier for a 22% decrease?","o":["0.22","1.22","0.78","0.88"],"a":2,"e":"A 22% decrease means you have 100% - 22% = 78%, which is 0.78 as a decimal multiplier.","d":2,"s":"1.17"}]
