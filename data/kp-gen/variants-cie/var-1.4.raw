[{"id":"cv1531","cat":"number","topic":"Ordering","q":"Arrange these temperatures in ascending order: -8°C, 4°C, -2°C, 1°C.","o":["-8°C, -2°C, 1°C, 4°C","1°C, 4°C, -2°C, -8°C","4°C, 1°C, -2°C, -8°C","-2°C, -8°C, 1°C, 4°C"],"a":0,"e":"Ascending order means from smallest to largest. On a number line, -8 is the most negative (smallest), followed by -2, then 1, and finally the positive number 4.","d":1,"s":"1.4"},{"id":"cv1532","cat":"number","topic":"Ordering","q":"Arrange these temperatures in ascending order: -12°C, 0°C, -6°C, 3°C.","o":["-12°C, -6°C, 0°C, 3°C","0°C, 3°C, -6°C, -12°C","3°C, 0°C, -6°C, -12°C","-6°C, -12°C, 0°C, 3°C"],"a":0,"e":"Ascending order means from smallest to largest. On a number line, -12 is the most negative (smallest), followed by -6, then 0, and finally the positive number 3.","d":1,"s":"1.4"},{"id":"cv1533","cat":"number","topic":"Ordering","q":"Arrange these temperatures in ascending order: -4°C, 5°C, -9°C, -1°C.","o":["-9°C, -4°C, -1°C, 5°C","-1°C, 5°C, -4°C, -9°C","5°C, -1°C, -4°C, -9°C","-4°C, -9°C, -1°C, 5°C"],"a":0,"e":"Ascending order means from smallest to largest. On a number line, -9 is the most negative (smallest), followed by -4, then -1, and finally the positive number 5.","d":1,"s":"1.4"},{"id":"cv1534","cat":"number","topic":"Ordering","q":"Which of the following statements is true?","o":["-5.3 < -5.33","-5.3 > -5.33","-5.3 = -5.33","-5.03 < -5.3"],"a":1,"e":"For negative numbers, the number with the smaller absolute value is greater. Since 5.3 is smaller than 5.33, -5.3 is greater than -5.33. On a number line, -5.3 is to the right of -5.33.","d":1,"s":"1.4"},{"id":"cv1535","cat":"number","topic":"Ordering","q":"Which of the following statements is true?","o":["-2.8 < -2.88","-2.8 > -2.88","-2.8 = -2.88","-2.08 < -2.8"],"a":1,"e":"For negative numbers, the number with the smaller absolute value is greater. Since 2.8 is smaller than 2.88, -2.8 is greater than -2.88. On a number line, -2.8 is to the right of -2.88.","d":1,"s":"1.4"},{"id":"cv1536","cat":"number","topic":"Ordering","q":"Which of the following statements is true?","o":["-7.1 < -7.11","-7.1 > -7.11","-7.1 = -7.11","-7.01 < -7.1"],"a":1,"e":"For negative numbers, the number with the smaller absolute value is greater. Since 7.1 is smaller than 7.11, -7.1 is greater than -7.11. On a number line, -7.1 is to the right of -7.11.","d":1,"s":"1.4"},{"id":"cv1537","cat":"number","topic":"Ordering","q":"Arrange the following numbers in ascending order: 0.6, -0.4, 0.06, -0.04.","o":["-0.04, -0.4, 0.06, 0.6","-0.4, -0.04, 0.6, 0.06","-0.4, -0.04, 0.06, 0.6","0.6, 0.06, -0.04, -0.4"],"a":2,"e":"Ascending order means smallest to largest. First, order the negative numbers (-0.4 is smaller than -0.04). Then, order the positive numbers (0.06 is smaller than 0.6). Combining them gives -0.4, -0.04, 0.06, 0.6.","d":1,"s":"1.4"},{"id":"cv1538","cat":"number","topic":"Ordering","q":"Arrange the following numbers in ascending order: 0.9, -0.3, 0.09, -0.03.","o":["-0.03, -0.3, 0.09, 0.9","-0.3, -0.03, 0.9, 0.09","-0.3, -0.03, 0.09, 0.9","0.9, 0.09, -0.03, -0.3"],"a":2,"e":"Ascending order means smallest to largest. First, order the negative numbers (-0.3 is smaller than -0.03). Then, order the positive numbers (0.09 is smaller than 0.9). Combining them gives -0.3, -0.03, 0.09, 0.9.","d":1,"s":"1.4"},{"id":"cv1539","cat":"number","topic":"Ordering","q":"Arrange the following numbers in ascending order: 0.2, -0.8, 0.02, -0.08.","o":["-0.08, -0.8, 0.02, 0.2","-0.8, -0.08, 0.2, 0.02","-0.8, -0.08, 0.02, 0.2","0.2, 0.02, -0.08, -0.8"],"a":2,"e":"Ascending order means smallest to largest. First, order the negative numbers (-0.8 is smaller than -0.08). Then, order the positive numbers (0.02 is smaller than 0.2). Combining them gives -0.8, -0.08, 0.02, 0.2.","d":1,"s":"1.4"},{"id":"cv1540","cat":"number","topic":"Ordering","q":"Which of these numbers is the largest?","o":["-6.4","-6.04","-6.44","-6.004"],"a":3,"e":"For negative numbers, the number with the smallest absolute value (the one closest to zero) is the largest. -6.004 is the closest to zero.","d":2,"s":"1.4"},{"id":"cv1541","cat":"number","topic":"Ordering","q":"Which of these numbers is the largest?","o":["-3.7","-3.07","-3.77","-3.007"],"a":3,"e":"For negative numbers, the number with the smallest absolute value (the one closest to zero) is the largest. -3.007 is the closest to zero.","d":2,"s":"1.4"},{"id":"cv1542","cat":"number","topic":"Ordering","q":"Which of these numbers is the largest?","o":["-9.2","-9.02","-9.22","-9.002"],"a":3,"e":"For negative numbers, the number with the smallest absolute value (the one closest to zero) is the largest. -9.002 is the closest to zero.","d":2,"s":"1.4"},{"id":"cv1543","cat":"number","topic":"Ordering","q":"Which of the following values for $y$ satisfies the inequality $y < -4.65$?","o":["-4.6","-4.65","-4.64","-4.66"],"a":3,"e":"A number $y$ is less than -4.65 if it is further from zero on the negative number line. -4.66 is more negative than -4.65.","d":2,"s":"1.4"},{"id":"cv1544","cat":"number","topic":"Ordering","q":"Which of the following values for $y$ satisfies the inequality $y < -1.85$?","o":["-1.8","-1.85","-1.84","-1.86"],"a":3,"e":"A number $y$ is less than -1.85 if it is further from zero on the negative number line. -1.86 is more negative than -1.85.","d":2,"s":"1.4"},{"id":"cv1545","cat":"number","topic":"Ordering","q":"Which of the following values for $y$ satisfies the inequality $y < -7.35$?","o":["-7.3","-7.35","-7.34","-7.36"],"a":3,"e":"A number $y$ is less than -7.35 if it is further from zero on the negative number line. -7.36 is more negative than -7.35.","d":2,"s":"1.4"}]
