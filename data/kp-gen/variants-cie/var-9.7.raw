[{"id":"cv1690","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"A histogram is drawn for grouped continuous data. The frequency of a class is 40 and the class width is 8. What is the frequency density?","o":["5","320","32","0.2"],"a":0,"e":"Frequency density is calculated by dividing the frequency by the class width. So, Frequency Density = $\\frac{40}{8}$ = 5.","d":2,"s":"9.7"},{"id":"cv1691","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"A histogram is drawn for grouped continuous data. The frequency of a class is 24 and the class width is 6. What is the frequency density?","o":["4","144","18","0.25"],"a":0,"e":"Frequency density is calculated by dividing the frequency by the class width. So, Frequency Density = $\\frac{24}{6}$ = 4.","d":2,"s":"9.7"},{"id":"cv1692","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"A histogram is drawn for grouped continuous data. The frequency of a class is 18 and the class width is 4. What is the frequency density?","o":["4.5","72","14","0.222"],"a":0,"e":"Frequency density is calculated by dividing the frequency by the class width. So, Frequency Density = $\\frac{18}{4}$ = 4.5.","d":2,"s":"9.7"},{"id":"cv1693","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"On a histogram, the frequency density for a class interval of 20 < $x \\leq 25$ is 3.2. What is the frequency for this class?","o":["16","0.64","8.2","160"],"a":0,"e":"Frequency is calculated by multiplying the frequency density by the class width. The class width is 25 - 20 = 5. So, Frequency = 3.2 * 5 = 16.","d":2,"s":"9.7"},{"id":"cv1694","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"On a histogram, the frequency density for a class interval of 10 < $x \\leq 14$ is 7.5. What is the frequency for this class?","o":["30","1.875","11.5","300"],"a":0,"e":"Frequency is calculated by multiplying the frequency density by the class width. The class width is 14 - 10 = 4. So, Frequency = 7.5 * 4 = 30.","d":2,"s":"9.7"},{"id":"cv1695","cat":"statistics","topic":"Statistical Charts And Diagrams","q":"On a histogram, the frequency density for a class interval of 0 < $x \\leq 20$ is 1.8. What is the frequency for this class?","o":["36","0.09","21.8","360"],"a":0,"e":"Frequency is calculated by multiplying the frequency density by the class width. The class width is 20 - 0 = 20. So, Frequency = 1.8 * 20 = 36.","d":2,"s":"9.7"}]
