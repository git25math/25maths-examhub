[{"id":"cv1576","cat":"algebra","topic":"Functions","q":"If f(x) = 3x - 2, what is the value of f(4)?","o":["10","14","12","6"],"a":0,"e":"Substitute $x = 4$ into the function: f(4) = 3(4) - 2 = 12 - 2 = 10.","d":2,"s":"2.13"},{"id":"cv1577","cat":"algebra","topic":"Functions","q":"If g(x) = 4x + 1, what is the value of g(-2)?","o":["9","-7","-9","7"],"a":1,"e":"Substitute $x = -2$ into the function: g(-2) = 4(-2) + 1 = -8 + 1 = -7.","d":2,"s":"2.13"},{"id":"cv1578","cat":"algebra","topic":"Functions","q":"If h(x) = 6 - 2x, what is the value of h(5)?","o":["4","-16","-4","16"],"a":2,"e":"Substitute $x = 5$ into the function: h(5) = 6 - 2(5) = 6 - 10 = -4.","d":2,"s":"2.13"},{"id":"cv1579","cat":"algebra","topic":"Functions","q":"Given f(x) = $x^2$ + 7, find f(4).","o":["15","23","11","25"],"a":1,"e":"Substitute $x = 4$ into the function: f(4) = $4^2$ + 7 = 16 + 7 = 23.","d":2,"s":"2.13"},{"id":"cv1580","cat":"algebra","topic":"Functions","q":"Given g(x) = $x^2$ - 10, find g(-3).","o":["19","-1","1","-19"],"a":1,"e":"Substitute $x = -3$ into the function: g(-3) = $(-3)^2$ - 10 = 9 - 10 = -1.","d":2,"s":"2.13"},{"id":"cv1581","cat":"algebra","topic":"Functions","q":"Given h(x) = 50 - $x^2$, find h(7).","o":["43","1","-1","99"],"a":1,"e":"Substitute $x = 7$ into the function: h(7) = 50 - $7^2$ = 50 - 49 = 1.","d":2,"s":"2.13"}]
