[{"id":"cv1546","cat":"number","topic":"Order of Operations","q":"What is the value of $5 + 3 \\times 4$?","o":["32","17","12","23"],"a":1,"e":"Multiplication is done before addition: $3 \\times 4 = 12$, then $5 + 12 = 17$.","d":1,"s":"1.6"},{"id":"cv1547","cat":"number","topic":"Order of Operations","q":"Calculate the value of $2 + 6 \\times 3$.","o":["24","20","11","18"],"a":1,"e":"Multiplication takes precedence: $6 \\times 3 = 18$. Adding the result to 2 gives $2 + 18 = 20$.","d":1,"s":"1.6"},{"id":"cv1548","cat":"number","topic":"Order of Operations","q":"Evaluate $7 + 2 \\times 5$.","o":["17","45","14","19"],"a":0,"e":"Perform multiplication before addition: $2 \\times 5 = 10$, then $7 + 10 = 17$.","d":1,"s":"1.6"},{"id":"cv1549","cat":"number","topic":"Order of Operations","q":"Calculate $30 - 4 \\times (2 + 3)$.","o":["130","10","26","18"],"a":1,"e":"Brackets first: $2 + 3 = 5$. Then multiply: $4 \\times 5 = 20$. Finally subtract: $30 - 20 = 10$.","d":1,"s":"1.6"},{"id":"cv1550","cat":"number","topic":"Order of Operations","q":"What is the value of $15 - 2 \\times (1 + 4)$?","o":["65","13","5","25"],"a":2,"e":"Work inside the brackets first: $1 + 4 = 5$. Then multiply: $2 \\times 5 = 10$. Finally subtract: $15 - 10 = 5$.","d":1,"s":"1.6"},{"id":"cv1551","cat":"number","topic":"Order of Operations","q":"Evaluate $25 - 3 \\times (5 + 1)$.","o":["132","21","12","7"],"a":3,"e":"Calculate inside the brackets: $5 + 1 = 6$. Multiply next: $3 \\times 6 = 18$. Subtract from 25: $25 - 18 = 7$.","d":1,"s":"1.6"},{"id":"cv1552","cat":"number","topic":"Order of Operations","q":"What is the value of $\\frac{10 + 5}{7 - 2}$?","o":["3","5","15","2"],"a":0,"e":"The fraction bar acts as a bracket for both parts. Numerator: $10 + 5 = 15$. Denominator: $7 - 2 = 5$. So $\\frac{15}{5} = 3$.","d":1,"s":"1.6"},{"id":"cv1553","cat":"number","topic":"Order of Operations","q":"Calculate $\\frac{12 + 8}{9 - 4}$.","o":["2","4","10","5"],"a":1,"e":"Treat the top and bottom as if they are in brackets. Top: $12 + 8 = 20$. Bottom: $9 - 4 = 5$. The division is $20 \\div 5 = 4$.","d":1,"s":"1.6"},{"id":"cv1554","cat":"number","topic":"Order of Operations","q":"Evaluate $\\frac{18 + 6}{10 - 2}$.","o":["8","2","3","6"],"a":2,"e":"Evaluate the numerator and denominator separately. Numerator: $18 + 6 = 24$. Denominator: $10 - 2 = 8$. Then divide: $24 \\div 8 = 3$.","d":1,"s":"1.6"},{"id":"cv1555","cat":"number","topic":"Order of Operations","q":"Evaluate $4^2 - 2 \\times 5 + 3$.","o":["9","73","11","70"],"a":0,"e":"Indices first: $4^2 = 16$. Then multiply: $2 \\times 5 = 10$. Now perform addition and subtraction from left to right: $16 - 10 + 3 = 6 + 3 = 9$.","d":2,"s":"1.6"},{"id":"cv1556","cat":"number","topic":"Order of Operations","q":"What is the value of $3^2 - 4 \\times 2 + 5$?","o":["15","6","10","11"],"a":1,"e":"Calculate the power first: $3^2 = 9$. Then multiply: $4 \\times 2 = 8$. Finally, $9 - 8 + 5 = 1 + 5 = 6$.","d":2,"s":"1.6"},{"id":"cv1557","cat":"number","topic":"Order of Operations","q":"Calculate $6^2 - 5 \\times 4 + 2$.","o":["124","126","18","22"],"a":2,"e":"First handle the index: $6^2 = 36$. Then multiplication: $5 \\times 4 = 20$. Finally: $36 - 20 + 2 = 18$.","d":2,"s":"1.6"},{"id":"cv1558","cat":"number","topic":"Order of Operations","q":"Calculate $3 \\times (2 + 4)^2 \\div 9$.","o":["48","12","36","108"],"a":1,"e":"Brackets first: $2 + 4 = 6$. Indices next: $6^2 = 36$. Multiplication: $3 \\times 36 = 108$. Division: $108 \\div 9 = 12$.","d":2,"s":"1.6"},{"id":"cv1559","cat":"number","topic":"Order of Operations","q":"What is $4 \\times (1 + 3)^2 \\div 8$?","o":["32","8","16","64"],"a":1,"e":"Work inside the brackets: $1 + 3 = 4$. Indices: $4^2 = 16$. Multiplication: $4 \\times 16 = 64$. Division: $64 \\div 8 = 8$.","d":2,"s":"1.6"},{"id":"cv1560","cat":"number","topic":"Order of Operations","q":"Evaluate $5 \\times (2 + 2)^2 \\div 10$.","o":["8","40","16","80"],"a":0,"e":"Brackets: $2 + 2 = 4$. Indices: $4^2 = 16$. Multiply: $5 \\times 16 = 80$. Divide: $80 \\div 10 = 8$.","d":2,"s":"1.6"}]
