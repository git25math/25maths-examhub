[{"id":"ev0943","cat":"edx-geometry","topic":"Measures","q":"What is the length of the pencil shown in the diagram, measured to the nearest millimetre? [Imagine a diagram showing a pencil aligned with a ruler. The pencil starts at 0 cm and ends at 5.6 cm]","o":["5 cm","5.6 cm","56 mm","6 cm"],"a":2,"e":"The pencil measures 5.6 cm. To convert centimetres to millimetres, multiply by 10. So, 5.6 cm = 5.6 \\times 10 = 56 mm.","d":1,"s":"4.4"},{"id":"ev0944","cat":"edx-geometry","topic":"Measures","q":"What is the length of the pencil shown in the diagram, measured to the nearest millimetre? [Imagine a diagram showing a pencil aligned with a ruler. The pencil starts at 0 cm and ends at 9.1 cm]","o":["91 mm","9.1 cm","9 cm","910 mm"],"a":0,"e":"The pencil measures 9.1 cm. To convert centimetres to millimetres, multiply by 10. So, 9.1 cm = 9.1 \\times 10 = 91 mm.","d":1,"s":"4.4"},{"id":"ev0945","cat":"edx-geometry","topic":"Measures","q":"What is the length of the pencil shown in the diagram, measured to the nearest millimetre? [Imagine a diagram showing a pencil aligned with a ruler. The pencil starts at 0 cm and ends at 3.8 cm]","o":["380 mm","4 cm","3.8 cm","38 mm"],"a":3,"e":"The pencil measures 3.8 cm. To convert centimetres to millimetres, multiply by 10. So, 3.8 cm = 3.8 \\times 10 = 38 mm.","d":1,"s":"4.4"},{"id":"ev0946","cat":"edx-geometry","topic":"Measures","q":"Convert 2.5 metres into centimetres.","o":["25 cm","250 cm","2500 cm","0.25 cm"],"a":1,"e":"There are 100 centimetres in 1 metre. So, 2.5 $m = 2.5$ \\times 100 = 250 cm.","d":1,"s":"4.4"},{"id":"ev0947","cat":"edx-geometry","topic":"Measures","q":"Convert 0.8 metres into centimetres.","o":["8 cm","800 cm","80 cm","0.08 cm"],"a":2,"e":"There are 100 centimetres in 1 metre. So, 0.8 $m = 0.8$ \\times 100 = 80 cm.","d":1,"s":"4.4"},{"id":"ev0948","cat":"edx-geometry","topic":"Measures","q":"Convert 4.1 metres into centimetres.","o":["410 cm","41 cm","4100 cm","0.41 cm"],"a":0,"e":"There are 100 centimetres in 1 metre. So, 4.1 $m = 4.1$ \\times 100 = 410 cm.","d":1,"s":"4.4"},{"id":"ev0949","cat":"edx-geometry","topic":"Measures","q":"A bag of sugar weighs 250 grams. How many kilograms is this?","o":["2.5 kg","0.25 kg","25 kg","2500 kg"],"a":1,"e":"There are 1000 grams in 1 kilogram. So, 250 $g = 250$ \\div 1000 = 0.25 kg.","d":1,"s":"4.4"},{"id":"ev0950","cat":"edx-geometry","topic":"Measures","q":"A small stone weighs 800 grams. How many kilograms is this?","o":["8 kg","80 kg","0.08 kg","0.8 kg"],"a":3,"e":"There are 1000 grams in 1 kilogram. So, 800 $g = 800$ \\div 1000 = 0.8 kg.","d":1,"s":"4.4"},{"id":"ev0951","cat":"edx-geometry","topic":"Measures","q":"A melon weighs 1500 grams. How many kilograms is this?","o":["1.5 kg","15 kg","150 kg","0.15 kg"],"a":0,"e":"There are 1000 grams in 1 kilogram. So, 1500 $g = 1500$ \\div 1000 = 1.5 kg.","d":1,"s":"4.4"},{"id":"ev0952","cat":"edx-geometry","topic":"Geometry","q":"A train travels a distance of 180 km in 2 hours and 15 minutes. What is its average speed in km/h?","o":["80 km/h","90 km/h","75 km/h","100 km/h"],"a":0,"e":"First, convert the time to hours: 2 hours and 15 minutes = 2.25 hours. Speed = Distance / Time = 180 km / 2.25 h = 80 km/h.","d":2,"s":"4.4"},{"id":"ev0953","cat":"edx-geometry","topic":"Geometry","q":"A cyclist travels a distance of 350 km in 3 hours and 30 minutes. What is the average speed in km/h?","o":["100 km/h","116.7 km/h","90 km/h","105 km/h"],"a":0,"e":"First, convert the time to hours: 3 hours and 30 minutes = 3.5 hours. Speed = Distance / Time = 350 km / 3.5 h = 100 km/h.","d":2,"s":"4.4"},{"id":"ev0954","cat":"edx-geometry","topic":"Geometry","q":"A bus travels a distance of 210 km in 1 hour and 45 minutes. What is its average speed in km/h?","o":["110 km/h","120 km/h","105 km/h","130 km/h"],"a":1,"e":"First, convert the time to hours: 1 hour and 45 minutes = 1.75 hours. Speed = Distance / Time = 210 km / 1.75 h = 120 km/h.","d":2,"s":"4.4"},{"id":"ev0955","cat":"edx-geometry","topic":"Geometry","q":"Convert 3.4 $\\text{m}^2$ to $\\text{cm}^2$.","o":["340 $\\text{cm}^2$","3400 $\\text{cm}^2$","34000 $\\text{cm}^2$","340000 $\\text{cm}^2$"],"a":2,"e":"Since 1 m = 100 cm, then 1 $\\text{m}^2$ = $(100 cm)^2 = 10000 \\text{cm}^2$. Therefore, 3.4 $\\text{m}^2$ = 3.4 \\times 10000 $\\text{cm}^2 = 34000 \\text{cm}^2$.","d":2,"s":"4.4"},{"id":"ev0956","cat":"edx-geometry","topic":"Geometry","q":"Convert 0.6 $\\text{m}^2$ to $\\text{cm}^2$.","o":["60 $\\text{cm}^2$","600 $\\text{cm}^2$","6000 $\\text{cm}^2$","60000 $\\text{cm}^2$"],"a":2,"e":"Since 1 m = 100 cm, then 1 $\\text{m}^2$ = $(100 cm)^2 = 10000 \\text{cm}^2$. Therefore, 0.6 $\\text{m}^2$ = 0.6 \\times 10000 $\\text{cm}^2 = 6000 \\text{cm}^2$.","d":2,"s":"4.4"},{"id":"ev0957","cat":"edx-geometry","topic":"Geometry","q":"Convert 8.1 $\\text{m}^2$ to $\\text{cm}^2$.","o":["81000 $\\text{cm}^2$","8100 $\\text{cm}^2$","810000 $\\text{cm}^2$","810 $\\text{cm}^2$"],"a":0,"e":"Since 1 m = 100 cm, then 1 $\\text{m}^2$ = $(100 cm)^2 = 10000 \\text{cm}^2$. Therefore, 8.1 $\\text{m}^2$ = 8.1 \\times 10000 $\\text{cm}^2 = 81000 \\text{cm}^2$.","d":2,"s":"4.4"}]
