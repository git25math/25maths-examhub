[{"id":"hv0843","cat":"geometry","topic":"Mastery of Angles","q":"What is the sum of the interior angles of a pentagon?","o":["$360¬į$","$540¬į$","$720¬į$","$1080¬į$"],"a":1,"e":"Sum of interior angles $= (n-2) \\times 180¬į = (5-2) \\times 180¬į = 540¬į$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0844","cat":"geometry","topic":"Mastery of Angles","q":"Find the sum of the interior angles of a heptagon (7-sided polygon).","o":["$900¬į$","$1080¬į$","$720¬į$","$1260¬į$"],"a":0,"e":"Sum of interior angles $= (n-2) \\times 180¬į = (7-2) \\times 180¬į = 900¬į$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0845","cat":"geometry","topic":"Mastery of Angles","q":"Calculate the sum of the interior angles of an octagon.","o":["$1260¬į$","$720¬į$","$1080¬į$","$900¬į$"],"a":2,"e":"Sum of interior angles $= (n-2) \\times 180¬į = (8-2) \\times 180¬į = 1080¬į$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0846","cat":"geometry","topic":"Mastery of Angles","q":"Each exterior angle of a regular polygon is $45¬į$. How many sides does it have?","o":["$4$","$6$","$8$","$10$"],"a":2,"e":"Number of sides $= \\dfrac{360¬į}{45¬į} = 8$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0847","cat":"geometry","topic":"Mastery of Angles","q":"A regular polygon has exterior angles of $40¬į$. How many sides does this polygon have?","o":["$9$","$12$","$8$","$10$"],"a":0,"e":"Number of sides $= \\dfrac{360¬į}{40¬į} = 9$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0848","cat":"geometry","topic":"Mastery of Angles","q":"The exterior angle of a regular polygon is $24¬į$. Determine the number of sides.","o":["$12$","$15$","$18$","$20$"],"a":1,"e":"Number of sides $= \\dfrac{360¬į}{24¬į} = 15$.","d":1,"s":"Y9.4","diag":"calc"},{"id":"hv0849","cat":"geometry","topic":"Mastery of Angles","q":"What is the size of each interior angle of a regular decagon (10-sided polygon)?","o":["$144¬į$","$135¬į$","$150¬į$","$140¬į$"],"a":0,"e":"Interior angle $= \\dfrac{(10-2) \\times 180¬į}{10} = \\dfrac{1440¬į}{10} = 144¬į$.","d":2,"s":"Y9.4","diag":"calc"},{"id":"hv0850","cat":"geometry","topic":"Mastery of Angles","q":"Calculate the size of each interior angle of a regular dodecagon (12-sided polygon).","o":["$144¬į$","$160¬į$","$156¬į$","$150¬į$"],"a":3,"e":"Interior angle $= \\dfrac{(12-2) \\times 180¬į}{12} = \\dfrac{1800¬į}{12} = 150¬į$.","d":2,"s":"Y9.4","diag":"calc"},{"id":"hv0851","cat":"geometry","topic":"Mastery of Angles","q":"Find the size of each interior angle of a regular nonagon (9-sided polygon).","o":["$135¬į$","$140¬į$","$120¬į$","$144¬į$"],"a":1,"e":"Interior angle $= \\dfrac{(9-2) \\times 180¬į}{9} = \\dfrac{1260¬į}{9} = 140¬į$.","d":2,"s":"Y9.4","diag":"calc"},{"id":"hv0852","cat":"geometry","topic":"Mastery of Angles","q":"Four interior angles of a pentagon are $100¬į$, $105¬į$, $115¬į$ and $125¬į$. Find the fifth angle, $x$ .","o":["$85$","$95$","$105$","$75$"],"a":1,"e":"Sum $= (5-2) \\times 180¬į = 540¬į$. So $x = 540 - (100 + 105 + 115 + 125) = 540 - 445 = 95$.","d":2,"s":"Y9.4","diag":"calc"},{"id":"hv0853","cat":"geometry","topic":"Mastery of Angles","q":"The interior angles of a pentagon are $120¬į$, $110¬į$, $100¬į$, $90¬į$ and $x¬į$. Find the value of $x$.","o":["$120$","$110$","$130$","$100$"],"a":0,"e":"Sum $= 540¬į$. So $x = 540 - (120 + 110 + 100 + 90) = 540 - 420 = 120$.","d":2,"s":"Y9.4","diag":"calc"},{"id":"hv0854","cat":"geometry","topic":"Mastery of Angles","q":"A pentagon has interior angles of $125¬į$, $95¬į$, $110¬į$, $100¬į$ and $x¬į$. Calculate the value of $x$.","o":["$100$","$120$","$110$","$115$"],"a":2,"e":"Sum $= 540¬į$. So $x = 540 - (125 + 95 + 110 + 100) = 540 - 430 = 110$.","d":2,"s":"Y9.4","diag":"calc"}]
