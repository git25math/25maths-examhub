[{"id":"hv0630","cat":"geometry","topic":"Cylinders and Cones","q":"Find the volume of a cylinder with radius $2$ cm and height $5$ cm. (Use $\\pi \\approx 3.14$)","o":["$62.8$ cm$^3$","$31.4$ cm$^3$","$125.6$ cm$^3$","$20$ cm$^3$"],"a":0,"e":"$V = \\pi r^2 h = 3.14 \\times 2^2 \\times 5 = 3.14 \\times 4 \\times 5 = 62.8$ cm$^3$.","d":1,"s":"Y7.8","diag":"calc"},{"id":"hv0631","cat":"geometry","topic":"Cylinders and Cones","q":"A cylindrical container has a radius of $4$ cm and a height of $10$ cm. Calculate its volume. (Use $\\pi \\approx 3.14$)","o":["$502.4$ cm$^3$","$251.2$ cm$^3$","$125.6$ cm$^3$","$160$ cm$^3$"],"a":0,"e":"$V = \\pi r^2 h = 3.14 \\times 4^2 \\times 10 = 3.14 \\times 16 \\times 10 = 502.4$ cm$^3$.","d":1,"s":"Y7.8","diag":"calc"},{"id":"hv0632","cat":"geometry","topic":"Cylinders and Cones","q":"Calculate the volume of a cylinder that has a radius of $5$ cm and a height of $2$ cm. (Use $\\pi \\approx 3.14$)","o":["$157$ cm$^3$","$78.5$ cm$^3$","$314$ cm$^3$","$50$ cm$^3$"],"a":0,"e":"$V = \\pi r^2 h = 3.14 \\times 5^2 \\times 2 = 3.14 \\times 25 \\times 2 = 157$ cm$^3$.","d":1,"s":"Y7.8","diag":"calc"},{"id":"hv0633","cat":"geometry","topic":"Cylinders and Cones","q":"If a cylinder and a cone have the same radius and height, the volume of the cone is:","o":["$\\frac{1}{3} \\times$ Volume of Cylinder","$\\frac{1}{2} \\times$ Volume of Cylinder","$3 \\times$ Volume of Cylinder","Equal to the Volume of Cylinder"],"a":0,"e":"The volume of a cone is exactly one-third the volume of a cylinder with the same base area and height.","d":1,"s":"Y7.8","diag":"concept"},{"id":"hv0634","cat":"geometry","topic":"Cylinders and Cones","q":"A cone has base radius $r$ and vertical height $h$. Which formula correctly expresses its volume?","o":["$\\frac{1}{3}\\pi r^2 h$","$\\pi r^2 h$","$2\\pi r h$","$\\frac{1}{3}\\pi r h$"],"a":0,"e":"The standard formula for the volume of a cone is $V = \\frac{1}{3}\\pi r^2 h$.","d":1,"s":"Y7.8","diag":"concept"},{"id":"hv0635","cat":"geometry","topic":"Cylinders and Cones","q":"A cylinder has a volume of $450$ cm$^3$. What is the volume of a cone with the same base and height?","o":["$150$ cm$^3$","$450$ cm$^3$","$225$ cm$^3$","$1,350$ cm$^3$"],"a":0,"e":"Volume of cone $= \\frac{1}{3} \\times$ Volume of cylinder $= \\frac{1}{3} \\times 450 = 150$ cm$^3$.","d":1,"s":"Y7.8","diag":"concept"},{"id":"hv0636","cat":"geometry","topic":"Cylinders and Cones","q":"Find the curved surface area of a cylinder with radius $3$ cm and height $8$ cm. (Use $\\pi \\approx 3.14$)","o":["$150.72$ cm$^2$","$75.36$ cm$^2$","$226.08$ cm$^2$","$48$ cm$^2$"],"a":0,"e":"Curved SA $= 2\\pi rh = 2 \\times 3.14 \\times 3 \\times 8 = 150.72$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},{"id":"hv0637","cat":"geometry","topic":"Cylinders and Cones","q":"A cylindrical pipe has a radius of $5$ cm and a length of $6$ cm. Find its curved surface area. (Use $\\pi \\approx 3.14$)","o":["$188.4$ cm$^2$","$94.2$ cm$^2$","$376.8$ cm$^2$","$60$ cm$^2$"],"a":0,"e":"Curved SA $= 2\\pi rh = 2 \\times 3.14 \\times 5 \\times 6 = 188.4$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},{"id":"hv0638","cat":"geometry","topic":"Cylinders and Cones","q":"Calculate the curved surface area of a cylinder with radius $4$ cm and height $5$ cm. (Use $\\pi \\approx 3.14$)","o":["$125.6$ cm$^2$","$62.8$ cm$^2$","$251.2$ cm$^2$","$40$ cm$^2$"],"a":0,"e":"Curved SA $= 2\\pi rh = 2 \\times 3.14 \\times 4 \\times 5 = 125.6$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},{"id":"hv0639","cat":"geometry","topic":"Cylinders and Cones","q":"A cone has radius $3$ cm and slant height $5$ cm. Find the total surface area. (Use $\\pi \\approx 3.14$)","o":["$75.36$ cm$^2$","$47.1$ cm$^2$","$28.26$ cm$^2$","$56.52$ cm$^2$"],"a":0,"e":"Total SA $= \\pi r l + \\pi r^2 = (3.14 \\times 3 \\times 5) + (3.14 \\times 3^2) = 47.1 + 28.26 = 75.36$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},{"id":"hv0640","cat":"geometry","topic":"Cylinders and Cones","q":"Calculate the total surface area of a cone with radius $6$ cm and slant height $10$ cm. (Use $\\pi \\approx 3.14$)","o":["$301.44$ cm$^2$","$188.4$ cm$^2$","$113.04$ cm$^2$","$226.08$ cm$^2$"],"a":0,"e":"Total SA $= \\pi r l + \\pi r^2 = (3.14 \\times 6 \\times 10) + (3.14 \\times 6^2) = 188.4 + 113.04 = 301.44$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},{"id":"hv0641","cat":"geometry","topic":"Cylinders and Cones","q":"A cone has radius $8$ cm and slant height $17$ cm. Find the total surface area. (Use $\\pi \\approx 3.14$)","o":["$628$ cm$^2$","$427.04$ cm$^2$","$200.96$ cm$^2$","$512$ cm$^2$"],"a":0,"e":"Total SA $= \\pi r l + \\pi r^2 = (3.14 \\times 8 \\times 17) + (3.14 \\times 8^2) = 427.04 + 200.96 = 628$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"}]
