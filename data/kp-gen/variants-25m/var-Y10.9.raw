[{"id":"hv0408","cat":"geometry","topic":"Congruence and Similarity","q":"Two triangles are similar. The ratio of their corresponding sides is $3:4$. What is the ratio of their areas?","o":["$3:4$","$6:8$","$9:16$","$27:64$"],"a":2,"e":"For similar shapes, the area ratio is the square of the length ratio: $(3)^2:(4)^2 = 9:16$.","d":1,"s":"Y10.9","diag":"calc"},{"id":"hv0409","cat":"geometry","topic":"Congruence and Similarity","q":"Two triangles are similar. The ratio of their corresponding sides is $5:6$. What is the ratio of their areas?","o":["$5:6$","$25:36$","$10:12$","$125:216$"],"a":1,"e":"For similar shapes, the area ratio is the square of the length ratio: $(5)^2:(6)^2 = 25:36$.","d":1,"s":"Y10.9","diag":"calc"},{"id":"hv0410","cat":"geometry","topic":"Congruence and Similarity","q":"Two triangles are similar. The ratio of their corresponding sides is $4:9$. What is the ratio of their areas?","o":["$4:9$","$16:18$","$8:27$","$16:81$"],"a":3,"e":"For similar shapes, the area ratio is the square of the length ratio: $(4)^2:(9)^2 = 16:81$.","d":1,"s":"Y10.9","diag":"calc"},{"id":"hv0411","cat":"geometry","topic":"Congruence and Similarity","q":"Which of the following criteria is NOT sufficient to prove that two triangles are congruent?","o":["SAS","SSS","AAA","ASA"],"a":2,"e":"AAA (angle-angle-angle) only proves that triangles are similar. They could be different sizes, so they are not necessarily congruent.","d":1,"s":"Y10.9","diag":"concept"},{"id":"hv0412","cat":"geometry","topic":"Congruence and Similarity","q":"A student attempts to prove two triangles are congruent using various conditions. Which condition is invalid for proving congruence?","o":["AAA","RHS","SSS","SAS"],"a":0,"e":"AAA proves similarity but not congruence, as the side lengths could be scaled differently while keeping the same angles.","d":1,"s":"Y10.9","diag":"concept"},{"id":"hv0413","cat":"geometry","topic":"Congruence and Similarity","q":"In triangle geometry, which of these sets of information does NOT guarantee that two triangles are congruent?","o":["Three sides are equal (SSS)","Two sides and the included angle are equal (SAS)","Three angles are equal (AAA)","A right angle, hypotenuse, and one side are equal (RHS)"],"a":2,"e":"AAA guarantees the triangles have the same shape (similarity), but not the same size (congruence).","d":1,"s":"Y10.9","diag":"concept"},{"id":"hv0414","cat":"geometry","topic":"Congruence and Similarity","q":"Two similar cylinders have heights $4$ cm and $6$ cm. If the volume of the smaller cylinder is $16$ cm³, find the volume of the larger cylinder.","o":["$24$ cm³","$36$ cm³","$54$ cm³","$81$ cm³"],"a":2,"e":"Scale factor $= \\frac{6}{4} = 1.5$. Volume ratio $= 1.5^3 = 3.375$. Volume $= 16 \\times 3.375 = 54$ cm³.","d":2,"s":"Y10.9","diag":"calc"},{"id":"hv0415","cat":"geometry","topic":"Congruence and Similarity","q":"Two similar solid spheres have radii of $6$ cm and $12$ cm. If the volume of the smaller sphere is $25$ cm³, what is the volume of the larger sphere?","o":["$50$ cm³","$100$ cm³","$200$ cm³","$150$ cm³"],"a":2,"e":"Scale factor $= \\frac{12}{6} = 2$. Volume ratio $= 2^3 = 8$. Volume $= 25 \\times 8 = 200$ cm³.","d":2,"s":"Y10.9","diag":"calc"},{"id":"hv0416","cat":"geometry","topic":"Congruence and Similarity","q":"Two similar cones have heights of $10$ cm and $20$ cm. If the volume of the smaller cone is $40$ cm³, calculate the volume of the larger cone.","o":["$80$ cm³","$160$ cm³","$120$ cm³","$320$ cm³"],"a":3,"e":"Scale factor $= \\frac{20}{10} = 2$. Volume ratio $= 2^3 = 8$. Volume $= 40 \\times 8 = 320$ cm³.","d":2,"s":"Y10.9","diag":"calc"},{"id":"hv0417","cat":"geometry","topic":"Congruence and Similarity","q":"Triangle $PQR$ is similar to triangle $XYZ$. If $PQ=2$, $XY=5$, and the area of $PQR$ is $4$ cm², what is the area of $XYZ$?","o":["$10$ cm²","$25$ cm²","$20$ cm²","$12.5$ cm²"],"a":1,"e":"Scale factor $= \\frac{5}{2} = 2.5$. Area ratio $= 2.5^2 = 6.25$. Area of $XYZ = 4 \\times 6.25 = 25$ cm².","d":2,"s":"Y10.9","diag":"calc"},{"id":"hv0418","cat":"geometry","topic":"Congruence and Similarity","q":"Triangle $LMN$ is similar to triangle $OPQ$. If $LM=6$, $OP=9$, and the area of $LMN$ is $12$ cm², what is the area of $OPQ$?","o":["$18$ cm²","$27$ cm²","$24$ cm²","$36$ cm²"],"a":1,"e":"Scale factor $= \\frac{9}{6} = 1.5$. Area ratio $= 1.5^2 = 2.25$. Area of $OPQ = 12 \\times 2.25 = 27$ cm².","d":2,"s":"Y10.9","diag":"calc"},{"id":"hv0419","cat":"geometry","topic":"Congruence and Similarity","q":"Triangle $STU$ is similar to triangle $VWX$. If $ST=4$, $VW=10$, and the area of $STU$ is $8$ cm², what is the area of $VWX$?","o":["$20$ cm²","$40$ cm²","$50$ cm²","$80$ cm²"],"a":2,"e":"Scale factor $= \\frac{10}{4} = 2.5$. Area ratio $= 2.5^2 = 6.25$. Area of $VWX = 8 \\times 6.25 = 50$ cm².","d":2,"s":"Y10.9","diag":"calc"}]
