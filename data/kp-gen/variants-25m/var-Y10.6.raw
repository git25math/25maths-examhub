[{"id":"hv0372","cat":"geometry","topic":"Further Trigonometry","q":"Which of the following represents the area of a triangle with sides $x$ and $y$ and included angle $Z$?","o":["$\\frac{1}{2}xy\\sin Z$","$xy\\sin Z$","$\\frac{1}{2}xy\\cos Z$","$\\frac{1}{2}xy\\tan Z$"],"a":0,"e":"The area of a triangle is given by the formula $\\frac{1}{2}ab\\sin C$, where $a$ and $b$ are two sides and $C$ is the included angle. Here, the sides are $x$ and $y$ and the angle is $Z$.","d":1,"s":"Y10.6","diag":"vocab"},{"id":"hv0373","cat":"geometry","topic":"Further Trigonometry","q":"The area of a triangle $PQR$ with sides $p$, $q$ and included angle $R$ is calculated as:","o":["$\\frac{1}{2}pq\\cos R$","$\\frac{1}{2}pq\\sin R$","$pq\\sin R$","$pq\\cos R$"],"a":1,"e":"Using the trigonometric area formula $\\frac{1}{2}ab\\sin C$, for sides $p$ and $q$ with included angle $R$, the area is $\\frac{1}{2}pq\\sin R$.","d":1,"s":"Y10.6","diag":"vocab"},{"id":"hv0374","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $LMN$, the area can be found using the formula:","o":["$lm\\sin N$","$\\frac{1}{2}lm\\cos N$","$\\frac{1}{2}lm\\sin N$","$\\frac{1}{2}lm\\tan N$"],"a":2,"e":"The area of any triangle is half the product of two sides and the sine of the angle between them. For sides $l$ and $m$, the included angle is $N$, so the area is $\\frac{1}{2}lm\\sin N$.","d":1,"s":"Y10.6","diag":"vocab"},{"id":"hv0375","cat":"geometry","topic":"Further Trigonometry","q":"Find the area of a triangle with sides $a=4$ cm, $b=12$ cm and included angle $C=30Â°$.","o":["$12$ cmÂ²","$24$ cmÂ²","$48$ cmÂ²","$6$ cmÂ²"],"a":0,"e":"Area $= \\frac{1}{2}(4)(12)\\sin 30Â° = 24 \\times 0.5 = 12$ cmÂ².","d":1,"s":"Y10.6","diag":"calc"},{"id":"hv0376","cat":"geometry","topic":"Further Trigonometry","q":"Find the area of a triangle with sides $x=10$ cm, $y=14$ cm and included angle $Z=30Â°$.","o":["$70$ cmÂ²","$35$ cmÂ²","$140$ cmÂ²","$17.5$ cmÂ²"],"a":1,"e":"Area $= \\frac{1}{2}(10)(14)\\sin 30Â° = 70 \\times 0.5 = 35$ cmÂ².","d":1,"s":"Y10.6","diag":"calc"},{"id":"hv0377","cat":"geometry","topic":"Further Trigonometry","q":"Find the area of a triangle with sides $p=8$ cm, $q=15$ cm and included angle $R=30Â°$.","o":["$60$ cmÂ²","$15$ cmÂ²","$120$ cmÂ²","$30$ cmÂ²"],"a":3,"e":"Area $= \\frac{1}{2}(8)(15)\\sin 30Â° = 60 \\times 0.5 = 30$ cmÂ².","d":1,"s":"Y10.6","diag":"calc"},{"id":"hv0378","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $ABC$, $a=10$, $A=45Â°$, $B=60Â°$. Using the sine rule, find $b$ to 1 d.p.","o":["$12.2$","$15.0$","$8.7$","$10.0$"],"a":0,"e":"$\\frac{a}{\\sin A} = \\frac{b}{\\sin B}$. $\\frac{10}{\\sin 45Â°} = \\frac{b}{\\sin 60Â°}$. $b = \\frac{10 \\times \\sin 60Â°}{\\sin 45Â°} = \\frac{10 \\times 0.8660}{0.7071} = 12.2$.","d":2,"s":"Y10.6","diag":"calc"},{"id":"hv0379","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $XYZ$, $x=12$, $X=40Â°$, $Y=70Â°$. Using the sine rule, find $y$ to 1 d.p.","o":["$11.3$","$18.2$","$17.5$","$15.6$"],"a":2,"e":"$\\frac{x}{\\sin X} = \\frac{y}{\\sin Y}$. $\\frac{12}{\\sin 40Â°} = \\frac{y}{\\sin 70Â°}$. $y = \\frac{12 \\times \\sin 70Â°}{\\sin 40Â°} = \\frac{12 \\times 0.9397}{0.6428} = 17.5$.","d":2,"s":"Y10.6","diag":"calc"},{"id":"hv0380","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $PQR$, $p=6$, $P=25Â°$, $Q=55Â°$. Using the sine rule, find $q$ to 1 d.p.","o":["$8.4$","$11.6$","$13.1$","$9.8$"],"a":1,"e":"$\\frac{p}{\\sin P} = \\frac{q}{\\sin Q}$. $\\frac{6}{\\sin 25Â°} = \\frac{q}{\\sin 55Â°}$. $q = \\frac{6 \\times \\sin 55Â°}{\\sin 25Â°} = \\frac{6 \\times 0.8192}{0.4226} = 11.6$.","d":2,"s":"Y10.6","diag":"calc"},{"id":"hv0381","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $ABC$, $a=4$, $b=6$, $C=60Â°$. Find $c$ using the cosine rule.","o":["$\\sqrt{52}$","$\\sqrt{28}$","$\\sqrt{76}$","$\\sqrt{40}$"],"a":1,"e":"$c^2 = a^2+b^2-2ab\\cos C = 16+36-2(4)(6)\\cos 60Â° = 52-48(0.5) = 52-24 = 28$. So $c=\\sqrt{28}$.","d":2,"s":"Y10.6","diag":"calc"},{"id":"hv0382","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $XYZ$, $x=2$, $y=5$, $Z=60Â°$. Find $z$ using the cosine rule.","o":["$\\sqrt{29}$","$\\sqrt{19}$","$\\sqrt{39}$","$\\sqrt{21}$"],"a":1,"e":"$z^2 = x^2+y^2-2xy\\cos Z = 4+25-2(2)(5)\\cos 60Â° = 29-20(0.5) = 29-10 = 19$. So $z=\\sqrt{19}$.","d":2,"s":"Y10.6","diag":"calc"},{"id":"hv0383","cat":"geometry","topic":"Further Trigonometry","q":"In triangle $PQR$, $p=8$, $q=10$, $R=60Â°$. Find $r$ using the cosine rule.","o":["$\\sqrt{164}$","$\\sqrt{144}$","$\\sqrt{184}$","$\\sqrt{84}$"],"a":3,"e":"$r^2 = p^2+q^2-2pq\\cos R = 64+100-2(8)(10)\\cos 60Â° = 164-160(0.5) = 164-80 = 84$. So $r=\\sqrt{84}$.","d":2,"s":"Y10.6","diag":"calc"}]
