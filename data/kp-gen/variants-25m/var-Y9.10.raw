[{"id":"hv0783","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{8x^2}{2x}$.","o":["$4x^2$","$6x$","$4x$","$x^2$"],"a":2,"e":"$\\dfrac{8x^2}{2x} = \\dfrac{8}{2} \\times \\dfrac{x^2}{x} = 4x$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0784","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{15y^2}{5y}$.","o":["$3y$","$10y$","$3y^2$","$5y$"],"a":0,"e":"$\\dfrac{15y^2}{5y} = \\dfrac{15}{5} \\times \\dfrac{y^2}{y} = 3y$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0785","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{12a^2}{4a}$.","o":["$8a$","$3a^2$","$3$","$3a$"],"a":3,"e":"$\\dfrac{12a^2}{4a} = \\dfrac{12}{4} \\times \\dfrac{a^2}{a} = 3a$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0786","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{x^2 - 16}{x + 4}$.","o":["$x + 4$","$x - 16$","$\\dfrac{x-16}{x+4}$","$x - 4$"],"a":3,"e":"$\\dfrac{x^2 - 16}{x + 4} = \\dfrac{(x+4)(x-4)}{x+4} = x - 4$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0787","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{y^2 - 25}{y - 5}$.","o":["$y + 5$","$y - 5$","$y + 25$","$y^2 - 5$"],"a":0,"e":"$\\dfrac{y^2 - 25}{y - 5} = \\dfrac{(y+5)(y-5)}{y-5} = y + 5$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0788","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{a^2 - 1}{a + 1}$.","o":["$a + 1$","$a - 1$","$a - 2$","$1$"],"a":1,"e":"$\\dfrac{a^2 - 1}{a + 1} = \\dfrac{(a+1)(a-1)}{a+1} = a - 1$.","d":1,"s":"Y9.10","diag":"calc"},{"id":"hv0789","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{4}{y} + \\dfrac{5}{y}$.","o":["$\\dfrac{9}{y}$","$\\dfrac{20}{y^2}$","$\\dfrac{9}{2y}$","$\\dfrac{20}{y}$"],"a":0,"e":"$\\dfrac{4}{y} + \\dfrac{5}{y} = \\dfrac{4+5}{y} = \\dfrac{9}{y}$.","d":2,"s":"Y9.10","diag":"calc"},{"id":"hv0790","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{7}{x} - \\dfrac{2}{x}$.","o":["$\\dfrac{9}{x}$","$\\dfrac{5}{x^2}$","$\\dfrac{5}{x}$","$\\dfrac{14}{x}$"],"a":2,"e":"$\\dfrac{7}{x} - \\dfrac{2}{x} = \\dfrac{7-2}{x} = \\dfrac{5}{x}$.","d":2,"s":"Y9.10","diag":"calc"},{"id":"hv0791","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{1}{a} + \\dfrac{6}{a}$.","o":["$\\dfrac{7}{2a}$","$\\dfrac{7}{a}$","$\\dfrac{6}{a^2}$","$\\dfrac{7}{a^2}$"],"a":1,"e":"$\\dfrac{1}{a} + \\dfrac{6}{a} = \\dfrac{1+6}{a} = \\dfrac{7}{a}$.","d":2,"s":"Y9.10","diag":"calc"},{"id":"hv0792","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{2}{x+2} + \\dfrac{1}{x-1}$.","o":["$\\dfrac{3x}{(x+2)(x-1)}$","$\\dfrac{3x+4}{(x+2)(x-1)}$","$\\dfrac{3}{(x+2)(x-1)}$","$\\dfrac{2x+2}{(x+2)(x-1)}$"],"a":0,"e":"$\\dfrac{2(x-1) + 1(x+2)}{(x+2)(x-1)} = \\dfrac{2x - 2 + x + 2}{(x+2)(x-1)} = \\dfrac{3x}{(x+2)(x-1)}$.","d":2,"s":"Y9.10","diag":"calc"},{"id":"hv0793","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{1}{x+3} + \\dfrac{2}{x+1}$.","o":["$\\dfrac{3x+4}{(x+3)(x+1)}$","$\\dfrac{3x+7}{(x+3)(x+1)}$","$\\dfrac{3}{(2x+4)}$","$\\dfrac{3x+6}{(x+3)(x+1)}$"],"a":1,"e":"$\\dfrac{1(x+1) + 2(x+3)}{(x+3)(x+1)} = \\dfrac{x + 1 + 2x + 6}{(x+3)(x+1)} = \\dfrac{3x + 7}{(x+3)(x+1)}$.","d":2,"s":"Y9.10","diag":"calc"},{"id":"hv0794","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\dfrac{3}{x-2} - \\dfrac{1}{x+1}$.","o":["$\\dfrac{2x+1}{(x-2)(x+1)}$","$\\dfrac{4x+1}{(x-2)(x+1)}$","$\\dfrac{2x+5}{(x-2)(x+1)}$","$\\dfrac{2}{(x-2)(x+1)}$"],"a":2,"e":"$\\dfrac{3(x+1) - 1(x-2)}{(x-2)(x+1)} = \\dfrac{3x + 3 - x + 2}{(x-2)(x+1)} = \\dfrac{2x + 5}{(x-2)(x+1)}$.","d":2,"s":"Y9.10","diag":"calc"}]
