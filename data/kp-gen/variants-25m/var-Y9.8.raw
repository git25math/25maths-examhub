[{"id":"hv0891","cat":"probability","topic":"Statistical Sampling","q":"Which sampling method involves assigning a unique number to every member of the population and selecting them using a random number generator?","o":["Stratified sampling","Systematic sampling","Simple random sampling","Quota sampling"],"a":2,"e":"Simple random sampling ensures every individual has an equal and independent chance of being selected.","d":1,"s":"Y9.8","diag":"vocab"},{"id":"hv0892","cat":"probability","topic":"Statistical Sampling","q":"In which type of sampling does every possible group of a specific size have the same probability of being chosen from the population?","o":["Convenience sampling","Simple random sampling","Cluster sampling","Systematic sampling"],"a":1,"e":"This is the fundamental definition of simple random sampling.","d":1,"s":"Y9.8","diag":"vocab"},{"id":"hv0893","cat":"probability","topic":"Statistical Sampling","q":"When a computer picks 50 names at random from a database containing 500 employees, what type of sampling is being performed?","o":["Simple random sampling","Stratified sampling","Opportunity sampling","Systematic sampling"],"a":0,"e":"Because the selection is automated and random across the whole group, it is simple random sampling.","d":1,"s":"Y9.8","diag":"vocab"},{"id":"hv0894","cat":"probability","topic":"Statistical Sampling","q":"A researcher interviews the first 30 people they meet in a shopping mall. What type of sampling is this?","o":["Convenience sampling","Random sampling","Stratified sampling","Systematic sampling"],"a":0,"e":"This is convenience sampling because the researcher is choosing the most easily accessible subjects.","d":1,"s":"Y9.8","diag":"concept"},{"id":"hv0895","cat":"probability","topic":"Statistical Sampling","q":"A teacher asks only the students sitting in the front row for their opinion on the school's new uniform policy. This is an example of:","o":["Stratified sampling","Convenience sampling","Random sampling","Systematic sampling"],"a":1,"e":"The teacher is selecting students based on their proximity and ease of access, which defines convenience sampling.","d":1,"s":"Y9.8","diag":"concept"},{"id":"hv0896","cat":"probability","topic":"Statistical Sampling","q":"To save time, a manager asks the five employees whose offices are closest to theirs for feedback on a new system. This method is called:","o":["Random sampling","Stratified sampling","Systematic sampling","Convenience sampling"],"a":3,"e":"Choosing participants based on being nearby or easy to reach is convenience sampling.","d":1,"s":"Y9.8","diag":"concept"},{"id":"hv0897","cat":"probability","topic":"Statistical Sampling","q":"A sports club has 120 adults and 80 children. For a stratified sample of 40 members, how many children should be selected?","o":["$16$","$24$","$20$","$8$"],"a":0,"e":"Total population $= 120 + 80 = 200$. Proportion of children $= \\dfrac{80}{200} = 0.4$. Number of children in sample $= 0.4 \\times 40 = 16$.","d":2,"s":"Y9.8","diag":"calc"},{"id":"hv0898","cat":"probability","topic":"Statistical Sampling","q":"A company has 300 managers and 700 workers. For a stratified sample of 100 employees, how many managers should be selected?","o":["$70$","$30$","$50$","$10$"],"a":1,"e":"Total population $= 300 + 700 = 1000$. Proportion of managers $= \\dfrac{300}{1000} = 0.3$. Number of managers in sample $= 0.3 \\times 100 = 30$.","d":2,"s":"Y9.8","diag":"calc"},{"id":"hv0899","cat":"probability","topic":"Statistical Sampling","q":"A library has 2000 fiction books and 3000 non-fiction books. For a stratified sample of 200 books, how many fiction books should be included?","o":["$120$","$100$","$80$","$40$"],"a":2,"e":"Total population $= 2000 + 3000 = 5000$. Proportion of fiction books $= \\dfrac{2000}{5000} = 0.4$. Number of fiction books in sample $= 0.4 \\times 200 = 80$.","d":2,"s":"Y9.8","diag":"calc"},{"id":"hv0900","cat":"probability","topic":"Statistical Sampling","q":"Which of these factors is most likely to introduce bias into a survey about exercise habits?","o":["Using a large random sample","Asking people at a gym how often they exercise","Using a computer to pick participants","Ensuring the sample reflects the population age groups"],"a":1,"e":"Asking people at a gym creates bias because they are significantly more likely to exercise than the general population, making the sample unrepresentative.","d":2,"s":"Y9.8","diag":"concept"},{"id":"hv0901","cat":"probability","topic":"Statistical Sampling","q":"What is a common source of bias in a telephone survey conducted only during working hours on weekdays?","o":["The cost of the phone calls","Excluding people who are at work","Using a random number dialer","The duration of the interview"],"a":1,"e":"Conducting the survey during working hours excludes a large portion of the population (those with jobs), leading to a biased, unrepresentative sample.","d":2,"s":"Y9.8","diag":"concept"},{"id":"hv0902","cat":"probability","topic":"Statistical Sampling","q":"Which of the following would be a source of bias when surveying students about the quality of school canteen food?","o":["Surveying every 5th student on the school register","Only surveying students who are currently in the canteen buying lunch","Picking 50 students at random from the whole school","Using a stratified sample based on gender"],"a":1,"e":"Only surveying students in the canteen excludes those who bring packed lunches or eat elsewhere because they dislike the food, leading to biased results.","d":2,"s":"Y9.8","diag":"concept"}]
