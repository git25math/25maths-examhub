[
  {"id":"hv0720","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two straight lines cross. One angle is $48°$. What is the vertically opposite angle?","o":["$132°$","$48°$","$42°$","$96°$"],"a":1,"e":"Vertically opposite angles are equal, so the angle is $48°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0721","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two straight lines cross. One angle is $135°$. What is the vertically opposite angle?","o":["$45°$","$135°$","$90°$","$270°$"],"a":1,"e":"Vertically opposite angles are equal, so the angle is $135°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0722","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two straight lines cross. One angle is $76°$. What is the vertically opposite angle?","o":["$104°$","$76°$","$14°$","$152°$"],"a":1,"e":"Vertically opposite angles are equal, so the angle is $76°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0723","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two parallel lines are cut by a transversal. One alternate angle is $63°$. What is the other?","o":["$63°$","$117°$","$27°$","$126°$"],"a":0,"e":"Alternate angles between parallel lines are equal: $63°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0724","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two parallel lines are cut by a transversal. One alternate angle is $124°$. What is the other?","o":["$124°$","$56°$","$62°$","$248°$"],"a":0,"e":"Alternate angles between parallel lines are equal: $124°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0725","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two parallel lines are cut by a transversal. One alternate angle is $85°$. What is the other?","o":["$85°$","$95°$","$5°$","$170°$"],"a":0,"e":"Alternate angles between parallel lines are equal: $85°$.","d":1,"s":"Y8.6","diag":"concept"},
  {"id":"hv0726","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"When two parallel lines are cut by a transversal, the sum of the co-interior angles is:","o":["$90°$","$360°$","$270°$","$180°$"],"a":3,"e":"Co-interior angles are supplementary, meaning they sum to $180°$.","d":1,"s":"Y8.6","diag":"vocab"},
  {"id":"hv0727","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"If two parallel lines are intersected by a transversal, the interior angles on the same side add up to:","o":["$90°$","$120°$","$270°$","$180°$"],"a":3,"e":"Interior angles on the same side of a transversal (co-interior) sum to $180°$.","d":1,"s":"Y8.6","diag":"vocab"},
  {"id":"hv0728","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"The sum of consecutive interior angles (co-interior angles) between parallel lines is:","o":["$90°$","$360°$","$270°$","$180°$"],"a":3,"e":"Consecutive interior angles between parallel lines are supplementary ($180°$).","d":1,"s":"Y8.6","diag":"vocab"},
  {"id":"hv0729","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"A transversal crosses two parallel lines. A corresponding angle is $130°$. What is its co-interior partner on the same side?","o":["$130°$","$50°$","$90°$","$180°$"],"a":1,"e":"The co-interior angle on the same side is $180° - 130° = 50°$.","d":2,"s":"Y8.6","diag":"calc"},
  {"id":"hv0730","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"A transversal crosses two parallel lines. A corresponding angle is $75°$. What is its co-interior partner on the same side?","o":["$75°$","$105°$","$90°$","$180°$"],"a":1,"e":"The co-interior angle on the same side is $180° - 75° = 105°$.","d":2,"s":"Y8.6","diag":"calc"},
  {"id":"hv0731","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"A transversal crosses two parallel lines. A corresponding angle is $115°$. What is its co-interior partner on the same side?","o":["$115°$","$65°$","$90°$","$180°$"],"a":1,"e":"The co-interior angle on the same side is $180° - 115° = 65°$.","d":2,"s":"Y8.6","diag":"calc"},
  {"id":"hv0732","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two lines intersect. One angle is $x°$ and the adjacent angle is $(3x + 20)°$. Find $x$.","o":["$30$","$40$","$50$","$60$"],"a":1,"e":"Adjacent angles on a straight line sum to $180°$: $x + 3x + 20 = 180 \\Rightarrow 4x = 160 \\Rightarrow x = 40$.","d":2,"s":"Y8.6","diag":"calc"},
  {"id":"hv0733","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two lines intersect. One angle is $x°$ and the adjacent angle is $(2x + 45)°$. Find $x$.","o":["$45$","$35$","$55$","$65$"],"a":0,"e":"Adjacent angles on a straight line sum to $180°$: $x + 2x + 45 = 180 \\Rightarrow 3x = 135 \\Rightarrow x = 45$.","d":2,"s":"Y8.6","diag":"calc"},
  {"id":"hv0734","cat":"geometry","topic":"Intersecting Lines and Parallel Lines","q":"Two lines intersect. One angle is $x°$ and the adjacent angle is $(4x + 30)°$. Find $x$.","o":["$20$","$25$","$30$","$35$"],"a":2,"e":"Adjacent angles on a straight line sum to $180°$: $x + 4x + 30 = 180 \\Rightarrow 5x = 150 \\Rightarrow x = 30$.","d":2,"s":"Y8.6","diag":"calc"}
]
