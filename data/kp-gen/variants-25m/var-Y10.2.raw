[{"id":"hv0324","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{8y^2}{4y}$.","o":["$4y$","$2y$","$2y^2$","$\\frac{y}{2}$"],"a":1,"e":"$\\frac{8y^2}{4y} = \\frac{8}{4} \\times \\frac{y^2}{y} = 2y$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0325","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{15a^2}{3a}$.","o":["$5a$","$5a^2$","$3a$","$\\frac{a}{5}$"],"a":0,"e":"$\\frac{15a^2}{3a} = \\frac{15}{3} \\times \\frac{a^2}{a} = 5a$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0326","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{12x^3}{4x^2}$.","o":["$3x^2$","$4x$","$3x$","$8x$"],"a":2,"e":"$\\frac{12x^3}{4x^2} = \\frac{12}{4} \\times \\frac{x^3}{x^2} = 3x$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0327","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{x^2 - 9}{x + 3}$.","o":["$x + 3$","$x - 9$","$x - 3$","$x^2 - 3$"],"a":2,"e":"$\\frac{x^2-9}{x+3} = \\frac{(x-3)(x+3)}{x+3} = x-3$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0328","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{y^2 - 25}{y - 5}$.","o":["$y + 5$","$y - 5$","$y + 25$","$y^2 + 5$"],"a":0,"e":"$\\frac{y^2-25}{y-5} = \\frac{(y-5)(y+5)}{y-5} = y+5$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0329","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{x^2 - 16}{x + 4}$.","o":["$x + 4$","$x - 16$","$x - 8$","$x - 4$"],"a":3,"e":"$\\frac{x^2-16}{x+4} = \\frac{(x-4)(x+4)}{x+4} = x-4$.","d":1,"s":"Y10.2","diag":"calc"},{"id":"hv0330","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{3}{x} + \\frac{2}{x+2}$.","o":["$\\frac{5}{2x+2}$","$\\frac{5x+6}{x(x+2)}$","$\\frac{5}{x(x+2)}$","$\\frac{5x+2}{x(x+2)}$"],"a":1,"e":"$\\frac{3}{x}+\\frac{2}{x+2} = \\frac{3(x+2)+2x}{x(x+2)} = \\frac{3x+6+2x}{x(x+2)} = \\frac{5x+6}{x(x+2)}$.","d":2,"s":"Y10.2","diag":"calc"},{"id":"hv0331","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{4}{x} + \\frac{1}{x+3}$.","o":["$\\frac{5x+12}{x(x+3)}$","$\\frac{5}{x+3}$","$\\frac{4x+12}{x(x+3)}$","$\\frac{5x+3}{x(x+3)}$"],"a":0,"e":"$\\frac{4}{x}+\\frac{1}{x+3} = \\frac{4(x+3)+x}{x(x+3)} = \\frac{4x+12+x}{x(x+3)} = \\frac{5x+12}{x(x+3)}$.","d":2,"s":"Y10.2","diag":"calc"},{"id":"hv0332","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{2}{x-1} + \\frac{3}{x}$.","o":["$\\frac{5x-3}{x(x-1)}$","$\\frac{5x-1}{x(x-1)}$","$\\frac{5}{2x-1}$","$\\frac{5x+3}{x(x-1)}$"],"a":0,"e":"$\\frac{2}{x-1}+\\frac{3}{x} = \\frac{2x+3(x-1)}{x(x-1)} = \\frac{2x+3x-3}{x(x-1)} = \\frac{5x-3}{x(x-1)}$.","d":2,"s":"Y10.2","diag":"calc"},{"id":"hv0333","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{x^2-16}{x^2+x-12}$.","o":["$\\frac{x+4}{x-3}$","$\\frac{x-4}{x-3}$","$\\frac{x-4}{x+3}$","$\\frac{x+4}{x+3}$"],"a":1,"e":"$\\frac{x^2-16}{x^2+x-12} = \\frac{(x-4)(x+4)}{(x+4)(x-3)} = \\frac{x-4}{x-3}$.","d":2,"s":"Y10.2","diag":"calc"},{"id":"hv0334","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{x^2-25}{x^2+7x+10}$.","o":["$\\frac{x-5}{x+2}$","$\\frac{x+5}{x+2}$","$\\frac{x-5}{x+5}$","$\\frac{x+5}{x-2}$"],"a":0,"e":"$\\frac{x^2-25}{x^2+7x+10} = \\frac{(x-5)(x+5)}{(x+2)(x+5)} = \\frac{x-5}{x+2}$.","d":2,"s":"Y10.2","diag":"calc"},{"id":"hv0335","cat":"algebra","topic":"Algebraic Fractions","q":"Simplify $\\frac{x^2-1}{x^2+3x+2}$.","o":["$\\frac{x+1}{x+2}$","$\\frac{x-1}{x-2}$","$\\frac{x-1}{x+2}$","$\\frac{x+1}{x-2}$"],"a":2,"e":"$\\frac{x^2-1}{x^2+3x+2} = \\frac{(x-1)(x+1)}{(x+1)(x+2)} = \\frac{x-1}{x+2}$.","d":2,"s":"Y10.2","diag":"calc"}]
