[{"id":"hv0669","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the highest common factor (HCF) of $18$ and $27$?","o":["$6$","$3$","$9$","$18$"],"a":2,"e":"Factors of $18$: $1,2,3,6,9,18$. Factors of $27$: $1,3,9,27$. HCF $= 9$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0670","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the highest common factor (HCF) of $30$ and $45$?","o":["$5$","$15$","$10$","$30$"],"a":1,"e":"Factors of $30$: $1,2,3,5,6,10,15,30$. Factors of $45$: $1,3,5,9,15,45$. HCF $= 15$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0671","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the highest common factor (HCF) of $16$ and $28$?","o":["$4$","$8$","$2$","$14$"],"a":0,"e":"Factors of $16$: $1,2,4,8,16$. Factors of $28$: $1,2,4,7,14,28$. HCF $= 4$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0672","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the lowest common multiple (LCM) of $4$ and $10$?","o":["$40$","$10$","$20$","$4$"],"a":2,"e":"Multiples of $4$: $4,8,12,16,20,\\ldots$ Multiples of $10$: $10,20,\\ldots$ LCM $= 20$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0673","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the lowest common multiple (LCM) of $9$ and $12$?","o":["$36$","$108$","$12$","$18$"],"a":0,"e":"Multiples of $9$: $9,18,27,36,\\ldots$ Multiples of $12$: $12,24,36,\\ldots$ LCM $= 36$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0674","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"What is the lowest common multiple (LCM) of $5$ and $6$?","o":["$11$","$30$","$60$","$1$"],"a":1,"e":"Multiples of $5$: $5,10,15,20,25,30,\\ldots$ Multiples of $6$: $6,12,18,24,30,\\ldots$ LCM $= 30$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0675","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Express $42$ as a product of prime factors.","o":["$2 \\times 3 \\times 7$","$6 \\times 7$","$2 \\times 21$","$2^2 \\times 3 \\times 5$"],"a":0,"e":"$42 = 2 \\times 21 = 2 \\times 3 \\times 7$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0676","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Express $84$ as a product of prime factors.","o":["$2 \\times 3^2 \\times 7$","$2^2 \\times 3 \\times 7$","$4 \\times 21$","$2 \\times 42$"],"a":1,"e":"$84 = 2 \\times 42 = 2 \\times 2 \\times 21 = 2 \\times 2 \\times 3 \\times 7 = 2^2 \\times 3 \\times 7$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0677","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Express $90$ as a product of prime factors.","o":["$3 \\times 30$","$2 \\times 3 \\times 15$","$9 \\times 10$","$2 \\times 3^2 \\times 5$"],"a":3,"e":"$90 = 2 \\times 45 = 2 \\times 3 \\times 15 = 2 \\times 3 \\times 3 \\times 5 = 2 \\times 3^2 \\times 5$.","d":1,"s":"Y8.2","diag":"calc"},{"id":"hv0678","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Which of the following is an irrational number?","o":["$0.75$","$\\sqrt{3}$","$\\frac{1}{3}$","$\\sqrt{4}$"],"a":1,"e":"$\\sqrt{3}$ cannot be written as a simple fraction, whereas $0.75 = \\frac{3}{4}$, $\\frac{1}{3}$ is a fraction, and $\\sqrt{4} = 2$.","d":2,"s":"Y8.2","diag":"concept"},{"id":"hv0679","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Which of the following is an irrational number?","o":["$\\pi$","$\\frac{22}{7}$","$3.14$","$\\sqrt{16}$"],"a":0,"e":"$\\pi$ is a non-repeating, non-terminating decimal that cannot be expressed exactly as a fraction. $\\frac{22}{7}$ and $3.14$ are rational approximations, and $\\sqrt{16} = 4$.","d":2,"s":"Y8.2","diag":"concept"},{"id":"hv0680","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Which of the following is an irrational number?","o":["$\\frac{5}{8}$","$-10$","$0.\\overline{6}$","$\\sqrt{7}$"],"a":3,"e":"$\\sqrt{7}$ is irrational because its decimal expansion never terminates or repeats. $0.\\overline{6} = \\frac{2}{3}$ is rational.","d":2,"s":"Y8.2","diag":"concept"},{"id":"hv0681","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Using prime factorisation, find the LCM of $20$ and $30$.","o":["$10$","$60$","$120$","$600$"],"a":1,"e":"$20 = 2^2 \\times 5$ and $30 = 2 \\times 3 \\times 5$. LCM $= 2^2 \\times 3 \\times 5 = 4 \\times 15 = 60$.","d":2,"s":"Y8.2","diag":"calc"},{"id":"hv0682","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Using prime factorisation, find the LCM of $15$ and $25$.","o":["$75$","$5$","$150$","$375$"],"a":0,"e":"$15 = 3 \\times 5$ and $25 = 5^2$. LCM $= 3 \\times 5^2 = 3 \\times 25 = 75$.","d":2,"s":"Y8.2","diag":"calc"},{"id":"hv0683","cat":"number","topic":"Rational Numbers, Factors and Primes","q":"Using prime factorisation, find the LCM of $14$ and $21$.","o":["$7$","$84$","$42$","$294$"],"a":2,"e":"$14 = 2 \\times 7$ and $21 = 3 \\times 7$. LCM $= 2 \\times 3 \\times 7 = 42$.","d":2,"s":"Y8.2","diag":"calc"}]
