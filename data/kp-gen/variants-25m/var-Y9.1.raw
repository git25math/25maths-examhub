[{"id":"hv0771","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{45}$.","o":["$9\\sqrt{5}$","$3\\sqrt{5}$","$5\\sqrt{3}$","$3\\sqrt{15}$"],"a":1,"e":"$\\sqrt{45} = \\sqrt{9 \\times 5} = 3\\sqrt{5}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0772","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{48}$.","o":["$3\\sqrt{4}$","$16\\sqrt{3}$","$4\\sqrt{3}$","$2\\sqrt{12}$"],"a":2,"e":"$\\sqrt{48} = \\sqrt{16 \\times 3} = 4\\sqrt{3}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0773","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{50}$.","o":["$25\\sqrt{2}$","$2\\sqrt{5}$","$5\\sqrt{5}$","$5\\sqrt{2}$"],"a":3,"e":"$\\sqrt{50} = \\sqrt{25 \\times 2} = 5\\sqrt{2}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0774","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{12} + \\sqrt{27}$.","o":["$\\sqrt{39}$","$5\\sqrt{3}$","$5\\sqrt{6}$","$6\\sqrt{3}$"],"a":1,"e":"$\\sqrt{12} = 2\\sqrt{3}$ and $\\sqrt{27} = 3\\sqrt{3}$, so $2\\sqrt{3} + 3\\sqrt{3} = 5\\sqrt{3}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0775","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{20} + \\sqrt{45}$.","o":["$\\sqrt{65}$","$9\\sqrt{5}$","$5\\sqrt{5}$","$5\\sqrt{10}$"],"a":2,"e":"$\\sqrt{20} = 2\\sqrt{5}$ and $\\sqrt{45} = 3\\sqrt{5}$, so $2\\sqrt{5} + 3\\sqrt{5} = 5\\sqrt{5}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0776","cat":"number","topic":"Working with Irrational Numbers","q":"Simplify $\\sqrt{32} + \\sqrt{50}$.","o":["$9\\sqrt{2}$","$41\\sqrt{2}$","$8\\sqrt{2}$","$\\sqrt{82}$"],"a":0,"e":"$\\sqrt{32} = 4\\sqrt{2}$ and $\\sqrt{50} = 5\\sqrt{2}$, so $4\\sqrt{2} + 5\\sqrt{2} = 9\\sqrt{2}$.","d":1,"s":"Y9.1","diag":"calc"},{"id":"hv0777","cat":"number","topic":"Working with Irrational Numbers","q":"Rationalise the denominator of $\\dfrac{1}{\\sqrt{3}}$.","o":["$\\dfrac{\\sqrt{3}}{3}$","$\\dfrac{3}{\\sqrt{3}}$","$\\dfrac{1}{3}$","$\\sqrt{3}$"],"a":0,"e":"$\\dfrac{1}{\\sqrt{3}} \\times \\dfrac{\\sqrt{3}}{\\sqrt{3}} = \\dfrac{\\sqrt{3}}{3}$.","d":2,"s":"Y9.1","diag":"calc"},{"id":"hv0778","cat":"number","topic":"Working with Irrational Numbers","q":"Rationalise the denominator of $\\dfrac{1}{\\sqrt{7}}$.","o":["$\\dfrac{7}{\\sqrt{7}}$","$\\dfrac{\\sqrt{7}}{7}$","$\\dfrac{1}{7}$","$\\sqrt{7}$"],"a":1,"e":"$\\dfrac{1}{\\sqrt{7}} \\times \\dfrac{\\sqrt{7}}{\\sqrt{7}} = \\dfrac{\\sqrt{7}}{7}$.","d":2,"s":"Y9.1","diag":"calc"},{"id":"hv0779","cat":"number","topic":"Working with Irrational Numbers","q":"Rationalise the denominator of $\\dfrac{1}{\\sqrt{11}}$.","o":["$\\dfrac{1}{11}$","$\\sqrt{11}$","$\\dfrac{\\sqrt{11}}{11}$","$\\dfrac{11}{\\sqrt{11}}$"],"a":2,"e":"$\\dfrac{1}{\\sqrt{11}} \\times \\dfrac{\\sqrt{11}}{\\sqrt{11}} = \\dfrac{\\sqrt{11}}{11}$.","d":2,"s":"Y9.1","diag":"calc"},{"id":"hv0780","cat":"number","topic":"Working with Irrational Numbers","q":"Expand and simplify $(4 + \\sqrt{3})(4 - \\sqrt{3})$.","o":["13","19","7","$16 - 2\\sqrt{3}$"],"a":0,"e":"Using the difference of two squares: $(4)^2 - (\\sqrt{3})^2 = 16 - 3 = 13$.","d":2,"s":"Y9.1","diag":"calc"},{"id":"hv0781","cat":"number","topic":"Working with Irrational Numbers","q":"Expand and simplify $(5 + \\sqrt{6})(5 - \\sqrt{6})$.","o":["31","19","25","$25 - 6\\sqrt{6}$"],"a":1,"e":"Using the difference of two squares: $(5)^2 - (\\sqrt{6})^2 = 25 - 6 = 19$.","d":2,"s":"Y9.1","diag":"calc"},{"id":"hv0782","cat":"number","topic":"Working with Irrational Numbers","q":"Expand and simplify $(6 + \\sqrt{11})(6 - \\sqrt{11})$.","o":["47","36","25","$36 - \\sqrt{11}$"],"a":2,"e":"Using the difference of two squares: $(6)^2 - (\\sqrt{11})^2 = 36 - 11 = 25$.","d":2,"s":"Y9.1","diag":"calc"}]
