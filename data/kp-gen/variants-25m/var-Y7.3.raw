[{"id":"hv0588","cat":"number","topic":"Negative Number","q":"Calculate $(-7) + (-4)$.","o":["$-11$","$-3$","$11$","$3$"],"a":0,"e":"Adding two negative numbers: $(-7) + (-4) = -(7+4) = -11$.","d":1,"s":"Y7.3","diag":"concept"},{"id":"hv0589","cat":"number","topic":"Negative Number","q":"Calculate $(-2) + (-9)$.","o":["$7$","$-7$","$-11$","$11$"],"a":2,"e":"Adding two negative numbers: $(-2) + (-9) = -(2+9) = -11$.","d":1,"s":"Y7.3","diag":"concept"},{"id":"hv0590","cat":"number","topic":"Negative Number","q":"Calculate $(-6) + (-8)$.","o":["$-2$","$2$","$14$","$-14$"],"a":3,"e":"Adding two negative numbers: $(-6) + (-8) = -(6+8) = -14$.","d":1,"s":"Y7.3","diag":"concept"},{"id":"hv0591","cat":"number","topic":"Negative Number","q":"Calculate $(-5) \\times (-3)$.","o":["$15$","$-15$","$-8$","$8$"],"a":0,"e":"Negative times negative gives positive: $(-5) \\times (-3) = 15$.","d":1,"s":"Y7.3","diag":"calc"},{"id":"hv0592","cat":"number","topic":"Negative Number","q":"Calculate $(-2) \\times (-8)$.","o":["$-16$","$16$","$-10$","$10$"],"a":1,"e":"Negative times negative gives positive: $(-2) \\times (-8) = 16$.","d":1,"s":"Y7.3","diag":"calc"},{"id":"hv0593","cat":"number","topic":"Negative Number","q":"Calculate $(-7) \\times (-4)$.","o":["$-11$","$11$","$-28$","$28$"],"a":3,"e":"Negative times negative gives positive: $(-7) \\times (-4) = 28$.","d":1,"s":"Y7.3","diag":"calc"},{"id":"hv0594","cat":"number","topic":"Negative Number","q":"What is $5 - (-8)$?","o":["$13$","$-3$","$3$","$-13$"],"a":0,"e":"Subtracting a negative is the same as adding: $5 - (-8) = 5 + 8 = 13$.","d":1,"s":"Y7.3","diag":"concept"},{"id":"hv0595","cat":"number","topic":"Negative Number","q":"What is $12 - (-4)$?","o":["$8$","$16$","$-8$","$-16$"],"a":1,"e":"Subtracting a negative is the same as adding: $12 - (-4) = 12 + 4 = 16$.","d":1,"s":"Y7.3","diag":"concept"},{"id":"hv0596","cat":"number","topic":"Negative Number","q":"What is $9 - (-6)$?","o":["$3$","$-3$","$-15$","$15$"],"a":3,"e":"Subtracting a negative is the same as adding: $9 - (-6) = 9 + 6 = 15$.","d":1,"s":"Y7.3","diag":"concept"}]
