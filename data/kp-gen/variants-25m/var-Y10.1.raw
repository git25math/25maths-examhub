    "id": "hv0282",
    "cat": "number",
    "topic": "Real Numbers",
    "q": "Simplify $3^2 \\times 3^{-6}$.",
    "o": [
      "$3^{-12}$",
      "$3^8$",
      "$3^4$",
      "$3^{-4}$"
    ],
    "a": 3,
    "e": "Using the index law $a^m \\times a^n = a^{m+n}$: $3^2 \\times 3^{-6} = 3^{2+(-6)} = 3^{-4}$.",
    "d": 2,
    "s": "Y10.1",
    "diag": "calc"
  },
  {
