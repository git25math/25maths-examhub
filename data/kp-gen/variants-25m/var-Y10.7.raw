[{"id":"hv0384","cat":"geometry","topic":"Circles","q":"What is the angle between a tangent to a circle and the radius drawn to the point of contact?","o":["$45째$","$60째$","$180째$","$90째$"],"a":3,"e":"A tangent to a circle is always perpendicular to the radius at the point of contact, meaning they form a $90째$ angle.","d":1,"s":"Y10.7","diag":"concept"},{"id":"hv0385","cat":"geometry","topic":"Circles","q":"At the point where a tangent touches a circle, the angle it makes with the radius is...","o":["$90째$","$30째$","$45째$","$180째$"],"a":0,"e":"By definition, the angle between a radius and a tangent at the point of contact is $90째$.","d":1,"s":"Y10.7","diag":"concept"},{"id":"hv0386","cat":"geometry","topic":"Circles","q":"If a line is tangent to a circle at point P, what angle does the radius OP form with this line?","o":["$60째$","$45째$","$90째$","$180째$"],"a":2,"e":"The radius and tangent are perpendicular at the point of tangency, resulting in an angle of $90째$.","d":1,"s":"Y10.7","diag":"concept"},{"id":"hv0387","cat":"geometry","topic":"Circles","q":"An arc of a circle with radius $9$ cm subtends an angle of $40째$ at the centre. Find the arc length.","o":["$2\\pi$ cm","$4\\pi$ cm","$9\\pi$ cm","$18\\pi$ cm"],"a":0,"e":"Arc length $= \\frac{40}{360} \\times 2\\pi(9) = \\frac{1}{9} \\times 18\\pi = 2\\pi$ cm.","d":1,"s":"Y10.7","diag":"calc"},{"id":"hv0388","cat":"geometry","topic":"Circles","q":"An arc of a circle with radius $6$ cm subtends an angle of $60째$ at the centre. Find the arc length.","o":["$4\\pi$ cm","$2\\pi$ cm","$6\\pi$ cm","$12\\pi$ cm"],"a":1,"e":"Arc length $= \\frac{60}{360} \\times 2\\pi(6) = \\frac{1}{6} \\times 12\\pi = 2\\pi$ cm.","d":1,"s":"Y10.7","diag":"calc"},{"id":"hv0389","cat":"geometry","topic":"Circles","q":"An arc of a circle with radius $15$ cm subtends an angle of $120째$ at the centre. Find the arc length.","o":["$5\\pi$ cm","$20\\pi$ cm","$10\\pi$ cm","$15\\pi$ cm"],"a":2,"e":"Arc length $= \\frac{120}{360} \\times 2\\pi(15) = \\frac{1}{3} \\times 30\\pi = 10\\pi$ cm.","d":1,"s":"Y10.7","diag":"calc"},{"id":"hv0390","cat":"geometry","topic":"Circles","q":"An angle at the centre of a circle is $160째$. What is the angle at the circumference subtended by the same arc?","o":["$320째$","$80째$","$160째$","$40째$"],"a":1,"e":"The angle at the circumference is half the angle at the centre: $\\frac{160째}{2} = 80째$.","d":2,"s":"Y10.7","diag":"concept"},{"id":"hv0391","cat":"geometry","topic":"Circles","q":"An angle at the centre of a circle is $110째$. What is the angle at the circumference subtended by the same arc?","o":["$55째$","$110째$","$220째$","$27.5째$"],"a":0,"e":"The angle at the circumference is half the angle at the centre: $\\frac{110째}{2} = 55째$.","d":2,"s":"Y10.7","diag":"concept"},{"id":"hv0392","cat":"geometry","topic":"Circles","q":"An angle at the centre of a circle is $84째$. What is the angle at the circumference subtended by the same arc?","o":["$168째$","$84째$","$21째$","$42째$"],"a":3,"e":"The angle at the circumference is half the angle at the centre: $\\frac{84째}{2} = 42째$.","d":2,"s":"Y10.7","diag":"concept"},{"id":"hv0393","cat":"geometry","topic":"Circles","q":"Find the area of a sector with radius $12$ cm and angle $90째$.","o":["$12\\pi$ cm짼","$36\\pi$ cm짼","$24\\pi$ cm짼","$48\\pi$ cm짼"],"a":1,"e":"Sector area $= \\frac{90}{360} \\times \\pi(12)^2 = \\frac{1}{4} \\times 144\\pi = 36\\pi$ cm짼.","d":2,"s":"Y10.7","diag":"calc"},{"id":"hv0394","cat":"geometry","topic":"Circles","q":"Find the area of a sector with radius $3$ cm and angle $240째$.","o":["$3\\pi$ cm짼","$9\\pi$ cm짼","$6\\pi$ cm짼","$12\\pi$ cm짼"],"a":2,"e":"Sector area $= \\frac{240}{360} \\times \\pi(3)^2 = \\frac{2}{3} \\times 9\\pi = 6\\pi$ cm짼.","d":2,"s":"Y10.7","diag":"calc"},{"id":"hv0395","cat":"geometry","topic":"Circles","q":"Find the area of a sector with radius $10$ cm and angle $36째$.","o":["$10\\pi$ cm짼","$20\\pi$ cm짼","$5\\pi$ cm짼","$100\\pi$ cm짼"],"a":0,"e":"Sector area $= \\frac{36}{360} \\times \\pi(10)^2 = \\frac{1}{10} \\times 100\\pi = 10\\pi$ cm짼.","d":2,"s":"Y10.7","diag":"calc"}]
