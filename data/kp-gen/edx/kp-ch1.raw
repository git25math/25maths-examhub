  {
    "id": "kp-E1.7-01",
    "section": "1.7",
    "order": 1,
    "title": "Ratio and Proportion",
    "title_zh": "比与比例",
    "explanation": {
      "en": "A **Ratio** compares quantities. To divide an amount into a ratio, add the total parts, divide the amount by total parts to find one part, then multiply by the required parts.\n\n**Direct Proportion** means as one variable increases, the other increases at the same rate ($y = kx$). \n\n**Inverse Proportion** means as one increases, the other decreases ($y = \\frac{k}{x}$).",
      "zh": "**比**用于比较数量。要按比例分配金额，先将总份数相加，用金额除以总份数求出一份的量，然后乘以所需的份数。\n\n**正比例**意味着一个变量增加，另一个变量以相同的速率增加 ($y = kx$)。\n\n**反比例**意味着一个增加，另一个减少 ($y = \\frac{k}{x}$)。"
    },
    "examPatterns": [
      {
        "id": "ep-divide-ratio",
        "label": "Divide a quantity into a given ratio",
        "label_zh": "按给定比例分配数量",
        "description": "Calculate specific amounts for each part of the ratio.",
        "description_zh": "计算比例中每一部分的具体金额。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-divide-ratio",
        "question": "Divide $450 in the ratio 2 : 3 : 4$.",
        "question_zh": "将 450 美元按 2 : 3 : 4 的比例分配。",
        "solution": "**Step 1:** Total parts = $2 + 3 + 4 = 9$.\n**Step 2:** Value of one part = $450 \\div 9 = 50$.\n**Step 3:** Multiply each part: $2 \\times 50 = 100$; $3 \\times 50 = 150$; $4 \\times 50 = 200$.\n\n**Answer:** $100, $150, $200",
        "solution_zh": "**步骤1：** 总份数 = $2 + 3 + 4 = 9$。\n**步骤2：** 一份的价值 = $450 \\div 9 = 50$。\n**步骤3：** 分别乘以各份数：$2 \\times 50 = 100$；$3 \\times 50 = 150$；$4 \\times 50 = 200$。\n\n**答案：** 100 美元, 150 美元, 200 美元",
        "source": "Adapted from 4MA1/2F/Jan/2020"
      },
      {
        "patternId": "ep-divide-ratio",
        "question": "The ratio of boys to girls is 4 : 5. There are 20 more girls than boys. How many students are there in total?",
        "question_zh": "男女生比例为 4 : 5。女生比男生多 20 人。总共有多少名学生？",
        "solution": "**Step 1:** Difference in parts = $5 - 4 = 1$ part.\n**Step 2:** 1 part = 20 students.\n**Step 3:** Total parts = $4 + 5 = 9$ parts.\n**Step 4:** Total students = $9 \\times 20 = 180$.\n\n**Answer:** 180",
        "solution_zh": "**步骤1：** 份数差 = $5 - 4 = 1$ 份。\n**步骤2：** 1 份 = 20 名学生。\n**步骤3：** 总份数 = $4 + 5 = 9$ 份。\n**步骤4：** 总学生数 = $9 \\times 20 = 180$。\n\n**答案：** 180",
        "source": "Adapted from 4MA1/1H/June/2021"
      }
    ],
    "testYourself": [
      {
        "q": "If 5 pens cost $3.50, how much do 8 pens cost?",
        "q_zh": "如果 5 支笔卖 3.50 美元，8 支笔卖多少钱？",
        "o": [
          "$5.60",
          "$4.80",
          "$7.00",
          "$5.40"
        ],
        "a": 0,
        "e": "Cost per pen = $3.50 \\div 5 = 0.70$. Cost for 8 pens = $0.70 \\times 8 = 5.60$.",
        "e_zh": "每支笔的价格 = $3.50 \\div 5 = 0.70$。8 支笔的价格 = $0.70 \\times 8 = 5.60$。"
      },
      {
        "q": "A map has a scale of 1 : 50,000. What distance on the ground does 2 cm on the map represent?",
        "q_zh": "地图比例尺为 1 : 50,000。地图上的 2 厘米代表地面上的多少距离？",
        "o": [
          "100 m",
          "1 km",
          "10 km",
          "100 km"
        ],
        "a": 1,
        "e": "2 cm represents $2 \\times 50,000 = 100,000$ cm. $100,000$ cm = $1,000$ m = $1$ km.",
        "e_zh": "2 厘米代表 $2 \\times 50,000 = 100,000$ 厘米。$100,000$ 厘米 = $1,000$ 米 = $1$ 千米。"
      }
    ],
    "vocabLinks": [],
    "tier": "both"
