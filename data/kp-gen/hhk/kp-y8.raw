[
  {
    "id": "kp-Y8.1-01",
    "section": "Y8.1",
    "order": 1,
    "title": "Rounding and Estimation",
    "title_zh": "舍入与估算",
    "explanation": {
      "en": "**Rounding** to a specific number of decimal places (d.p.) or significant figures (s.f.) helps simplify numbers while keeping their value close to the original.\n\n**Significant figures** start from the first non-zero digit. For example, in $0.00405$, the first significant figure is $4$. Zeros between non-zero digits are significant, but leading zeros are not.\n\n**Estimation** involves rounding all numbers in a calculation to $1$ significant figure to find an approximate answer quickly. This is useful for checking the reasonableness of a result.",
      "zh": "**舍入**到指定的小数位数 (d.p.) 或有效数字 (s.f.) 有助于简化数字，同时保持其数值接近原始值。\n\n**有效数字**从第一个非零数字开始计数。例如，在 $0.00405$ 中，第一个有效数字是 $4$。非零数字之间的零是有效的，但前导零不是。\n\n**估算**涉及将计算中的所有数字舍入到 $1$ 位有效数字，以快速找到近似答案。这对于检查结果的合理性非常有用。"
    },
    "examPatterns": [
      {
        "id": "ep-round-sf",
        "label": "Rounding to significant figures",
        "label_zh": "舍入至有效数字",
        "description": "Round a given number to a specified number of significant figures.",
        "description_zh": "将给定的数字舍入到指定的有效数字位数。"
      },
      {
        "id": "ep-estimate",
        "label": "Estimating complex calculations",
        "label_zh": "估算复杂计算",
        "description": "Approximate the value of a calculation by rounding each term to 1 s.f.",
        "description_zh": "通过将每项舍入到 1 位有效数字来估算计算值。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-round-sf",
        "question": "Round $0.038452$ to $3$ significant figures.",
        "question_zh": "将 $0.038452$ 舍入到 $3$ 位有效数字。",
        "solution": "**Step 1:** Identify the first non-zero digit. It is $3$.\n**Step 2:** Count three digits from there: $3, 8, 4$.\n**Step 3:** Look at the next digit ($5$). Since it is $5$ or more, round up the last digit ($4$ becomes $5$).\n**Answer:** $0.0385$",
        "solution_zh": "**步骤1：** 确定第一个非零数字，是 $3$。\n**步骤2：** 从该位起数三位：$3, 8, 4$。\n**步骤3：** 查看下一位数字 ($5$)。因为是 $5$ 或更大，所以进位（$4$ 变为 $5$）。\n**答案：** $0.0385$",
        "source": "Year 8 Assessment"
      },
      {
        "patternId": "ep-estimate",
        "question": "Estimate the value of $\\frac{41.2 \\times 2.94}{0.485}$.",
        "question_zh": "估算 $\\frac{41.2 \\times 2.94}{0.485}$ 的值。",
        "solution": "**Step 1:** Round each number to $1$ significant figure.\n$41.2 \\approx 40$\n$2.94 \\approx 3$\n$0.485 \\approx 0.5$\n**Step 2:** Perform the calculation: $\\frac{40 \\times 3}{0.5} = \\frac{120}{0.5} = 240$.\n**Answer:** $240$",
        "solution_zh": "**步骤1：** 将每个数字舍入到 $1$ 位有效数字。\n$41.2 \\approx 40$\n$2.94 \\approx 3$\n$0.485 \\approx 0.5$\n**步骤2：** 进行计算：$\\frac{40 \\times 3}{0.5} = \\frac{120}{0.5} = 240$。\n**答案：** $240$",
        "source": "Adapted from Y8 curriculum"
      }
    ],
    "testYourself": [
      {
        "q": "What is $4057$ rounded to $2$ significant figures?",
        "q_zh": "将 $4057$ 舍入到 $2$ 位有效数字是多少？",
        "o": [
          "40",
          "41",
          "4000",
          "4100"
        ],
        "a": 3,
        "e": "The first two significant figures are 4 and 0. The next digit is 5, so round up. 40 becomes 41, and we keep the place value with zeros: 4100.",
        "e_zh": "前两位有效数字是 4 和 0。下一位是 5，所以进位。40 变成 41，用零占位保持数位：4100。"
      },
      {
        "q": "Estimate $\\sqrt{98.4} + (3.1)^2$.",
        "q_zh": "估算 $\\sqrt{98.4} + (3.1)^2$。",
        "o": [
          "13",
          "19",
          "25",
          "109"
        ],
        "a": 1,
        "e": "Rounding to 1 s.f.: $\\sqrt{100} + 3^2 = 10 + 9 = 19$.",
        "e_zh": "舍入到 1 位有效数字：$\\sqrt{100} + 3^2 = 10 + 9 = 19$。"
      }
    ],
    "vocabLinks": [],
    "tier": "both"
  },
  {
    "id": "kp-Y8.2-01",
    "section": "Y8.2",
    "order": 1,
    "title": "HCF, LCM and Prime Factorization",
    "title_zh": "最高公因数、最低公倍数与质因数分解",
    "explanation": {
      "en": "**Prime factorization** is the process of expressing a composite number as a product of its prime factors (e.g., $12 = 2^2 \\times 3$).\n\n**Highest Common Factor (HCF)** is the largest number that divides exactly into two or more numbers. It is found by multiplying the lowest powers of common prime factors.\n\n**Lowest Common Multiple (LCM)** is the smallest number that is a multiple of two or more numbers. It is found by multiplying the highest powers of all prime factors involved.",
      "zh": "**质因数分解**是将一个合数表示为其质因数乘积的过程（例如，$12 = 2^2 \\times 3$）。\n\n**最高公因数 (HCF)** 是指能整除两个或多个数的最大共有正整数。通过将共有质因数的最低幂相乘来找到。\n\n**最低公倍数 (LCM)** 是指作为两个或多个数的倍数的最小正整数。通过将涉及的所有质因数的最高幂相乘来找到。"
    },
    "examPatterns": [
      {
        "id": "ep-prime-factor",
        "label": "Find prime factors in index form",
        "label_zh": "以指数形式写出质因数",
        "description": "Use a factor tree to find the prime decomposition of a number.",
        "description_zh": "使用因数树找到一个数的质因数分解。"
      },
      {
        "id": "ep-hcf-lcm",
        "label": "Calculate HCF and LCM",
        "label_zh": "计算 HCF 和 LCM",
        "description": "Find HCF and LCM for two or three numbers using prime factors.",
        "description_zh": "利用质因数找到两个或三个数的 HCF 和 LCM。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-prime-factor",
        "question": "Write $120$ as a product of its prime factors in index form.",
        "question_zh": "将 $120$ 以指数形式写成质因数的乘积。",
        "solution": "**Step 1:** Use a factor tree: $120 = 10 \\times 12$.\n**Step 2:** $10 = 2 \\times 5$; $12 = 2 \\times 2 \\times 3$.\n**Step 3:** Collect all factors: $2, 2, 2, 3, 5$.\n**Answer:** $2^3 \\times 3 \\times 5$",
        "solution_zh": "**步骤1：** 使用因数树：$120 = 10 \\times 12$。\n**步骤2：** $10 = 2 \\times 5$；$12 = 2 \\times 2 \\times 3$。\n**步骤3：** 汇总所有因数：$2, 2, 2, 3, 5$。\n**答案：** $2^3 \\times 3 \\times 5$",
        "source": "Year 8 Assessment"
      },
      {
        "patternId": "ep-hcf-lcm",
        "question": "Given $A = 2^2 \\times 3 \\times 5$ and $B = 2 \\times 3^2$, find the HCF and LCM of $A$ and $B$.",
        "question_zh": "已知 $A = 2^2 \\times 3 \\times 5$ 且 $B = 2 \\times 3^2$，求 $A$ 和 $B$ 的 HCF 和 LCM。",
        "solution": "**Step 1 for HCF:** Take the lowest power of common primes ($2^1$ and $3^1$). HCF $= 2 \\times 3 = 6$.\n**Step 2 for LCM:** Take the highest power of all primes ($2^2, 3^2, 5^1$). LCM $= 4 \\times 9 \\times 5 = 180$.\n**Answers:** HCF $= 6$, LCM $= 180$",
        "solution_zh": "**HCF 步骤1：** 取共有质因数的最低幂 ($2^1$ 和 $3^1$)。HCF $= 2 \\times 3 = 6$。\n**LCM 步骤2：** 取所有质因数的最高幂 ($2^2, 3^2, 5^1$)。LCM $= 4 \\times 9 \\times 5 = 180$。\n**答案：** HCF $= 6$, LCM $= 180$",
        "source": "Adapted from Y8 curriculum"
      }
    ],
    "testYourself": [
      {
        "q": "Which of these is the prime factorization of 72?",
        "q_zh": "下列哪项是 72 的质因数分解？",
        "o": [
          "$2 \\times 3^2$",
          "$2^3 \\times 3^2$",
          "$8 \\times 9$",
          "$2^2 \\times 3^3$"
        ],
        "a": 1,
        "e": "$72 = 8 \\times 9 = (2 \\times 2 \\times 2) \\times (3 \\times 3) = 2^3 \\times 3^2$.",
        "e_zh": "$72 = 8 \\times 9 = (2 \\times 2 \\times 2) \\times (3 \\times 3) = 2^3 \\times 3^2$。"
      },
      {
        "q": "What is the LCM of 12 and 15?",
        "q_zh": "12 和 15 的最低公倍数 (LCM) 是多少？",
        "o": [
          "3",
          "30",
          "60",
          "180"
        ],
        "a": 2,
        "e": "$12 = 2^2 \\times 3$, $15 = 3 \\times 5$. LCM $= 2^2 \\times 3 \\times 5 = 60$.",
        "e_zh": "$12 = 2^2 \\times 3$，$15 = 3 \\times 5$。LCM $= 2^2 \\times 3 \\times 5 = 60$。"
      }
    ],
    "vocabLinks": [],
    "tier": "both"
  },
  {
    "id": "kp-Y8.3-01",
    "section": "Y8.3",
    "order": 1,
    "title": "Substitution and Rearranging Formulas",
    "title_zh": "代入求值与公式变形",
    "explanation": {
      "en": "**Substitution** involves replacing letters in a formula with given numbers to calculate a final value. Always use brackets when substituting negative numbers.\n\n**Changing the subject** of a formula means rearranging it so that a different variable is isolated on one side (usually the left). Use inverse operations (the opposite of BIDMAS in reverse order) to isolate the target variable.",
      "zh": "**代入求值**涉及将公式中的字母替换为给定的数字以计算最终数值。代入负数时务必使用括号。\n\n**公式变形（改变主元）**意味着重新排列公式，使不同的变量单独位于等号的一侧（通常是左侧）。使用逆运算（按 BIDMAS 相反顺序的逆操作）来孤立目标变量。"
    },
    "examPatterns": [
      {
        "id": "ep-substitute",
        "label": "Substitute into complex formulas",
        "label_zh": "代入复杂公式",
        "description": "Calculate the value of a variable given values for all other variables in a formula.",
        "description_zh": "已知公式中所有其他变量的值，计算某个变量的值。"
      },
      {
        "id": "ep-rearrange",
        "label": "Change the subject of the formula",
        "label_zh": "改变公式的主元",
        "description": "Rearrange a formula like $v = u + at$ to make another letter (e.g., $a$) the subject.",
        "description_zh": "将如 $v = u + at$ 的公式变形，使另一个字母（如 $a$）成为主元。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-substitute",
        "question": "If $s = ut + \\frac{1}{2}at^2$, find $s$ when $u = 5, t = 4$ and $a = 10$.",
        "question_zh": "如果 $s = ut + \\frac{1}{2}at^2$，当 $u = 5, t = 4, a = 10$ 时，求 $s$。",
        "solution": "**Step 1:** Substitute values: $s = (5)(4) + \\frac{1}{2}(10)(4^2)$.\n**Step 2:** Calculate: $s = 20 + 5(16) = 20 + 80 = 100$.\n**Answer:** $100$",
        "solution_zh": "**步骤1：** 代入数值：$s = (5)(4) + \\frac{1}{2}(10)(4^2)$。\n**步骤2：** 计算：$s = 20 + 5(16) = 20 + 80 = 100$。\n**答案：** $100$",
        "source": "Year 8 Assessment"
      },
      {
        "patternId": "ep-rearrange",
        "question": "Make $x$ the subject of the formula: $y = 3x - 7$.",
        "question_zh": "将公式 $y = 3x - 7$ 的主元变为 $x$。",
        "solution": "**Step 1:** Add $7$ to both sides: $y + 7 = 3x$.\n**Step 2:** Divide both sides by $3$: $\\frac{y + 7}{3} = x$.\n**Answer:** $x = \\frac{y + 7}{3}$",
        "solution_zh": "**步骤1：** 等号两边同时加 $7$：$y + 7 = 3x$。\n**步骤2：** 等号两边同时除以 $3$：$\\frac{y + 7}{3} = x$。\n**答案：** $x = \\frac{y + 7}{3}$",
        "source": "Adapted from Y8 curriculum"
      }
    ],
    "testYourself": [
      {
        "q": "If $v^2 = u^2 + 2as$, find $v$ when $u=3, a=2, s=4$ (take positive root).",
        "q_zh": "如果 $v^2 = u^2 + 2as$，当 $u=3, a=2, s=4$ 时，求 $v$（取正根）。",
        "o": [
          "5",
          "25",
          "7",
          "16"
        ],
        "a": 0,
        "e": "$v^2 = 3^2 + 2(2)(4) = 9 + 16 = 25$. So $v = \\sqrt{25} = 5$.",
        "e_zh": "$v^2 = 3^2 + 2(2)(4) = 9 + 16 = 25$。因此 $v = \\sqrt{25} = 5$。"
      },
      {
        "q": "Rearrange $A = \\pi r^2$ to make $r$ the subject.",
        "q_zh": "将 $A = \\pi r^2$ 变形，使 $r$ 成为主元。",
        "o": [
          "$r = \\frac{A}{\\pi}$",
          "$r = \\sqrt{A \\pi}$",
          "$r = \\sqrt{\\frac{A}{\\pi}}$",
          "$r = (\\frac{A}{\\pi})^2$"
        ],
        "a": 2,
        "e": "Divide by $\\pi$ first to get $r^2 = A/\\pi$, then take the square root of both sides.",
        "e_zh": "先除以 $\\pi$ 得到 $r^2 = A/\\pi$，然后对两边开平方。"
      }
    ],
    "vocabLinks": [],
    "tier": "both"
  },
  {
    "id": "kp-Y8.4-01",
    "section": "Y8.4",
    "order": 1,
    "title": "Solving Linear Inequalities",
    "title_zh": "解线性不等式",
    "explanation": {
      "en": "**Inequalities** use symbols like $<$ (less than), $>$ (greater than), $\\leq$ (less than or equal to), and $\\geq$ (greater than or equal to).\n\n**Solving inequalities** is similar to solving equations, with one critical rule: if you multiply or divide by a **negative number**, you must **flip the inequality sign**.\n\n**Number lines** are used to represent solutions. Use an open circle $\\circ$ for $<$ or $>$, and a closed circle $\\bullet$ for $\\leq$ or $\\geq$.",
      "zh": "**不等式**使用符号如 $<$（小于）、$>$（大于）、$\\leq$（小于或等于）和 $\\geq$（大于或等于）。\n\n**解不等式**与解方程类似，但有一个关键规则：如果你乘以或除以一个**负数**，必须**翻转不等号方向**。\n\n**数轴**用于表示解集。使用空心圆圈 $\\circ$ 表示 $<$ 或 $>$，使用实心圆圈 $\\bullet$ 表示 $\\leq$ 或 $\\geq$。"
    },
    "examPatterns": [
      {
        "id": "ep-solve-ineq",
        "label": "Solve linear inequalities",
        "label_zh": "解线性不等式",
        "description": "Find the range of values for $x$ that satisfy an inequality.",
        "description_zh": "找到满足不等式的 $x$ 的取值范围。"
      },
      {
        "id": "ep-number-line",
        "label": "Represent on a number line",
        "label_zh": "在数轴上表示",
        "description": "Graph the solution of an inequality on a provided number line.",
        "description_zh": "在给出的数轴上画出不等式的解。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-solve-ineq",
        "question": "Solve the inequality: $5x - 3 > 17$.",
        "question_zh": "解不等式：$5x - 3 > 17$。",
        "solution": "**Step 1:** Add $3$ to both sides: $5x > 20$.\n**Step 2:** Divide both sides by $5$: $x > 4$.\n**Answer:** $x > 4$",
        "solution_zh": "**步骤1：** 等号两边同时加 $3$：$5x > 20$。\n**步骤2：** 等号两边同时除以 $5$：$x > 4$。\n**答案：** $x > 4$",
        "source": "Year 8 Assessment"
      },
      {
        "patternId": "ep-solve-ineq",
        "question": "Solve $10 - 2x \\leq 4$.",
        "question_zh": "解 $10 - 2x \\leq 4$。",
        "solution": "**Step 1:** Subtract $10$: $-2x \\leq -6$.\n**Step 2:** Divide by $-2$ and flip the sign: $x \\geq 3$.\n**Answer:** $x \\geq 3$",
        "solution_zh": "**步骤1：** 减去 $10$：$-2x \\leq -6$。\n**步骤2：** 除以 $-2$ 并翻转符号：$x \\geq 3$。\n**答案：** $x \\geq 3$",
        "source": "Adapted from Y8 curriculum"
      }
    ],
    "testYourself": [
      {
        "q": "Solve $3x + 1 \\leq 10$.",
        "q_zh": "解 $3x + 1 \\leq 10$。",
        "o": [
          "$x \\leq 3$",
          "$x \\geq 3$",
          "$x < 3$",
          "$x \\leq 11/3$"
        ],
        "a": 0,
        "e": "$3x \\leq 9$, so $x \\leq 3$.",
        "e_zh": "$3x \\leq 9$，所以 $x \\leq 3$。"
      },
      {
        "q": "Which inequality is represented by a closed circle at 5 with an arrow pointing to the left?",
        "q_zh": "哪个不等式由 5 处的实心圆圈和向左的箭头表示？",
        "o": [
          "$x < 5$",
          "$x > 5$",
          "$x \\leq 5$",
          "$x \\geq 5$"
        ],
        "a": 2,
        "e": "Closed circle means 'equal to' included ($\\leq$ or $\\geq$). Arrow to the left means 'less than'. So $x \\leq 5$.",
        "e_zh": "实心圆圈表示包含“等于”（$\\leq$ 或 $\\geq$）。向左的箭头表示“小于”。所以是 $x \\leq 5$。"
      }
    ],
    "vocabLinks": [],
    "tier": "both"
  },
  {
    "id": "kp-Y8.5-01",
    "section": "Y8.5",
    "order": 1,
    "title": "Pythagoras' Theorem",
    "title_zh": "勾股定理",
    "explanation": {
      "en": "**Pythagoras' Theorem** states that in a right-angled triangle, the square of the hypotenuse ($c$) is equal to the sum of the squares of the other two sides ($a$ and $b$): $$a^2 + b^2 = c^2$$\n\n**The hypotenuse** is the longest side, located opposite the right angle ($90^\\circ$).\n\nTo find a **shorter side**, rearrange the formula: $a^2 = c^2 - b^2$. Always remember to take the square root at the end.",
      "zh": "**勾股定理**指出，在直角三角形中，斜边 ($c$) 的平方等于另外两条直角边 ($a$ 和 $b$) 的平方和：$$a^2 + b^2 = c^2$$\n\n**斜边**是直角三角形中最长的边，位于直角 ($90^\\circ$) 的对面。\n\n要求**直角边**，需变形公式：$a^2 = c^2 - b^2$。务必记得最后开平方根。"
    },
    "examPatterns": [
      {
        "id": "ep-find-hypotenuse",
        "label": "Calculate the hypotenuse",
        "label_zh": "计算斜边",
        "description": "Given two shorter sides, find the length of the longest side.",
        "description_zh": "已知两条直角边，求最长边的长度。"
      },
      {
        "id": "ep-find-side",
        "label": "Calculate a shorter side",
        "label_zh": "计算直角边",
        "description": "Given the hypotenuse and one side, find the missing side.",
        "description_zh": "已知斜边和一条直角边，求缺失的另一条边。"
      }
    ],
    "examples": [
      {
        "patternId": "ep-find-hypotenuse",
        "question": "A right-angled triangle has sides of $5\\text{ cm}$ and $12\\text{ cm}$. Find the length of the hypotenuse.",
        "question_zh": "一个直角三角形的直角边分别为 $5\\text{ cm}$ 和 $12\\text{ cm}$。求斜边的长度。",
        "solution": "**Step 1:** Identify $a=5, b=12$.\n**Step 2:** Use $c^2 = a^2 + b^2 = 5^2 + 12^2 = 25 + 144 = 169$.\n**Step 3:** $c = \\sqrt{169} = 13$.\n**Answer:** $13\\text{ cm}$",
        "solution_zh": "**步骤1：** 确定 $a=5, b=12$。\n**步骤2：** 使用 $c^2 = a^2 + b^2 = 5^2 + 12^2 = 25 + 144 = 169$。\n**步骤3：** $c = \\sqrt{169} = 13$。\n**答案：** $13\\text{ cm}$",
        "source": "Year 8 Assessment"
      },
      {
        "patternId": "ep-find-side",
        "question": "A right-angled triangle has a hypotenuse of $10\\text{ cm}$ and one side of $8\\text{ cm}$. Find the length of the third side.",
        "question_zh": "一个直角三角形的斜边为 $10\\text{ cm}$，一条直角边为 $8\\text{ cm}$。求第三条边的长度。",
        "solution": "**Step 1:** Identify $c=10, b=8$.\n**Step 2:** Use $a^2 = c^2 - b^2 = 10^2 - 8^2 = 100 - 64 = 36$.\n**Step 3:** $a = \\sqrt{36} = 6$.\n**Answer:** $6\\text{ cm}$",
        "solution_zh": "**步骤1：** 确定 $c=10, b=8$。\n**步骤2：** 使用 $a^2 = c^2 - b^2 = 10^2 - 8^2 = 100 - 64 = 36$。\n**步骤3：** $a = \\sqrt{36} = 6$。\n**答案：** $6\\text{ cm}$",
        "source": "Adapted from Y8 curriculum"
      }
    ],
    "testYourself": [
      {
        "q": "What is the length of the hypotenuse in a triangle with sides 3 and 4?",
        "q_zh": "直角边为 3 和 4 的三角形中，斜边的长度是多少？",
        "o": [
          "5",
          "7",
          "25",
          "12"
        ],
        "a": 0,
        "e": "$3^2 + 4^2 = 9 + 16 = 25$. $\\sqrt{25} = 5$.",
        "e_zh": "$3^2 + 4^2 = 9 + 16 = 25$。$\\sqrt{25} = 5$。"
      },
      {
        "q": "Can a triangle with side lengths 6, 8, 11 be right-angled?",
        "q_zh": "边长为 6, 8, 11 的三角形可以是直角三角形吗？",
        "o": [
          "Yes, because 6+8 > 11",
          "No, because $6^2 + 8^2 \\neq 11^2$",
          "Yes, because 11 is the hypotenuse",
          "No, because all sides must be odd"
        ],
        "a": 1,
        "e": "$6^2 + 8^2 = 36 + 64 = 100$, but $11^2 = 121$. Since $100 \\neq 121$, it is not a right-angled triangle.",
        "e_zh": "$6^2 + 8^2 = 36 + 64 = 100$，但 $11^2 = 121$。因为 $100 \\neq 121$，所以它不是直角三角形。"
      }
    ],
