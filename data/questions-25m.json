[
  {"id":"h001","cat":"fractions","topic":"Multiplication of Fractions","q":"Simplify $\\frac{12}{18}$.","o":["$\\frac{2}{3}$","$\\frac{3}{4}$","$\\frac{6}{9}$","$\\frac{4}{6}$"],"a":0,"e":"$\\frac{12}{18} = \\frac{12 \\div 6}{18 \\div 6} = \\frac{2}{3}$","d":1,"s":"Y7.1","diag":"calc"},
  {"id":"h002","cat":"fractions","topic":"Multiplication of Fractions","q":"Convert $2\\frac{3}{4}$ to an improper fraction.","o":["$\\frac{11}{4}$","$\\frac{8}{4}$","$\\frac{9}{4}$","$\\frac{7}{4}$"],"a":0,"e":"$2\\frac{3}{4} = \\frac{2 \\times 4 + 3}{4} = \\frac{11}{4}$","d":1,"s":"Y7.1","diag":"concept"},
  {"id":"h003","cat":"fractions","topic":"Multiplication of Fractions","q":"Calculate $\\frac{2}{5} \\times \\frac{3}{4}$.","o":["$\\frac{3}{10}$","$\\frac{6}{20}$","$\\frac{5}{9}$","$\\frac{6}{9}$"],"a":0,"e":"Multiply numerators: $2 \\times 3 = 6$. Multiply denominators: $5 \\times 4 = 20$. Simplify: $\\frac{6}{20} = \\frac{3}{10}$.","d":1,"s":"Y7.1","diag":"calc"},
  {"id":"h004","cat":"fractions","topic":"Multiplication of Fractions","q":"What is the reciprocal of $\\frac{3}{7}$?","o":["$\\frac{7}{3}$","$\\frac{3}{7}$","$\\frac{1}{3}$","$-\\frac{3}{7}$"],"a":0,"e":"The reciprocal of a fraction $\\frac{a}{b}$ is $\\frac{b}{a}$. So the reciprocal of $\\frac{3}{7}$ is $\\frac{7}{3}$.","d":1,"s":"Y7.1","diag":"concept"},
  {"id":"h005","cat":"fractions","topic":"Multiplication of Fractions","q":"Calculate $\\frac{1}{3} + \\frac{1}{4}$.","o":["$\\frac{7}{12}$","$\\frac{2}{7}$","$\\frac{1}{7}$","$\\frac{2}{12}$"],"a":0,"e":"Find the LCM of 3 and 4: $12$. Convert: $\\frac{4}{12} + \\frac{3}{12} = \\frac{7}{12}$.","d":1,"s":"Y7.1","diag":"calc"},
  {"id":"h006","cat":"fractions","topic":"Multiplication of Fractions","q":"Round 3.456 to 2 decimal places.","o":["3.46","3.45","3.50","3.4"],"a":0,"e":"Look at the 3rd decimal place (6). Since $6 \\geq 5$, round up: $3.456 \\approx 3.46$.","d":1,"s":"Y7.1","diag":"calc"},
  {"id":"h007","cat":"fractions","topic":"Multiplication of Fractions","q":"Calculate $1\\frac{2}{3} \\times \\frac{3}{5}$.","o":["$1$","$\\frac{3}{5}$","$\\frac{2}{5}$","$1\\frac{1}{5}$"],"a":0,"e":"Convert to improper: $\\frac{5}{3} \\times \\frac{3}{5}$. Cancel: $\\frac{5}{3} \\times \\frac{3}{5} = \\frac{15}{15} = 1$.","d":2,"s":"Y7.1","diag":"calc"},
  {"id":"h008","cat":"fractions","topic":"Multiplication of Fractions","q":"A recipe needs $\\frac{3}{4}$ cup of flour. If you make $\\frac{2}{3}$ of the recipe, how much flour do you need?","o":["$\\frac{1}{2}$ cup","$\\frac{5}{7}$ cup","$\\frac{2}{4}$ cup","$\\frac{6}{7}$ cup"],"a":0,"e":"$\\frac{3}{4} \\times \\frac{2}{3} = \\frac{6}{12} = \\frac{1}{2}$ cup.","d":2,"s":"Y7.1","diag":"logic"},
  {"id":"h009","cat":"fractions","topic":"Multiplication of Fractions","q":"Round 0.04567 to 2 significant figures.","o":["0.046","0.045","0.05","0.04"],"a":0,"e":"The first significant figure is 4, the second is 5. The next digit is 6, so round up: $0.046$.","d":2,"s":"Y7.1","diag":"calc"},

  {"id":"h010","cat":"fractions","topic":"Division of Fraction","q":"Calculate $\\frac{3}{4} \\div \\frac{1}{2}$.","o":["$\\frac{3}{2}$","$\\frac{3}{8}$","$\\frac{1}{2}$","$\\frac{2}{3}$"],"a":0,"e":"Dividing by a fraction means multiplying by its reciprocal: $\\frac{3}{4} \\times \\frac{2}{1} = \\frac{6}{4} = \\frac{3}{2}$.","d":1,"s":"Y7.2","diag":"concept"},
  {"id":"h011","cat":"fractions","topic":"Division of Fraction","q":"Calculate $5 \\div \\frac{1}{3}$.","o":["15","$\\frac{5}{3}$","$\\frac{1}{15}$","3"],"a":0,"e":"$5 \\div \\frac{1}{3} = 5 \\times 3 = 15$.","d":1,"s":"Y7.2","diag":"calc"},
  {"id":"h012","cat":"fractions","topic":"Division of Fraction","q":"What is $\\frac{2}{3} \\div \\frac{4}{5}$?","o":["$\\frac{5}{6}$","$\\frac{8}{15}$","$\\frac{6}{5}$","$\\frac{10}{12}$"],"a":0,"e":"$\\frac{2}{3} \\div \\frac{4}{5} = \\frac{2}{3} \\times \\frac{5}{4} = \\frac{10}{12} = \\frac{5}{6}$.","d":1,"s":"Y7.2","diag":"calc"},
  {"id":"h013","cat":"fractions","topic":"Division of Fraction","q":"Evaluate $(\\frac{1}{2} + \\frac{1}{3}) \\times 6$.","o":["5","3","4","6"],"a":0,"e":"First: $\\frac{1}{2} + \\frac{1}{3} = \\frac{5}{6}$. Then: $\\frac{5}{6} \\times 6 = 5$.","d":2,"s":"Y7.2","diag":"calc"},

  {"id":"h014","cat":"number","topic":"Negative Number","q":"Calculate $(-3) + (-5)$.","o":["$-8$","$-2$","$8$","$2$"],"a":0,"e":"Adding two negative numbers: $(-3) + (-5) = -(3+5) = -8$.","d":1,"s":"Y7.3","diag":"concept"},
  {"id":"h015","cat":"number","topic":"Negative Number","q":"Calculate $(-4) \\times (-6)$.","o":["$24$","$-24$","$-10$","$10$"],"a":0,"e":"Negative times negative gives positive: $(-4) \\times (-6) = 24$.","d":1,"s":"Y7.3","diag":"calc"},
  {"id":"h016","cat":"number","topic":"Negative Number","q":"What is $7 - (-3)$?","o":["$10$","$4$","$-4$","$-10$"],"a":0,"e":"Subtracting a negative is the same as adding: $7 - (-3) = 7 + 3 = 10$.","d":1,"s":"Y7.3","diag":"concept"},
  {"id":"h017","cat":"number","topic":"Negative Number","q":"Arrange in ascending order: $-5, 2, -1, 0, -3$.","o":["$-5, -3, -1, 0, 2$","$-1, -3, -5, 0, 2$","$2, 0, -1, -3, -5$","$-5, -1, -3, 0, 2$"],"a":0,"e":"From smallest to largest: $-5 < -3 < -1 < 0 < 2$.","d":1,"s":"Y7.3","diag":"concept"},

  {"id":"h018","cat":"geometry","topic":"Position and Direction","q":"A point is translated 3 units right and 2 units up from $(1, 4)$. What are the new coordinates?","o":["$(4, 6)$","$(3, 2)$","$(-2, 2)$","$(1, 6)$"],"a":0,"e":"Add 3 to x: $1+3=4$. Add 2 to y: $4+2=6$. New point: $(4, 6)$.","d":1,"s":"Y7.4","diag":"concept"},
  {"id":"h019","cat":"geometry","topic":"Position and Direction","q":"What is the reflection of the point $(3, -2)$ in the x-axis?","o":["$(3, 2)$","$(-3, -2)$","$(-3, 2)$","$(3, -2)$"],"a":0,"e":"Reflection in the x-axis changes the sign of y: $(3, -2) \\to (3, 2)$.","d":1,"s":"Y7.4","diag":"concept"},
  {"id":"h020","cat":"geometry","topic":"Position and Direction","q":"A shape is rotated $90^\\circ$ clockwise about the origin. The point $(2, 3)$ moves to:","o":["$(3, -2)$","$(-3, 2)$","$(-2, -3)$","$(2, -3)$"],"a":0,"e":"$90^\\circ$ clockwise rotation: $(x,y) \\to (y,-x)$. So $(2,3) \\to (3,-2)$.","d":2,"s":"Y7.4","diag":"concept"},

  {"id":"h021","cat":"ratio","topic":"Ratio and Proportion","q":"Simplify the ratio $12:18$.","o":["$2:3$","$3:4$","$6:9$","$4:6$"],"a":0,"e":"Divide both by HCF(12,18)=6: $12 \\div 6 : 18 \\div 6 = 2:3$.","d":1,"s":"Y7.5","diag":"calc"},
  {"id":"h022","cat":"ratio","topic":"Ratio and Proportion","q":"Share $\\$60$ in the ratio $2:3$. How much is the larger share?","o":["$\\$36$","$\\$24$","$\\$30$","$\\$40$"],"a":0,"e":"Total parts: $2+3=5$. One part: $60 \\div 5 = 12$. Larger share: $3 \\times 12 = \\$36$.","d":1,"s":"Y7.5","diag":"calc"},
  {"id":"h023","cat":"ratio","topic":"Ratio and Proportion","q":"If $5$ books cost $\\$35$, how much do $8$ books cost?","o":["$\\$56$","$\\$48$","$\\$40$","$\\$64$"],"a":0,"e":"Unit cost: $35 \\div 5 = \\$7$. For 8 books: $8 \\times 7 = \\$56$.","d":1,"s":"Y7.5","diag":"calc"},
  {"id":"h024","cat":"ratio","topic":"Ratio and Proportion","q":"Express $3:5$ as a fraction.","o":["$\\frac{3}{5}$","$\\frac{5}{3}$","$\\frac{3}{8}$","$\\frac{5}{8}$"],"a":0,"e":"$3:5$ means 3 out of 5, which is $\\frac{3}{5}$.","d":1,"s":"Y7.5","diag":"vocab"},

  {"id":"h025","cat":"percentage","topic":"Percentage","q":"Convert $\\frac{3}{5}$ to a percentage.","o":["$60\\%$","$35\\%$","$53\\%$","$75\\%$"],"a":0,"e":"$\\frac{3}{5} \\times 100 = 60\\%$.","d":1,"s":"Y7.6","diag":"calc"},
  {"id":"h026","cat":"percentage","topic":"Percentage","q":"Find $15\\%$ of $200$.","o":["$30$","$15$","$20$","$25$"],"a":0,"e":"$15\\% \\times 200 = 0.15 \\times 200 = 30$.","d":1,"s":"Y7.6","diag":"calc"},
  {"id":"h027","cat":"percentage","topic":"Percentage","q":"A shirt costs $\\$40$ and is reduced by $25\\%$. What is the sale price?","o":["$\\$30$","$\\$35$","$\\$25$","$\\$32$"],"a":0,"e":"Discount: $25\\%$ of $40 = \\$10$. Sale price: $40 - 10 = \\$30$.","d":1,"s":"Y7.6","diag":"calc"},
  {"id":"h028","cat":"percentage","topic":"Percentage","q":"Express $0.375$ as a percentage.","o":["$37.5\\%$","$3.75\\%$","$375\\%$","$0.375\\%$"],"a":0,"e":"$0.375 \\times 100 = 37.5\\%$.","d":1,"s":"Y7.6","diag":"calc"},

  {"id":"h029","cat":"geometry","topic":"Circle","q":"What is the circumference of a circle with radius $7$ cm? (Use $\\pi \\approx \\frac{22}{7}$)","o":["$44$ cm","$154$ cm","$22$ cm","$88$ cm"],"a":0,"e":"$C = 2\\pi r = 2 \\times \\frac{22}{7} \\times 7 = 44$ cm.","d":1,"s":"Y7.7","diag":"calc"},
  {"id":"h030","cat":"geometry","topic":"Circle","q":"Find the area of a circle with diameter $10$ cm. (Use $\\pi \\approx 3.14$)","o":["$78.5$ cm$^2$","$31.4$ cm$^2$","$314$ cm$^2$","$157$ cm$^2$"],"a":0,"e":"Radius $= 5$ cm. Area $= \\pi r^2 = 3.14 \\times 25 = 78.5$ cm$^2$.","d":1,"s":"Y7.7","diag":"calc"},
  {"id":"h031","cat":"geometry","topic":"Circle","q":"What is the name of a straight line from the centre to the circumference of a circle?","o":["Radius","Diameter","Chord","Tangent"],"a":0,"e":"A radius is a line segment from the centre of a circle to any point on the circumference.","d":1,"s":"Y7.7","diag":"vocab"},

  {"id":"h032","cat":"geometry","topic":"Cylinders and Cones","q":"Find the volume of a cylinder with radius $3$ cm and height $10$ cm. (Use $\\pi \\approx 3.14$)","o":["$282.6$ cm$^3$","$94.2$ cm$^3$","$188.4$ cm$^3$","$90$ cm$^3$"],"a":0,"e":"$V = \\pi r^2 h = 3.14 \\times 9 \\times 10 = 282.6$ cm$^3$.","d":1,"s":"Y7.8","diag":"calc"},
  {"id":"h033","cat":"geometry","topic":"Cylinders and Cones","q":"The volume of a cone is given by:","o":["$\\frac{1}{3}\\pi r^2 h$","$\\pi r^2 h$","$\\frac{1}{2}\\pi r^2 h$","$2\\pi r h$"],"a":0,"e":"The volume of a cone is $\\frac{1}{3}$ of the volume of a cylinder with the same base and height.","d":1,"s":"Y7.8","diag":"concept"},
  {"id":"h034","cat":"geometry","topic":"Cylinders and Cones","q":"Find the curved surface area of a cylinder with radius $4$ cm and height $7$ cm. (Use $\\pi \\approx 3.14$)","o":["$175.84$ cm$^2$","$87.92$ cm$^2$","$351.68$ cm$^2$","$100.48$ cm$^2$"],"a":0,"e":"Curved SA $= 2\\pi rh = 2 \\times 3.14 \\times 4 \\times 7 = 175.84$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"},

  {"id":"h035","cat":"algebra","topic":"Linear Sequences","q":"Find the next term in the sequence: $3, 7, 11, 15, \\ldots$","o":["$19$","$18$","$20$","$17$"],"a":0,"e":"Common difference: $7-3=4$. Next term: $15+4=19$.","d":1,"s":"Y7.9","diag":"calc"},
  {"id":"h036","cat":"algebra","topic":"Linear Sequences","q":"What is the $n$th term rule for the sequence $5, 8, 11, 14, \\ldots$?","o":["$3n + 2$","$3n + 5$","$n + 3$","$5n + 3$"],"a":0,"e":"Common difference $= 3$. Zero term $= 5 - 3 = 2$. $n$th term $= 3n + 2$.","d":2,"s":"Y7.9","diag":"concept"},
  {"id":"h037","cat":"algebra","topic":"Linear Sequences","q":"Find the 10th term of the sequence with $n$th term $= 2n - 1$.","o":["$19$","$20$","$21$","$18$"],"a":0,"e":"Substitute $n=10$: $2(10) - 1 = 19$.","d":1,"s":"Y7.9","diag":"calc"},
  {"id":"h038","cat":"algebra","topic":"Linear Sequences","q":"Is $50$ a term of the sequence $4, 9, 14, 19, \\ldots$?","o":["No","Yes","",""],"a":0,"e":"$n$th term $= 5n - 1$. Set $5n - 1 = 50$: $n = 10.2$. Since $n$ is not a whole number, $50$ is not a term.","d":2,"s":"Y7.9","diag":"logic"},

  {"id":"h039","cat":"probability","topic":"Probability","q":"A fair dice is rolled. What is the probability of getting a number greater than $4$?","o":["$\\frac{1}{3}$","$\\frac{1}{2}$","$\\frac{2}{3}$","$\\frac{1}{6}$"],"a":0,"e":"Numbers greater than 4: $\\{5, 6\\}$. Probability $= \\frac{2}{6} = \\frac{1}{3}$.","d":1,"s":"Y7.10","diag":"calc"},
  {"id":"h040","cat":"probability","topic":"Probability","q":"A bag has 3 red and 5 blue balls. What is the probability of picking a red ball?","o":["$\\frac{3}{8}$","$\\frac{5}{8}$","$\\frac{3}{5}$","$\\frac{1}{3}$"],"a":0,"e":"Total balls $= 3 + 5 = 8$. $P(\\text{red}) = \\frac{3}{8}$.","d":1,"s":"Y7.10","diag":"calc"},
  {"id":"h041","cat":"probability","topic":"Probability","q":"The probability of an event is $0.3$. What is the probability it does NOT happen?","o":["$0.7$","$0.3$","$1.3$","$0.03$"],"a":0,"e":"$P(\\text{not}) = 1 - P(\\text{event}) = 1 - 0.3 = 0.7$.","d":1,"s":"Y7.10","diag":"concept"},

  {"id":"h042","cat":"geometry","topic":"Constructions","q":"What instrument is used to draw an arc?","o":["Compass","Protractor","Ruler","Set square"],"a":0,"e":"A compass (pair of compasses) is used to draw arcs and circles.","d":1,"s":"Y7.11","diag":"vocab"},
  {"id":"h043","cat":"geometry","topic":"Constructions","q":"To bisect an angle, you need:","o":["A compass and a straight edge","Only a protractor","A ruler only","A calculator"],"a":0,"e":"Angle bisection is done using a compass to draw two arcs and a straight edge to connect the intersection.","d":1,"s":"Y7.11","diag":"concept"},
  {"id":"h044","cat":"geometry","topic":"Constructions","q":"What does 'perpendicular bisector' mean?","o":["A line that cuts another at 90 degrees at its midpoint","A line parallel to another","A line at 45 degrees","Any line through a midpoint"],"a":0,"e":"A perpendicular bisector crosses the line at its midpoint at a right angle ($90^\\circ$).","d":1,"s":"Y7.11","diag":"vocab"},

  {"id":"h045","cat":"fractions","topic":"Division of Fraction","q":"Calculate $2\\frac{1}{2} \\div 1\\frac{1}{4}$.","o":["$2$","$\\frac{5}{4}$","$3$","$\\frac{8}{5}$"],"a":0,"e":"Convert: $\\frac{5}{2} \\div \\frac{5}{4} = \\frac{5}{2} \\times \\frac{4}{5} = \\frac{20}{10} = 2$.","d":2,"s":"Y7.2","diag":"calc"},
  {"id":"h046","cat":"number","topic":"Negative Number","q":"Calculate $(-8) \\div (-2)$.","o":["$4$","$-4$","$16$","$-16$"],"a":0,"e":"Negative divided by negative gives positive: $(-8) \\div (-2) = 4$.","d":1,"s":"Y7.3","diag":"calc"},
  {"id":"h047","cat":"number","topic":"Negative Number","q":"The temperature drops from $5^\\circ$C to $-3^\\circ$C. What is the change?","o":["$-8^\\circ$C","$8^\\circ$C","$-2^\\circ$C","$2^\\circ$C"],"a":0,"e":"Change $= -3 - 5 = -8^\\circ$C (a drop of $8$ degrees).","d":1,"s":"Y7.3","diag":"logic"},
  {"id":"h048","cat":"percentage","topic":"Percentage","q":"Increase $80$ by $20\\%$.","o":["$96$","$100$","$84$","$64$"],"a":0,"e":"$20\\%$ of $80 = 16$. New value: $80 + 16 = 96$. Or: $80 \\times 1.2 = 96$.","d":1,"s":"Y7.6","diag":"calc"},
  {"id":"h049","cat":"ratio","topic":"Ratio and Proportion","q":"A map has a scale of $1:50000$. A distance on the map is $4$ cm. What is the real distance in km?","o":["$2$ km","$20$ km","$200$ km","$0.2$ km"],"a":0,"e":"Real distance $= 4 \\times 50000 = 200000$ cm $= 2000$ m $= 2$ km.","d":2,"s":"Y7.5","diag":"calc"},
  {"id":"h050","cat":"geometry","topic":"Circle","q":"A chord passes through the centre of a circle. It is called a:","o":["Diameter","Radius","Tangent","Secant"],"a":0,"e":"A chord that passes through the centre is called a diameter.","d":1,"s":"Y7.7","diag":"vocab"},

  {"id":"h051","cat":"algebra","topic":"Linear Sequences","q":"The first term of a sequence is $a = 3$ and common difference $d = -2$. Find the 5th term.","o":["$-5$","$-3$","$-7$","$5$"],"a":0,"e":"$a_5 = a + 4d = 3 + 4(-2) = 3 - 8 = -5$.","d":2,"s":"Y7.9","diag":"calc"},
  {"id":"h052","cat":"probability","topic":"Probability","q":"Two coins are tossed. What is the probability of getting two heads?","o":["$\\frac{1}{4}$","$\\frac{1}{2}$","$\\frac{1}{3}$","$\\frac{3}{4}$"],"a":0,"e":"Outcomes: HH, HT, TH, TT. $P(HH) = \\frac{1}{4}$.","d":2,"s":"Y7.10","diag":"logic"},
  {"id":"h053","cat":"percentage","topic":"Percentage","q":"What is $12.5\\%$ as a fraction in its simplest form?","o":["$\\frac{1}{8}$","$\\frac{1}{4}$","$\\frac{1}{12}$","$\\frac{5}{40}$"],"a":0,"e":"$12.5\\% = \\frac{12.5}{100} = \\frac{125}{1000} = \\frac{1}{8}$.","d":1,"s":"Y7.6","diag":"calc"},
  {"id":"h054","cat":"ratio","topic":"Ratio and Proportion","q":"If $y$ is directly proportional to $x$, and $y = 12$ when $x = 4$, find $y$ when $x = 7$.","o":["$21$","$28$","$15$","$24$"],"a":0,"e":"$k = \\frac{y}{x} = \\frac{12}{4} = 3$. When $x = 7$: $y = 3 \\times 7 = 21$.","d":2,"s":"Y7.5","diag":"calc"},
  {"id":"h055","cat":"geometry","topic":"Cylinders and Cones","q":"A cone has radius $5$ cm, height $12$ cm, and slant height $13$ cm. Find the total surface area. (Use $\\pi \\approx 3.14$)","o":["$282.6$ cm$^2$","$204.1$ cm$^2$","$345.4$ cm$^2$","$157$ cm$^2$"],"a":0,"e":"Total SA $= \\pi r l + \\pi r^2 = 3.14 \\times 5 \\times 13 + 3.14 \\times 25 = 204.1 + 78.5 = 282.6$ cm$^2$.","d":2,"s":"Y7.8","diag":"calc"}
]
