[{"id":"0580-2024March-Paper22-Q01","paper":"2024March-Paper22","qnum":1,"marks":1,"topics":["Number"],"s":"1.6","d":2,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/22/M/24 Q01","year":2024,"session":"March","tex":"A night bus runs from 21 50 to 05 18 the next day.\n\nWork out the number of hours and minutes that the night bus runs.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q02","paper":"2024March-Paper22","qnum":2,"marks":1,"topics":["Number"],"s":"1.3","d":2,"cat":"number","topic":"Powers and roots","qtype":"powers and roots","g":"indices","src":"0580/22/M/24 Q02","year":2024,"session":"March","tex":"Calculate $5.76 + 2.8^3$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q03","paper":"2024March-Paper22","qnum":3,"marks":2,"topics":["Algebra and graphs"],"s":"2.2","d":2,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/22/M/24 Q03","year":2024,"session":"March","tex":"Simplify $4m + 7k - m + 3k$.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024March-Paper22-Q04","paper":"2024March-Paper22","qnum":4,"marks":4,"topics":["Mensuration"],"s":"5.2","d":2,"cat":"mensuration","topic":"Area and perimeter","qtype":"area and perimeter","g":"mixed","src":"0580/22/M/24 Q04","year":2024,"session":"March","tex":"The diagram shows the net of a cuboid with its base shaded.\nThe length of the cuboid is 10 cm, its width is 4 cm and its height is 5 cm.\n\nWrite down the values of each of $a$, $b$, $c$ and $d$.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"write"},{"id":"0580-2024March-Paper22-Q05","paper":"2024March-Paper22","qnum":5,"marks":3,"topics":["Mensuration","Probability","Statistics"],"s":"5.3","d":2,"cat":"mensuration","topic":"Circles, arcs and sectors","qtype":"circles, arcs and sectors","g":"mixed","src":"0580/22/M/24 Q05","year":2024,"session":"March","tex":"There are 20 cars in a car park and 3 of the cars are blue.\n\n(a) James wants to draw a pie chart to show this information.\n\nFind the angle of the sector for the blue cars in this pie chart.\n\n(b) One of the 20 cars is picked at random.\n\nFind the probability that this car is not blue.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"apply","cmd":"draw"},{"id":"0580-2024March-Paper22-Q06","paper":"2024March-Paper22","qnum":6,"marks":1,"topics":["Transformations and vectors"],"s":"7.2","d":2,"cat":"vectors","topic":"Vectors in 2D","qtype":"vector operations","g":"mixed","src":"0580/22/M/24 Q06","year":2024,"session":"March","tex":"Write $\\overrightarrow{AB}$ as a column vector.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"write"},{"id":"0580-2024March-Paper22-Q07","paper":"2024March-Paper22","qnum":7,"marks":1,"topics":["Statistics"],"s":"9.5","d":2,"cat":"statistics","topic":"Scatter diagrams and correlation","qtype":"scatter diagrams","g":"mixed","src":"0580/22/M/24 Q07","year":2024,"session":"March","tex":"As the temperature increases, the number of people who go swimming increases.\n\nWrite down the type of correlation that this statement describes.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024March-Paper22-Q08","paper":"2024March-Paper22","qnum":8,"marks":4,"topics":["Algebra and graphs"],"s":"2.7","d":2,"cat":"algebra","topic":"Sequences","qtype":"sequences","g":"sequence","src":"0580/22/M/24 Q08","year":2024,"session":"March","tex":"(a) The $n$th term of a sequence is $n^2 - 3$.\n\nFind the first three terms of this sequence.\n\n\n\n(b) These are the first five terms of a different sequence.\n\\[ 1 \\quad 3 \\quad 9 \\quad 27 \\quad 81 \\]\n\nFind the $n$th term of this sequence.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024March-Paper22-Q09","paper":"2024March-Paper22","qnum":9,"marks":2,"topics":["Coordinate geometry"],"s":"3.1","d":2,"cat":"coord","topic":"Coordinates","qtype":"coordinates reading/plotting","g":"graph","src":"0580/22/M/24 Q09","year":2024,"session":"March","tex":"The line $y = 2x - 5$ intersects the line $y = 3$ at the point $P$.\n\nFind the coordinates of the point $P$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024March-Paper22-Q10","paper":"2024March-Paper22","qnum":10,"marks":2,"topics":["Geometry","Mensuration"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/22/M/24 Q10","year":2024,"session":"March","tex":"The diagram shows a trapezium $PQRS$.\n\nCalculate the area of the trapezium.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q11","paper":"2024March-Paper22","qnum":11,"marks":3,"topics":["Number"],"s":"1.4","d":2,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/22/M/24 Q11","year":2024,"session":"March","tex":"Without using a calculator, work out $1 \\frac{1}{4} - \\frac{5}{6}$.\n\nYou must show all your working and give your answer as a fraction in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q12","paper":"2024March-Paper22","qnum":12,"marks":1,"topics":["Probability"],"s":"8.2","d":2,"cat":"probability","topic":"Relative and expected frequencies","qtype":"relative/expected frequency","g":"mixed","src":"0580/22/M/24 Q12","year":2024,"session":"March","tex":"Farid spins a three-sided spinner with sides labelled $A$, $B$ and $C$.\nThe probability that the spinner lands on $C$ is 0.35.\nFarid spins the spinner 40 times.\n\nCalculate the number of times he expects the spinner to land on $C$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q13","paper":"2024March-Paper22","qnum":13,"marks":2,"topics":["Geometry"],"s":"4.3","d":2,"cat":"geometry","topic":"Scale drawings and bearings","qtype":"scale drawings and bearings","g":"mixed","src":"0580/22/M/24 Q13","year":2024,"session":"March","tex":"The bearing of $B$ from $A$ is 107\\degree.\n\nCalculate the bearing of $A$ from $B$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q14","paper":"2024March-Paper22","qnum":14,"marks":3,"topics":["Number"],"s":"1.12","d":2,"cat":"number","topic":"Rates","qtype":"rates","g":"mixed","src":"0580/22/M/24 Q14","year":2024,"session":"March","tex":"A train, 1750 metres long, is travelling at 55 km/h.\n\nCalculate how long it will take for the whole train to completely cross a bridge that is 480 metres long.\nGive your answer in seconds, correct to the nearest second.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q15","paper":"2024March-Paper22","qnum":15,"marks":7,"topics":["Geometry","Transformations and vectors"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/22/M/24 Q15","year":2024,"session":"March","tex":"(a) Describe fully the single transformation that maps\n(i) (b) triangle $A$ onto triangle $B$,\n\n(c) triangle $A$ onto triangle $C$.\n\n(d) Draw the image of triangle $A$ after a rotation, 90\\degree clockwise, about $(1, 3)$.","parts":[{"label":"(a)","marks":0},{"label":"(b)","marks":2},{"label":"(c)","marks":3},{"label":"(d)","marks":2}],"hasFigure":true,"cognitive":"recall","cmd":"describe"},{"id":"0580-2024March-Paper22-Q16","paper":"2024March-Paper22","qnum":16,"marks":2,"topics":["Number"],"s":"1.2","d":2,"cat":"number","topic":"Sets","qtype":"sets and Venn diagrams","g":"mixed","src":"0580/22/M/24 Q16","year":2024,"session":"March","tex":"$x$ is an integer.\n\\[ \\mathscr{E} = \\{ x : 1 \\leqslant x \\leqslant 10 \\} \\]\n\\[ P = \\{ x : x \\text{ is an even number} \\} \\]\n\\[ Q = \\{ x : x \\text{ is a multiple of 5} \\} \\]\n\nComplete the Venn diagram.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"complete"},{"id":"0580-2024March-Paper22-Q17","paper":"2024March-Paper22","qnum":17,"marks":4,"topics":["Number","Statistics"],"s":"1.9","d":2,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/22/M/24 Q17","year":2024,"session":"March","tex":"The height of each of 200 people is measured.\nThe table shows the results.\n\n\\begin{tabular}{|l|c|c|c|c|}\n\\hline\nHeight ($h$ cm) & $100 < h \\leqslant 120$ & $120 < h \\leqslant 130$ & $130 < h \\leqslant 150$ & $150 < h \\leqslant 190$ \\\\\n\\hline\nFrequency & 32 & 55 & 64 & 49 \\\\\n\\hline\n\\end{tabular}\nCalculate an estimate of the mean height.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","texHtml":"The height of each of 200 people is measured.\nThe table shows the results.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><th>Height ($h$ cm)</th><th style=\"text-align:center\">$100 < h \\leqslant 120$</th><th style=\"text-align:center\">$120 < h \\leqslant 130$</th><th style=\"text-align:center\">$130 < h \\leqslant 150$</th><th style=\"text-align:center\">$150 < h \\leqslant 190$</th></tr><tr><td>Frequency</td><td style=\"text-align:center\">32</td><td style=\"text-align:center\">55</td><td style=\"text-align:center\">64</td><td style=\"text-align:center\">49</td></tr></table></div>\nCalculate an estimate of the mean height."},{"id":"0580-2024March-Paper22-Q18","paper":"2024March-Paper22","qnum":18,"marks":2,"topics":["Number"],"s":"1.1","d":2,"cat":"number","topic":"Types of number","qtype":"types of number","g":"mixed","src":"0580/22/M/24 Q18","year":2024,"session":"March","tex":"Find the highest common factor (HCF) of $28x^5$ and $98x^3$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024March-Paper22-Q19","paper":"2024March-Paper22","qnum":19,"marks":3,"topics":["Number"],"s":"1.12","d":2,"cat":"number","topic":"Rates","qtype":"rates","g":"mixed","src":"0580/22/M/24 Q19","year":2024,"session":"March","tex":"The speed--time graph shows information about a bus journey.\n\nCalculate the total distance travelled by the bus.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q20","paper":"2024March-Paper22","qnum":20,"marks":2,"topics":["Geometry","Mensuration"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/22/M/24 Q20","year":2024,"session":"March","tex":"Calculate the area of triangle $ABC$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q21","paper":"2024March-Paper22","qnum":21,"marks":3,"topics":["Algebra and graphs"],"s":"2.4","d":2,"cat":"algebra","topic":"Indices II","qtype":"indices in algebra","g":"indices","src":"0580/22/M/24 Q21","year":2024,"session":"March","tex":"(a) $3^{-5} = 3^h$\n\nWrite down the value of $h$.\n\n(b) Simplify $(4x^3)^3$.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024March-Paper22-Q22","paper":"2024March-Paper22","qnum":22,"marks":2,"topics":["Algebra and graphs"],"s":"2.8","d":2,"cat":"algebra","topic":"Proportion","qtype":"proportion","g":"proportion","src":"0580/22/M/24 Q22","year":2024,"session":"March","tex":"$y$ is inversely proportional to the square of $(x + 3)$.\nWhen $x = 5$, $y = 0.375$.\n\nFind $y$ in terms of $x$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024March-Paper22-Q23","paper":"2024March-Paper22","qnum":23,"marks":4,"topics":["Algebra and graphs","Trigonometry"],"s":"2.11","d":2,"cat":"algebra","topic":"Sketching curves","qtype":"sketching curves","g":"graph","src":"0580/22/M/24 Q23","year":2024,"session":"March","tex":"(a) On the axes, sketch the graph of $y = \\cos x$, for $0\\degree \\leqslant x \\leqslant 360\\degree$.\n\n(b) Solve the equation $\\cos x = 0.294$ for $0\\degree \\leqslant x \\leqslant 360\\degree$.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"apply","cmd":"sketch"},{"id":"0580-2024March-Paper22-Q24","paper":"2024March-Paper22","qnum":24,"marks":2,"topics":["Number"],"s":"1.6","d":2,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/22/M/24 Q24","year":2024,"session":"March","tex":"$x^2 - 16x + a$ can be written in the form $(x + b)^2$.\n\nFind the value of $a$ and the value of $b$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024March-Paper22-Q25","paper":"2024March-Paper22","qnum":25,"marks":4,"topics":["Probability"],"s":"8.4","d":2,"cat":"probability","topic":"Conditional probability","qtype":"conditional probability","g":"mixed","src":"0580/22/M/24 Q25","year":2024,"session":"March","tex":"A bag contains 2 green buttons, 5 red buttons and 6 blue buttons.\nTwo buttons are taken at random from the bag without replacement.\n\nCalculate the probability that the two buttons are different colours.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024March-Paper22-Q26","paper":"2024March-Paper22","qnum":26,"marks":5,"topics":["Geometry","Mensuration"],"s":"4.2","d":2,"cat":"geometry","topic":"Geometrical constructions","qtype":"geometrical constructions","g":"mixed","src":"0580/22/M/24 Q26","year":2024,"session":"March","tex":"$A$ is the point $(6, 1)$ and $B$ is the point $(2, 7)$.\n\nFind the equation of the perpendicular bisector of $AB$.\nGive your answer in the form $y = mx + c$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"}]