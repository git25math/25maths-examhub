[{"id":"0580-2023OctNov-Paper12-Q01","paper":"2023OctNov-Paper12","qnum":1,"marks":1,"topics":["Number"],"s":"1.4","d":1,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/12/O/N/23 Q01","year":2023,"session":"OctNov","tex":"Write $\\frac{8}{10}$ as a decimal.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2023OctNov-Paper12-Q02","paper":"2023OctNov-Paper12","qnum":2,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/23 Q02","year":2023,"session":"OctNov","tex":"Asha works in a café.\nHer wage is calculated using the formula wage $=$ hourly rate $\\times$ number of hours $+$ bonus.\nHer hourly rate is \\$11.52 .\nOne week Asha works 25 hours and receives a bonus of \\$5.40 .\n\nWork out her wage for this week.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q03","paper":"2023OctNov-Paper12","qnum":3,"marks":2,"topics":["Algebra and graphs"],"s":"2.7","d":1,"cat":"algebra","topic":"Sequences","qtype":"sequences","g":"sequence","src":"0580/12/O/N/23 Q03","year":2023,"session":"OctNov","tex":"These are the first four terms in a sequence.\n\\[\n-3  4  11  18\n\\]\n\n(a) Find the next term.\n\n(b) Explain how you worked out your answer.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"apply","cmd":"explain"},{"id":"0580-2023OctNov-Paper12-Q04","paper":"2023OctNov-Paper12","qnum":4,"marks":1,"topics":["Number"],"s":"1.4","d":1,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/12/O/N/23 Q04","year":2023,"session":"OctNov","tex":"Work out $\\frac{2}{5}$ of 180.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q05","paper":"2023OctNov-Paper12","qnum":5,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/12/O/N/23 Q05","year":2023,"session":"OctNov","tex":"Write these numbers in order, starting with the smallest.\n\\[\n\\frac{3}{16}  18.7\\%  0.19  \\frac{9}{50}\n\\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2023OctNov-Paper12-Q06","paper":"2023OctNov-Paper12","qnum":6,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/23 Q06","year":2023,"session":"OctNov","tex":"Write down the number that is 9 greater than $-23$.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2023OctNov-Paper12-Q07","paper":"2023OctNov-Paper12","qnum":7,"marks":4,"topics":["Statistics"],"s":"9.4","d":1,"cat":"statistics","topic":"Statistical charts and diagrams","qtype":"statistical charts","g":"mixed","src":"0580/12/O/N/23 Q07","year":2023,"session":"OctNov","tex":"For 16 days, Safia records the number of dresses she sells.\n\\[\n24  6  18  14  27  37  9  16\n\\]\n\\[\n22  17  16  16  24  20  15  32\n\\]\n(a) Complete the stem-and-leaf diagram.\n\n\\begin{tabular}{r|p{10cm}}\n0 & \\\\\n1 & \\\\\n2 & \\\\\n3 & \\\\\n\\end{tabular}\n Key: $2 \\mid 4$ represents 24 dresses \n\n(b) Write down the mode.\n\n(c) Find the median.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":1},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"complete","texHtml":"For 16 days, Safia records the number of dresses she sells.\n\\[\n24  6  18  14  27  37  9  16\n\\]\n\\[\n22  17  16  16  24  20  15  32\n\\]\n(a) Complete the stem-and-leaf diagram.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><td style=\"text-align:right\">}\n0 &</td></tr><tr><td style=\"text-align:right\">1</td><td style=\"text-align:center\"></td></tr><tr><td style=\"text-align:right\">2</td><td style=\"text-align:center\"></td></tr><tr><td style=\"text-align:right\">3</td><td style=\"text-align:center\"></td></tr></table></div>\n Key: $2 \\mid 4$ represents 24 dresses \n\n(b) Write down the mode.\n\n(c) Find the median."},{"id":"0580-2023OctNov-Paper12-Q08","paper":"2023OctNov-Paper12","qnum":8,"marks":2,"topics":["Number"],"s":"1.9","d":1,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/12/O/N/23 Q08","year":2023,"session":"OctNov","tex":"Write 24.07839\n(a) correct to 2 decimal places,\n\n(b) correct to the nearest 10.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2023OctNov-Paper12-Q09","paper":"2023OctNov-Paper12","qnum":9,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/23 Q09","year":2023,"session":"OctNov","tex":"$v = u + at$\n\nFind the value of $v$ when $u = 30$, $a = -2$ and $t = 7$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2023OctNov-Paper12-Q10","paper":"2023OctNov-Paper12","qnum":10,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/23 Q10","year":2023,"session":"OctNov","tex":"Change 62\\,000 millimetres into kilometres.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"other"},{"id":"0580-2023OctNov-Paper12-Q11","paper":"2023OctNov-Paper12","qnum":11,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/23 Q11","year":2023,"session":"OctNov","tex":"\\includegraphics{\\currfiledir Figures/Q11.png}\nThe diagram shows two straight lines crossing two parallel lines.\n\nFind the value of $x$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2023OctNov-Paper12-Q12","paper":"2023OctNov-Paper12","qnum":12,"marks":2,"topics":["Number"],"s":"1.1","d":1,"cat":"number","topic":"Types of number","qtype":"types of number","g":"mixed","src":"0580/12/O/N/23 Q12","year":2023,"session":"OctNov","tex":"(a) Explain why 111 is not a prime number.\n\n(b) Find a prime number between 110 and 120.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"analyse","cmd":"explain"},{"id":"0580-2023OctNov-Paper12-Q13","paper":"2023OctNov-Paper12","qnum":13,"marks":2,"topics":["Geometry"],"s":"4.3","d":1,"cat":"geometry","topic":"Scale drawings and bearings","qtype":"scale drawings and bearings","g":"mixed","src":"0580/12/O/N/23 Q13","year":2023,"session":"OctNov","tex":"\\includegraphics{\\currfiledir Figures/Q13.png}\nFind the bearing of $Q$ from $P$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2023OctNov-Paper12-Q14","paper":"2023OctNov-Paper12","qnum":14,"marks":2,"topics":["Statistics"],"s":"9.5","d":1,"cat":"statistics","topic":"Scatter diagrams and correlation","qtype":"scatter diagrams","g":"mixed","src":"0580/12/O/N/23 Q14","year":2023,"session":"OctNov","tex":"(a) As the age of a car increases, the selling price decreases.\n\nWhat type of correlation is this?\n\n(b) Write down the type of correlation there is between the height of a driver and the value of their car.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2023OctNov-Paper12-Q15","paper":"2023OctNov-Paper12","qnum":15,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/23 Q15","year":2023,"session":"OctNov","tex":"Calculate the interior angle of a regular 9-sided polygon.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q16","paper":"2023OctNov-Paper12","qnum":16,"marks":3,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/12/O/N/23 Q16","year":2023,"session":"OctNov","tex":"Filip invests \\$4000 for 3 years at a rate of 2.5\\% per year simple interest.\n\nCalculate the value of his investment at the end of the 3 years.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q17","paper":"2023OctNov-Paper12","qnum":17,"marks":4,"topics":["Geometry","Mensuration","Trigonometry"],"s":"4.7","d":1,"cat":"geometry","topic":"Circle theorems","qtype":"circle theorems","g":"mixed","src":"0580/12/O/N/23 Q17","year":2023,"session":"OctNov","tex":"\\includegraphics{\\currfiledir Figures/Q17.png}\n$A$, $B$ and $C$ are points on a circle, centre $O$.\n(a) Draw a tangent to the circle at point $A$.\n\n(b) The circumference of the circle is 22.3 cm.\n\nCalculate the radius of the circle.\n\n(c) Give a geometrical reason why angle $BCA$ is $90^\\circ$.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"draw"},{"id":"0580-2023OctNov-Paper12-Q18","paper":"2023OctNov-Paper12","qnum":18,"marks":2,"topics":["Algebra and graphs"],"s":"2.2","d":1,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/12/O/N/23 Q18","year":2023,"session":"OctNov","tex":"Expand and simplify.\n\\[\n2(t + w) + 3(w - t)\n\\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2023OctNov-Paper12-Q19","paper":"2023OctNov-Paper12","qnum":19,"marks":3,"topics":["Number"],"s":"1.4","d":1,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/12/O/N/23 Q19","year":2023,"session":"OctNov","tex":"Without using a calculator, work out $3\\frac{1}{8} - 1\\frac{3}{4}$.\nYou must show all your working and give your answer as a mixed number in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q20","paper":"2023OctNov-Paper12","qnum":20,"marks":3,"topics":["Number"],"s":"1.2","d":1,"cat":"number","topic":"Sets","qtype":"sets and Venn diagrams","g":"mixed","src":"0580/12/O/N/23 Q20","year":2023,"session":"OctNov","tex":"$\\mathscr{E} = \\{\\text{students in a class}\\}$\n$C = \\{\\text{students who play cricket}\\}$\n$F = \\{\\text{students who play football}\\}$\n\nThere are 36 students in the class.\n15 students play cricket.\n20 students play football.\n(a) \\includegraphics{\\currfiledir Figures/Q20.png}\nComplete the Venn diagram.\n\n(b) Write down n$(C \\cup F)$.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"complete"},{"id":"0580-2023OctNov-Paper12-Q21","paper":"2023OctNov-Paper12","qnum":21,"marks":3,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/23 Q21","year":2023,"session":"OctNov","tex":"$ABC$ is a right-angled triangle.\n\\includegraphics{\\currfiledir Figures/Q21.png}\nCalculate $AC$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q22","paper":"2023OctNov-Paper12","qnum":22,"marks":5,"topics":["Coordinate geometry"],"s":"3.5","d":1,"cat":"coord","topic":"Equations of linear graphs","qtype":"equation of a straight line","g":"mixed","src":"0580/12/O/N/23 Q22","year":2023,"session":"OctNov","tex":"Point $A$ and line $L$ are shown on the grid.\n\\includegraphics{\\currfiledir Figures/Q22.png}\n(a) Write down the coordinates of point $A$.\n\n(b) On the grid, plot the point $(-2, 4)$.\n\n(c) Find the equation of line $L$.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1},{"label":"(c)","marks":3}],"hasFigure":true,"cognitive":"apply","cmd":"draw"},{"id":"0580-2023OctNov-Paper12-Q23","paper":"2023OctNov-Paper12","qnum":23,"marks":3,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/23 Q23","year":2023,"session":"OctNov","tex":"Bell A rings every 22 minutes.\nBell B rings every 14 minutes.\nBoth bells ring at 09\\,00.\n\nWork out the next time both bells ring together.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2023OctNov-Paper12-Q24","paper":"2023OctNov-Paper12","qnum":24,"marks":2,"topics":["Geometry"],"s":"4.4","d":1,"cat":"geometry","topic":"Similarity and congruence","qtype":"similarity and congruence","g":"mixed","src":"0580/12/O/N/23 Q24","year":2023,"session":"OctNov","tex":"\\includegraphics{\\currfiledir Figures/Q24.png}\nTriangle $ABC$ is mathematically similar to triangle $DEF$.\n\nCalculate the value of $x$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"}]