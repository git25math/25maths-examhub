nce\n\\[\nT_1 = 17 \\qquad T_2 = 12 \\qquad T_3 = 7 \\qquad T_4 = 2.\n\\]\n\nFind\n\n(a) $T_5$\n\n(b) $T_n$.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2025Specimen-Paper2-Q10","paper":"2025Specimen-Paper2","qnum":10,"marks":3,"topics":["Number"],"s":"1.4","d":2,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/2/S/25 Q10","year":2025,"session":"Specimen","tex":"Work out \\quad$2\\dfrac{2}{3} + 3\\dfrac{1}{2}$.\n\nGive your answer as a mixed number in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025Specimen-Paper2-Q11","paper":"2025Specimen-Paper2","qnum":11,"marks":2,"topics":["Number"],"s":"1.3","d":2,"cat":"number","topic":"Powers and roots","qtype":"powers and roots","g":"indices","src":"0580/2/S/25 Q11","year":2025,"session":"Specimen","tex":"Find the value of $64^{\\frac{2}{3}}$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2025Specimen-Paper2-Q12","paper":"2025Specimen-Paper2","qnum":12,"marks":4,"topics":["Number"],"s":"1.8","d":2,"cat":"number","topic":"Standard form","qtype":"standard form","g":"mixed","src":"0580/2/S/25 Q12","year":2025,"session":"Specimen","tex":"Work out, giving your answer in standard form,\n\n(a) $(7.1 \\times 10^{-15}) \\times (2 \\times 10^{3})$\n\n(b) $(5.2 \\times 10^{7}) + (5.2 \\times 10^{6})$","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025Specimen-Paper2-Q13","paper":"2025Specimen-Paper2","qnum":13,"marks":2,"topics":["Geometry"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/2/S/25 Q13","year":2025,"session":"Specimen","tex":"Find the number of sides of a regular polygon with interior angle $162^\\circ$.","parts":[],"hasFigure":false,"cognitiv