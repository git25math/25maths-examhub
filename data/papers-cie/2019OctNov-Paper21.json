ic":"Algebraic fractions","qtype":"algebraic fractions","g":"algebraic-fraction","src":"0580/21/O/N/19 Q10","year":2019,"session":"OctNov","tex":"Simplify.\n\\[\n\\frac{4}{x^{3}} - \\frac{3}{3x^{2}} + 8\n\\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2019OctNov-Paper21-Q11","paper":"2019OctNov-Paper21","qnum":11,"marks":2,"topics":["Algebra and graphs"],"s":"2.5","d":2,"cat":"algebra","topic":"Equations","qtype":"equations","g":"mixed","src":"0580/21/O/N/19 Q11","year":2019,"session":"OctNov","tex":"\\[\nP = 2r + r^{2}\n\\]\nRearrange the formula to write r in terms of P and r.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"rearrange","answer":{"type":"number","prefix":"r ="}},{"id":"0580-2019OctNov-Paper21-Q12","paper":"2019OctNov-Paper21","qnum":12,"marks":2,"topics":["Number","Mensuration"],"s":"1.10","d":2,"cat":"number","topic":"Limits of accuracy","qtype":"limits of accuracy","g":"mixed","src":"0580/21/O/N/19 Q12","year":2019,"session":"OctNov","tex":"The sides of a square are 15.1 cm, correct to 1 decimal place.\n\nFind the upper bound of the area of the square.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find","answer":{"type":"number","suffix":"cm²"}},{"id":"0580-2019OctNov-Paper21-Q13","paper":"2019OctNov-Paper21","qnum":13,"marks":2,"topics":["Coordinate geometry","Mensuration","Transformations and vectors"],"s":"3.4","d":2,"cat":"coord","topic":"Length and midpoint","qtype":"length and midpoint","g":"mixed","src":"0580/21/O/N/19 Q13","year":2019,"session":"OctNov","tex":"Calculate the area of the triangle.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"cm²"}},{"id":"0580-2019OctNov-Paper21-Q14","paper":"2019OctNov-Paper21","qnum":14,"marks":3,"topics":["Mensuration"],"s":"5.2","d":2,"cat":"mensuration","topic":"Area and perimeter","qtype":"area and perimeter","g":"mixed","src":"0580/21/O/N/19 Q14","year":2019,"session":"OctNov","tex":"The scale of a map is 1 : 10\\,000\\,000.\nOn the map, the area of Slovakia is 4.9 cm$^{2}$.\n\nCalculate the actual area of Slovakia.\nGive your answer in square kilometres.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"km²"}},{"id":"0580-2019OctNov-Paper21-Q15","paper":"2019OctNov-Paper21","qnum":15,"marks":3,"topics":["Algebra and graphs"],"s":"2.8","d":2,"cat":"algebra","topic":"Proportion","qtype":"proportion","g":"proportion","src":"0580/21/O/N/19 Q15","year":2019,"session":"OctNov","tex":"y is inversely proportional to x$^{2}$.\nWhen x = 4, y = 2.\nFind y when x = $\\frac{1}{2}$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find","answer":{"type":"number","prefix":"y ="}},{"id":"0580-2019OctNov-Paper21-Q16","paper":"2019OctNov-Paper21","qnum":16,"marks":3,"topics":["Coordinate geometry","Geometry","Transformations and vectors"],"s":"3.4","d":2,"cat":"coord","topic":"Length and midpoint","qtype":"length and midpoint","g":"mixed","src":"0580/21/O/N/19 Q16","year":2019,"session":"OctNov","tex":"Calculate the obtuse angle x in this triangle.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","prefix":"x =","suffix":"\\textdegree"}},{"id":"0580-2019OctNov-Paper21-Q17","paper":"2019OctNov-Paper21","qnum":17,"marks":3,"topics":["Geometry","Mensuration"],"s":"4.7","d":2,"cat":"geometry","topic":"Circle theorems","qtype":"circle theorems","g":"mixed","src":"0580/21/O/N/19 Q17","year":2019,"session":"OctNov","tex":"The diagram shows two sectors of circles with the same centre.\n\nCalculate the shaded area.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"cm²"}},{"id":"0580-2019OctNov-Paper21-Q18","paper":"2019OctNov-Paper21","qnum":18,"marks":3,"topics":["Number"],"s":"1.4","d":2,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/21/