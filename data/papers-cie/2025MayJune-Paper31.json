[{"id":"0580-2025MayJune-Paper31-Q01","paper":"2025MayJune-Paper31","qnum":1,"marks":4,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q01","year":2025,"session":"MayJune","tex":"The pictogram shows the number of goals scored by teams A, B and C.\n\n(a) Work out the number of goals scored by team B.\n\n(b) Teams A, B, C and D scored a total of 43 goals.\nComplete the pictogram.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":3}],"hasFigure":true,"cognitive":"apply","cmd":"complete"},{"id":"0580-2025MayJune-Paper31-Q02","paper":"2025MayJune-Paper31","qnum":2,"marks":1,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/31/M/J/25 Q02","year":2025,"session":"MayJune","tex":"An angle measures 157$^\\circ$.\nWrite down the mathematical name for this type of angle.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2025MayJune-Paper31-Q03","paper":"2025MayJune-Paper31","qnum":3,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q03","year":2025,"session":"MayJune","tex":"Find the value of $\\sqrt{1.96}$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2025MayJune-Paper31-Q04","paper":"2025MayJune-Paper31","qnum":4,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q04","year":2025,"session":"MayJune","tex":"Calculate the number of months in 5 years.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025MayJune-Paper31-Q05","paper":"2025MayJune-Paper31","qnum":5,"marks":3,"topics":["Geometry","Transformations and vectors"],"s":"4.5","d":1,"cat":"geometry","topic":"Symmetry","qtype":"symmetry","g":"mixed","src":"0580/31/M/J/25 Q05","year":2025,"session":"MayJune","tex":"(a) Write down the order of rotational symmetry for this shape.\n\n(b) Draw all the lines of symmetry on this shape.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"recall","cmd":"draw"},{"id":"0580-2025MayJune-Paper31-Q06","paper":"2025MayJune-Paper31","qnum":6,"marks":2,"topics":["Geometry"],"s":"4.2","d":1,"cat":"geometry","topic":"Geometrical constructions","qtype":"geometrical constructions","g":"mixed","src":"0580/31/M/J/25 Q06","year":2025,"session":"MayJune","tex":"In triangle $ABC$, $AC = 6.4$~cm and $BC = 5.3$~cm.\n\nUsing a ruler and compasses only, construct triangle $ABC$.\nLeave in your construction arcs.\nThe line $AB$ has been drawn for you.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"draw"},{"id":"0580-2025MayJune-Paper31-Q07","paper":"2025MayJune-Paper31","qnum":7,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q07","year":2025,"session":"MayJune","tex":"Solve.\n\\[\n3y = 18\n\\]","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"solve","answer":{"type":"number","prefix":"y ="}},{"id":"0580-2025MayJune-Paper31-Q08","paper":"2025MayJune-Paper31","qnum":8,"marks":4,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q08","year":2025,"session":"MayJune","tex":"(a) $T = 3(5P - 8) + 4$\n\\\\[0.3cm]\nFind the value of $T$ when $P = 12$.\n\n(b) $W = 4t + 8$\n\\\\[0.3cm]\nFind the value of $t$ when $W = 369$.","parts":[{"label":"(a)","marks":2,"answer":{"type":"number","prefix":"T ="}},{"label":"(b)","marks":2,"answer":{"type":"number","prefix":"t ="}}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2025MayJune-Paper31-Q09","paper":"2025MayJune-Paper31","qnum":9,"marks":2,"topics":["Algebra and graphs"],"s":"2.6","d":1,"cat":"algebra","topic":"Inequalities","qtype":"inequalities","g":"inequality","src":"0580/31/M/J/25 Q09","year":2025,"session":"MayJune","tex":"Represent the inequality $-3 < x \\le 2$ on the number line.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"other"},{"id":"0580-2025MayJune-Paper31-Q10","paper":"2025MayJune-Paper31","qnum":10,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q10","year":2025,"session":"MayJune","tex":"$\\dfrac{3}{7} \\qquad 0.41 \\qquad \\dfrac{17}{41} \\qquad 42\\%$\nWrite these numbers in order, starting with the smallest.\n\n  $<$  $<$  $<$  \n\\centerline{smallest}","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2025MayJune-Paper31-Q11","paper":"2025MayJune-Paper31","qnum":11,"marks":3,"topics":["Number"],"s":"1.15","d":1,"cat":"number","topic":"Time","qtype":"time calculations","g":"mixed","src":"0580/31/M/J/25 Q11","year":2025,"session":"MayJune","tex":"A plane leaves Seattle at 07 30 on Tuesday and arrives in Seoul 10 hours and 55 minutes later. \\\\\nThe local time in Seoul is 16 hours ahead of the local time in Seattle.\n\nWork out the day and time in Seoul when the plane arrives.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","prefix":"Day","suffix":"Time"}},{"id":"0580-2025MayJune-Paper31-Q12","paper":"2025MayJune-Paper31","qnum":12,"marks":2,"topics":["Coordinate geometry","Geometry"],"s":"3.6","d":1,"cat":"coord","topic":"Parallel lines","qtype":"parallel lines","g":"mixed","src":"0580/31/M/J/25 Q12","year":2025,"session":"MayJune","tex":"The equation of line $L$ is $y = 5x - 3$.\n\n(a) Write down the gradient of line $L$.\n\n\n    \n\n(b) Write down the equation of a line parallel to line $L$.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1,"answer":{"type":"number","prefix":"y ="}}],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2025MayJune-Paper31-Q13","paper":"2025MayJune-Paper31","qnum":13,"marks":2,"topics":["Geometry"],"s":"4.3","d":1,"cat":"geometry","topic":"Scale drawings and bearings","qtype":"scale drawings and bearings","g":"mixed","src":"0580/31/M/J/25 Q13","year":2025,"session":"MayJune","tex":"The scale drawing shows the position of ship $A$. \\\\\nThe scale is 1 centimetre represents 50 kilometres.\n\nShip $B$ is 300 km from ship $A$ on a bearing of 105$^\\circ$.\n\nOn the scale drawing mark the position of ship $B$.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"other"},{"id":"0580-2025MayJune-Paper31-Q14","paper":"2025MayJune-Paper31","qnum":14,"marks":3,"topics":["Number"],"s":"1.11","d":1,"cat":"number","topic":"Ratio and proportion","qtype":"ratio and proportion","g":"proportion","src":"0580/31/M/J/25 Q14","year":2025,"session":"MayJune","tex":"Tom needs 225 g of flour to make 10 cakes. \\\\\nA shop sells flour in 500 g bags.\n\nWork out the number of bags of flour Tom needs to make 70 cakes.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025MayJune-Paper31-Q15","paper":"2025MayJune-Paper31","qnum":15,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/31/M/J/25 Q15","year":2025,"session":"MayJune","tex":"\\begin{tabular}{ccc}\n        A & B & C \\\\\n         &\n         &\n         \\\\\n        D & E & F \\\\\n         &\n         &\n\n    \\end{tabular}\nWrite down the letter of the graph that shows these lines.\n\n(a) $x = 3$\n\n\n    \n\n(b) $y = 3x$","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"write","texHtml":"<div class=\"pp-table-wrap\"><table class=\"pp-table pp-table-nb\"><tr><td style=\"text-align:center\">A</td><td style=\"text-align:center\">B</td><td style=\"text-align:center\">C</td></tr><tr><td style=\"text-align:center\"></td><td style=\"text-align:center\"></td><td style=\"text-align:center\"></td></tr><tr><td style=\"text-align:center\">D</td><td style=\"text-align:center\">E</td><td style=\"text-align:center\">F</td></tr><tr><td style=\"text-align:center\"></td><td style=\"text-align:center\"></td><td style=\"text-align:center\"></td></tr></table></div>\nWrite down the letter of the graph that shows these lines.\n\n(a) $x = 3$\n\n\n    \n\n(b) $y = 3x$"},{"id":"0580-2025MayJune-Paper31-Q16","paper":"2025MayJune-Paper31","qnum":16,"marks":3,"topics":["Geometry","Mensuration"],"s":"4.4","d":1,"cat":"geometry","topic":"Similarity and congruence","qtype":"similarity and congruence","g":"mixed","src":"0580/31/M/J/25 Q16","year":2025,"session":"MayJune","tex":"The diagram shows a shape made from a square and four congruent isosceles triangles.\n\nWork out the area of this shape.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"cm²"}},{"id":"0580-2025MayJune-Paper31-Q17","paper":"2025MayJune-Paper31","qnum":17,"marks":3,"topics":["Mensuration"],"s":"5.4","d":1,"cat":"mensuration","topic":"Surface area and volume","qtype":"surface area and volume","g":"mixed","src":"0580/31/M/J/25 Q17","year":2025,"session":"MayJune","tex":"The volume of a cylinder is 863.5 cm$^3$. \\\\\nThe height of the cylinder is 12.3 cm.\n\nFind the radius of the cylinder.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find","answer":{"type":"number","suffix":"cm"}},{"id":"0580-2025MayJune-Paper31-Q18","paper":"2025MayJune-Paper31","qnum":18,"marks":1,"topics":["Number"],"s":"1.16","d":1,"cat":"number","topic":"Money","qtype":"money and currency","g":"mixed","src":"0580/31/M/J/25 Q18","year":2025,"session":"MayJune","tex":"Dara changes 5700 Thai baht to dollars. \\\\\nThe exchange rate is \\$1 = 34.18 Thai baht.\n\nCalculate the amount that Dara receives.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025MayJune-Paper31-Q19","paper":"2025MayJune-Paper31","qnum":19,"marks":2,"topics":["Statistics"],"s":"9.3","d":1,"cat":"statistics","topic":"Averages and measures of spread","qtype":"averages and spread","g":"mixed","src":"0580/31/M/J/25 Q19","year":2025,"session":"MayJune","tex":"A four-sided dice is numbered 1 to 4. \\\\\nHrishi throws the dice 50 times. \\\\\nThe results are shown in the table.\n\n\\begin{tabular}{|c|c|}\n\\hline\nNumber & Frequency \\\\\n\\hline\n1 & 14 \\\\\n\\hline\n2 & 15 \\\\\n\\hline\n3 & 9 \\\\\n\\hline\n4 & 12 \\\\\n\\hline\n\\end{tabular}\nCalculate the mean.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","texHtml":"A four-sided dice is numbered 1 to 4. \\\\\nHrishi throws the dice 50 times. \\\\\nThe results are shown in the table.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><th style=\"text-align:center\">Number</th><th style=\"text-align:center\">Frequency</th></tr><tr><td style=\"text-align:center\">1</td><td style=\"text-align:center\">14</td></tr><tr><td style=\"text-align:center\">2</td><td style=\"text-align:center\">15</td></tr><tr><td style=\"text-align:center\">3</td><td style=\"text-align:center\">9</td></tr><tr><td style=\"text-align:center\">4</td><td style=\"text-align:center\">12</td></tr></table></div>\nCalculate the mean.","answer":{"type":"table_input"}},{"id":"0580-2025MayJune-Paper31-Q20","paper":"2025MayJune-Paper31","qnum":20,"marks":2,"topics":["Probability"],"s":"8.1","d":1,"cat":"probability","topic":"Introduction to probability","qtype":"basic probability","g":"mixed","src":"0580/31/M/J/25 Q20","year":2025,"session":"MayJune","tex":"A tin contains red, yellow, green and brown sweets. \\\\\nThe table shows some of the probabilities of picking a sweet of each colour at random.\n\n\\begin{tabular}{|l|c|c|c|c|}\n\\hline\nColour & Red & Yellow & Green & Brown \\\\\n\\hline\nProbability & 0.68 & & 0.05 & 0.14 \\\\\n\\hline\n\\end{tabular}\nComplete the table.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"complete","texHtml":"A tin contains red, yellow, green and brown sweets. \\\\\nThe table shows some of the probabilities of picking a sweet of each colour at random.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><th>Colour</th><th style=\"text-align:center\">Red</th><th style=\"text-align:center\">Yellow</th><th style=\"text-align:center\">Green</th><th style=\"text-align:center\">Brown</th></tr><tr><td>Probability</td><td style=\"text-align:center\">0.68</td><td style=\"text-align:center\"></td><td style=\"text-align:center\">0.05</td><td style=\"text-align:center\">0.14</td></tr></table></div>\nComplete the table."},{"id":"0580-2025MayJune-Paper31-Q21","paper":"2025MayJune-Paper31","qnum":21,"marks":3,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/31/M/J/25 Q21","year":2025,"session":"MayJune","tex":"The diagram shows a right-angled triangle $ABC$.\n\nCalculate $BC$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","prefix":"BC =","suffix":"cm"}},{"id":"0580-2025MayJune-Paper31-Q22","paper":"2025MayJune-Paper31","qnum":22,"marks":6,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/31/M/J/25 Q22","year":2025,"session":"MayJune","tex":"(a) Anil invests \\$2000 and Baz invests \\$7500. \\\\\n    Write the ratio money invested by Anil : money invested by Baz in its simplest form.\n\n\n    \n\n(b) Kamil and Lavik share some money in the ratio Kamil : Lavik = 5 : 9. \\\\\n    Lavik receives \\$72 more than Kamil. \\\\\n    Calculate the total amount of money they share.\n\n\n    \n\n(c) Vanisha invests \\$4000 for 5 years at a rate of 3.5\\% per year compound interest. \\\\\n    Calculate the total interest earned during the 5 years.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2},{"label":"(c)","marks":3}],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2025MayJune-Paper31-Q23","paper":"2025MayJune-Paper31","qnum":23,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/31/M/J/25 Q23","year":2025,"session":"MayJune","tex":"The population of an island increases from 18 400 to 19 780. \\\\\nCalculate the percentage increase.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"%"}},{"id":"0580-2025MayJune-Paper31-Q24","paper":"2025MayJune-Paper31","qnum":24,"marks":2,"topics":["Geometry"],"s":"4.4","d":1,"cat":"geometry","topic":"Similarity and congruence","qtype":"similarity and congruence","g":"mixed","src":"0580/31/M/J/25 Q24","year":2025,"session":"MayJune","tex":"Triangle $ABC$ is mathematically similar to triangle $UVW$. \\\\\nCalculate $AB$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","prefix":"AB =","suffix":"cm"}},{"id":"0580-2025MayJune-Paper31-Q25","paper":"2025MayJune-Paper31","qnum":25,"marks":3,"topics":["Mensuration"],"s":"5.4","d":1,"cat":"mensuration","topic":"Surface area and volume","qtype":"surface area and volume","g":"mixed","src":"0580/31/M/J/25 Q25","year":2025,"session":"MayJune","tex":"A bar of gold in the shape of a cuboid has dimensions 2 cm by 4 cm by 6.5 cm. \\\\\nThe density of gold is 19.32 g/cm$^3$.\n\nCalculate the mass of this bar of gold. \\\\\n$[\\text{Density} = \\frac{\\text{mass}}{\\text{volume}}]$","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"g"}},{"id":"0580-2025MayJune-Paper31-Q26","paper":"2025MayJune-Paper31","qnum":26,"marks":4,"topics":["Number","Geometry"],"s":"1.2","d":1,"cat":"number","topic":"Sets","qtype":"sets and Venn diagrams","g":"mixed","src":"0580/31/M/J/25 Q26","year":2025,"session":"MayJune","tex":"Li asks 28 students if they speak English ($E$) and if they speak Spanish ($S$). \\\\\n15 students speak English. \\\\\n12 students speak Spanish. \\\\\n6 do not speak English and do not speak Spanish.\n\n(a) Complete the Venn diagram.\n\n\n    \n\n(b) Write down how many students speak English but do not speak Spanish.\n\n\n    \n\n(c) Find $n(E \\cap S)$.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":1},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"complete"},{"id":"0580-2025MayJune-Paper31-Q27","paper":"2025MayJune-Paper31","qnum":27,"marks":2,"topics":["Number"],"s":"1.9","d":1,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/31/M/J/25 Q27","year":2025,"session":"MayJune","tex":"The height, $h$ metres, of a building is 105 m, correct to the nearest metre. \\\\\nComplete this statement about the value of $h$.\n\n\\centerline{ $\\le h <$ }","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"complete"},{"id":"0580-2025MayJune-Paper31-Q28","paper":"2025MayJune-Paper31","qnum":28,"marks":9,"topics":["Algebra and graphs","Geometry"],"s":"2.8","d":1,"cat":"algebra","topic":"Proportion","qtype":"proportion","g":"proportion","src":"0580/31/M/J/25 Q28","year":2025,"session":"MayJune","tex":"(a) (i) (b) Complete the table of values for $y = x^2 - x - 5$.\n        \\begin{tabular}{|l||c|c|c|c|c|c|c|c|}\n            \\hline\n            $x$ & $-3$ & $-2$ & $-1$ & $0$ & $1$ & $2$ & $3$ & $4$ \\\\\n            \\hline\n            $y$ & & $1$ & $-3$ & & & $-3$ & $1$ & \\\\\n            \\hline\n            \\end{tabular}\n\n\n(c) On the grid, draw the graph of $y = x^2 - x - 5$ for $-3 \\le x \\le 4$.\n\n        \n\n(d) Write down the equation of the line of symmetry of the graph.\n\n\n    \n\n(e) Use the graph to solve the equation $x^2 - x - 5 = 0$.","parts":[{"label":"(a)","marks":0},{"label":"(b)","marks":2},{"label":"(c)","marks":4},{"label":"(d)","marks":1},{"label":"(e)","marks":2,"answer":{"type":"number","prefix":"x =","suffix":"or $x = $"}}],"hasFigure":true,"cognitive":"apply","cmd":"draw","texHtml":"(a) (i) (b) Complete the table of values for $y = x^2 - x - 5$.\n        <div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><th>$x$</th><th style=\"text-align:center\">$-3$</th><th style=\"text-align:center\">$-2$</th><th style=\"text-align:center\">$-1$</th><th style=\"text-align:center\">$0$</th><th style=\"text-align:center\">$1$</th><th style=\"text-align:center\">$2$</th><th style=\"text-align:center\">$3$</th><th style=\"text-align:center\">$4$</th></tr><tr><td>$y$</td><td style=\"text-align:center\"></td><td style=\"text-align:center\">$1$</td><td style=\"text-align:center\">$-3$</td><td style=\"text-align:center\"></td><td style=\"text-align:center\"></td><td style=\"text-align:center\">$-3$</td><td style=\"text-align:center\">$1$</td><td style=\"text-align:center\"></td></tr></table></div>\n\n\n(c) On the grid, draw the graph of $y = x^2 - x - 5$ for $-3 \\le x \\le 4$.\n\n        \n\n(d) Write down the equation of the line of symmetry of the graph.\n\n\n    \n\n(e) Use the graph to solve the equation $x^2 - x - 5 = 0$."},{"id":"0580-2025MayJune-Paper31-Q29","paper":"2025MayJune-Paper31","qnum":29,"marks":3,"topics":["Geometry","Mensuration"],"s":"4.7","d":1,"cat":"geometry","topic":"Circle theorems","qtype":"circle theorems","g":"mixed","src":"0580/31/M/J/25 Q29","year":2025,"session":"MayJune","tex":"This shape is made from a rectangle and a semicircle. \\\\\nThe diameter of the semicircle is 10 cm.\n\nCalculate the perimeter of this shape.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"cm"}},{"id":"0580-2025MayJune-Paper31-Q30","paper":"2025MayJune-Paper31","qnum":30,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/31/M/J/25 Q30","year":2025,"session":"MayJune","tex":"The diagram shows a right-angled triangle, $PQR$.\n\nCalculate angle $QRP$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","prefix":"Angle $QRP =$","suffix":"°"}}]