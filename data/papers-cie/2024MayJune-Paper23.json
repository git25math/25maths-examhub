[{"id":"0580-2024MayJune-Paper23-Q01","paper":"2024MayJune-Paper23","qnum":1,"marks":1,"topics":["Statistics"],"s":"9.3","d":2,"cat":"statistics","topic":"Averages and measures of spread","qtype":"averages and spread","g":"mixed","src":"0580/23/M/J/24 Q01","year":2024,"session":"MayJune","tex":"Write the number two million two thousand and two in figures.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024MayJune-Paper23-Q02","paper":"2024MayJune-Paper23","qnum":2,"marks":1,"topics":["Number"],"s":"1.6","d":2,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/23/M/J/24 Q02","year":2024,"session":"MayJune","tex":"Put one pair of brackets into this calculation to make it correct.\n\n$$5 - 4 \\times 3 - 9 - 2 = 0$$","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"other"},{"id":"0580-2024MayJune-Paper23-Q03","paper":"2024MayJune-Paper23","qnum":3,"marks":2,"topics":["Algebra and graphs","Statistics"],"s":"2.2","d":2,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/23/M/J/24 Q03","year":2024,"session":"MayJune","tex":"Simplify.\n\n7x - 8y - x - y","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024MayJune-Paper23-Q04","paper":"2024MayJune-Paper23","qnum":4,"marks":2,"topics":["Mensuration","Statistics"],"s":"5.4","d":2,"cat":"mensuration","topic":"Surface area and volume","qtype":"surface area and volume","g":"mixed","src":"0580/23/M/J/24 Q04","year":2024,"session":"MayJune","tex":"The base of a cuboid measures 10 cm by 7 cm.\nThe volume of the cuboid is 280 cm$^3$.\n\nCalculate the height of the cuboid.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q05","paper":"2024MayJune-Paper23","qnum":5,"marks":1,"topics":["Probability","Statistics"],"s":"8.1","d":2,"cat":"probability","topic":"Introduction to probability","qtype":"basic probability","g":"mixed","src":"0580/23/M/J/24 Q05","year":2024,"session":"MayJune","tex":"In a city, the probability that it will rain today is 0.15.\n\nFind the probability that it will not rain today in this city.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024MayJune-Paper23-Q06","paper":"2024MayJune-Paper23","qnum":6,"marks":2,"topics":["Number","Algebra and graphs","Statistics"],"s":"2.2","d":2,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/23/M/J/24 Q06","year":2024,"session":"MayJune","tex":"Factorise completely.\n\n4x$^2$y - 5xy$^2$","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024MayJune-Paper23-Q07","paper":"2024MayJune-Paper23","qnum":7,"marks":2,"topics":["Statistics"],"s":"9.3","d":2,"cat":"statistics","topic":"Averages and measures of spread","qtype":"averages and spread","g":"mixed","src":"0580/23/M/J/24 Q07","year":2024,"session":"MayJune","tex":"The scale of a map is 1 : 40 000.\nOn the map the distance between two villages is 37 cm.\nCalculate the actual distance between the two villages.\nGive your answer in kilometres.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q08","paper":"2024MayJune-Paper23","qnum":8,"marks":2,"topics":["Number","Statistics"],"s":"1.4","d":2,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/23/M/J/24 Q08","year":2024,"session":"MayJune","tex":"Without using a calculator, work out\n\n\\[\\frac{3}{7} - \\frac{1}{14}\\]\n\nYou must show all your working and give your answer as a fraction in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q09","paper":"2024MayJune-Paper23","qnum":9,"marks":2,"topics":["Geometry","Statistics"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/23/M/J/24 Q09","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nThe diagram shows a right-angled triangle.\nCalculate AB.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q10","paper":"2024MayJune-Paper23","qnum":10,"marks":2,"topics":["Coordinate geometry","Statistics"],"s":"3.3","d":2,"cat":"coord","topic":"Gradient of linear graphs","qtype":"gradient calculation","g":"graph","src":"0580/23/M/J/24 Q10","year":2024,"session":"MayJune","tex":"Find the gradient of the line joining the points (-2, 7) and (3, 1).","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024MayJune-Paper23-Q11","paper":"2024MayJune-Paper23","qnum":11,"marks":2,"topics":["Algebra and graphs","Statistics"],"s":"2.5","d":2,"cat":"algebra","topic":"Equations","qtype":"equations","g":"mixed","src":"0580/23/M/J/24 Q11","year":2024,"session":"MayJune","tex":"Solve the simultaneous equations.\n\n\\[\n\\begin{cases}\n5t - 2w = 19 \\\\\n3t + 2w = 5\n\\end{cases}\n\\]\n\nw =","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"solve"},{"id":"0580-2024MayJune-Paper23-Q12","paper":"2024MayJune-Paper23","qnum":12,"marks":4,"topics":["Algebra and graphs"],"s":"2.2","d":2,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/23/M/J/24 Q12","year":2024,"session":"MayJune","tex":"(a) Simplify.\n\n$\\dfrac{32g^{16}}{16g^{8}}$\n\n(b) Simplify.\n\n$\\sqrt[3]{625k^{8}}$","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024MayJune-Paper23-Q13","paper":"2024MayJune-Paper23","qnum":13,"marks":2,"topics":["Number","Geometry"],"s":"1.2","d":2,"cat":"number","topic":"Sets","qtype":"sets and Venn diagrams","g":"mixed","src":"0580/23/M/J/24 Q13","year":2024,"session":"MayJune","tex":"(a) \n\\[\n\n\\]\n\nShade the region $A \\cap B'$.\n\n(b) \n\\[\n\n\\]\n\nUse set notation to describe the shaded region.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"describe"},{"id":"0580-2024MayJune-Paper23-Q14","paper":"2024MayJune-Paper23","qnum":14,"marks":3,"topics":["Geometry","Trigonometry"],"s":"4.7","d":2,"cat":"geometry","topic":"Circle theorems","qtype":"circle theorems","g":"mixed","src":"0580/23/M/J/24 Q14","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nP, Q, R and T are points on the circle.\nAB is a tangent to the circle at T.\nAngle ATP = 50°, angle PTR = 48° and PQ = QR.\n\n(a) Find angle PRT.\n\n(b) Find angle QPR.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024MayJune-Paper23-Q15","paper":"2024MayJune-Paper23","qnum":15,"marks":4,"topics":["Number","Statistics"],"s":"1.9","d":2,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/23/M/J/24 Q15","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nThe time taken for each of 200 students to complete a calculation is measured.\nThe cumulative frequency diagram shows the results.\nUse the diagram to find an estimate for\n\n(a) the interquartile range\n\n(b) the number of students taking more than 40 seconds to complete the calculation.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"apply","cmd":"complete"},{"id":"0580-2024MayJune-Paper23-Q16","paper":"2024MayJune-Paper23","qnum":16,"marks":2,"topics":["Algebra and graphs","Statistics"],"s":"2.5","d":2,"cat":"algebra","topic":"Equations","qtype":"equations","g":"mixed","src":"0580/23/M/J/24 Q16","year":2024,"session":"MayJune","tex":"Rearrange the formula to make h the subject.\n\n\\[ A = \\pi r^2 + rdh \\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"rearrange"},{"id":"0580-2024MayJune-Paper23-Q17","paper":"2024MayJune-Paper23","qnum":17,"marks":4,"topics":["Number"],"s":"1.8","d":2,"cat":"number","topic":"Standard form","qtype":"standard form","g":"mixed","src":"0580/23/M/J/24 Q17","year":2024,"session":"MayJune","tex":"(a) Work out, giving your answer in standard form.\n\n$\\sqrt{2.1 \\times 10^{101}} \\times \\sqrt{8 \\times 10^{101}}$\n\n(b) Work out, giving your answer in standard form.\n\n$\\sqrt{2.1 \\times 10^{101}} + \\sqrt{2.1 \\times 10^{100}}$","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q18","paper":"2024MayJune-Paper23","qnum":18,"marks":3,"topics":["Geometry","Statistics"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/23/M/J/24 Q18","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nThe diagram shows two sides, VA and VB, of a regular polygon.\nAVX is a straight line.\nAngle BVX = y° and angle AVB = 11.5y°.\nFind the number of sides of this polygon.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024MayJune-Paper23-Q19","paper":"2024MayJune-Paper23","qnum":19,"marks":5,"topics":["Number","Geometry","Transformations and vectors"],"s":"1.1","d":2,"cat":"number","topic":"Types of number","qtype":"types of number","g":"mixed","src":"0580/23/M/J/24 Q19","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\n(a) Describe fully the single transformation that maps triangle T onto triangle W.\n\n(b) Draw the enlargement of triangle T with scale factor -2 and centre of enlargement (-1, 1).","parts":[{"label":"(a)","marks":3},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"recall","cmd":"describe"},{"id":"0580-2024MayJune-Paper23-Q20","paper":"2024MayJune-Paper23","qnum":20,"marks":4,"topics":["Algebra and graphs"],"s":"2.13","d":2,"cat":"algebra","topic":"Functions","qtype":"functions","g":"function","src":"0580/23/M/J/24 Q20","year":2024,"session":"MayJune","tex":"$f(x) = 3^x + 2$\n\n(a) Find x when $f(x) = 245$.\n\n(b) Find x when $f^{-1}(x) = 7$.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024MayJune-Paper23-Q21","paper":"2024MayJune-Paper23","qnum":21,"marks":2,"topics":["Number","Statistics"],"s":"1.4","d":2,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/23/M/J/24 Q21","year":2024,"session":"MayJune","tex":"Write the recurring decimal $0.\\dot{4}\\dot{1}$ as a fraction in its simplest form.\nYou must show all your working.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024MayJune-Paper23-Q22","paper":"2024MayJune-Paper23","qnum":22,"marks":3,"topics":["Trigonometry","Statistics"],"s":"6.4","d":2,"cat":"trigonometry","topic":"Trigonometric functions","qtype":"trigonometric functions/graphs","g":"function","src":"0580/23/M/J/24 Q22","year":2024,"session":"MayJune","tex":"Solve the equation $\\tan x + 3 = 0$ for $0° \\leq x \\leq 360°$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"solve"},{"id":"0580-2024MayJune-Paper23-Q23","paper":"2024MayJune-Paper23","qnum":23,"marks":3,"topics":["Number","Algebra and graphs","Statistics"],"s":"2.3","d":2,"cat":"algebra","topic":"Algebraic fractions","qtype":"algebraic fractions","g":"algebraic-fraction","src":"0580/23/M/J/24 Q23","year":2024,"session":"MayJune","tex":"Simplify.\n\n\\[ \\frac{2}{y+1} - \\frac{3}{y} \\]\n\nGive your answer as a single fraction in its simplest form.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024MayJune-Paper23-Q24","paper":"2024MayJune-Paper23","qnum":24,"marks":4,"topics":["Geometry","Mensuration","Statistics"],"s":"4.6","d":2,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/23/M/J/24 Q24","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nThe diagram shows a triangular prism with cross-section triangle BCV.\nAngle BCV = 90°, BC = 5 cm, CV = 4 cm and AB = 15 cm.\nCalculate the angle between AV and the base ABCD.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024MayJune-Paper23-Q25","paper":"2024MayJune-Paper23","qnum":25,"marks":4,"topics":["Algebra and graphs","Statistics"],"s":"2.3","d":2,"cat":"algebra","topic":"Algebraic fractions","qtype":"algebraic fractions","g":"algebraic-fraction","src":"0580/23/M/J/24 Q25","year":2024,"session":"MayJune","tex":"Simplify.\n\n\\[ \\frac{pt - p - t + 1}{1 - t^2} \\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024MayJune-Paper23-Q26","paper":"2024MayJune-Paper23","qnum":26,"marks":4,"topics":["Transformations and vectors","Statistics"],"s":"7.3","d":2,"cat":"vectors","topic":"Magnitude of a vector","qtype":"magnitude and unit vectors","g":"mixed","src":"0580/23/M/J/24 Q26","year":2024,"session":"MayJune","tex":"\\[\n\n\\]\n\nIn the diagram, O is the origin.\n$\\overrightarrow{OP} = \\mathbf{p}$ and $\\overrightarrow{OQ} = \\mathbf{q}$.\nR is the point of intersection of PQ and OS, with PR : RQ = 1 : 2 and OR = RS.\nFind the position vector of S in terms of p and q.\nGive your answer in its simplest form.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"}]