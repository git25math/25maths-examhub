},{"id":"0580-2024March-Paper12-Q25","paper":"2024March-Paper12","qnum":25,"marks":2,"topics":["Number"],"s":"1.1","d":1,"cat":"number","topic":"Types of number","qtype":"types of number","g":"mixed","src":"0580/12/M/24 Q25","year":2024,"session":"March","tex":"The highest common factor (HCF) of two numbers is 6.\nThe lowest common multiple (LCM) of the two numbers is 90.\nBoth numbers are greater than 6.\n\nWork out the two numbers.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","answer":{"type":"number","suffix":"and"}}]