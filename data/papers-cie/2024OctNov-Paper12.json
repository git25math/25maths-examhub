[{"id":"0580-2024OctNov-Paper12-Q01","paper":"2024OctNov-Paper12","qnum":1,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/24 Q01","year":2024,"session":"OctNov","tex":"Write the number half a million in figures.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024OctNov-Paper12-Q02","paper":"2024OctNov-Paper12","qnum":2,"marks":3,"topics":["Statistics"],"s":"9.4","d":1,"cat":"statistics","topic":"Statistical charts and diagrams","qtype":"statistical charts","g":"mixed","src":"0580/12/O/N/24 Q02","year":2024,"session":"OctNov","tex":"Anton records the colour of each car in a car park.\\\\\nHis results are shown in the table.\n\n\\begin{tabular}{l | c | c | c | c}\nColour & Black & Grey & White & Blue \\\\ \\hline\nFrequency & 12 & 9 & 11 & 4\n\\end{tabular}\nOn the grid, draw a bar chart to show this information.\\\\\nComplete the scale on the frequency axis.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"draw","texHtml":"Anton records the colour of each car in a car park.\\\\\nHis results are shown in the table.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><td>Colour</td><td style=\"text-align:center\">Black</td><td style=\"text-align:center\">Grey</td><td style=\"text-align:center\">White</td><td style=\"text-align:center\">Blue</td></tr><tr><td>Frequency</td><td style=\"text-align:center\">12</td><td style=\"text-align:center\">9</td><td style=\"text-align:center\">11</td><td style=\"text-align:center\">4</td></tr></table></div>\nOn the grid, draw a bar chart to show this information.\\\\\nComplete the scale on the frequency axis."},{"id":"0580-2024OctNov-Paper12-Q03","paper":"2024OctNov-Paper12","qnum":3,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/24 Q03","year":2024,"session":"OctNov","tex":"Solve.\n\n(a) $5x = 14$\n\n(b) $x + 6 = 25$","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"apply","cmd":"solve"},{"id":"0580-2024OctNov-Paper12-Q04","paper":"2024OctNov-Paper12","qnum":4,"marks":4,"topics":["Geometry","Transformations and vectors"],"s":"4.5","d":1,"cat":"geometry","topic":"Symmetry","qtype":"symmetry","g":"mixed","src":"0580/12/O/N/24 Q04","year":2024,"session":"OctNov","tex":"The diagram shows a regular polygon.\n\n(a) Write down the mathematical name for this polygon.\n\n(b) On the diagram, draw all the lines of symmetry.\n\n(c) Write down the order of rotational symmetry.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"draw"},{"id":"0580-2024OctNov-Paper12-Q05","paper":"2024OctNov-Paper12","qnum":5,"marks":2,"topics":["Number"],"s":"1.9","d":1,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/12/O/N/24 Q05","year":2024,"session":"OctNov","tex":"Write 53~683.588 correct to\n\n(a) the nearest hundred\n\n(b) 1 decimal place.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024OctNov-Paper12-Q06","paper":"2024OctNov-Paper12","qnum":6,"marks":2,"topics":["Geometry"],"s":"4.2","d":1,"cat":"geometry","topic":"Geometrical constructions","qtype":"geometrical constructions","g":"mixed","src":"0580/12/O/N/24 Q06","year":2024,"session":"OctNov","tex":"Triangle $ABC$ has sides $AC = 4.2$~cm and $BC = 5.6$~cm.\n\nUsing a ruler and compasses only, construct triangle $ABC$.\\\\\nLeave in your construction arcs.\\\\\nThe side $AB$ has been drawn for you.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"draw"},{"id":"0580-2024OctNov-Paper12-Q07","paper":"2024OctNov-Paper12","qnum":7,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/24 Q07","year":2024,"session":"OctNov","tex":"Put one pair of brackets in each calculation to make it correct.\n\n(a) $15 + 12 - 3 \\times 4 = 51$\n\n(b) $15 + 12 - 3 \\times 4 = 96$","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"recall","cmd":"other"},{"id":"0580-2024OctNov-Paper12-Q08","paper":"2024OctNov-Paper12","qnum":8,"marks":2,"topics":["Algebra and graphs"],"s":"2.2","d":1,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/12/O/N/24 Q08","year":2024,"session":"OctNov","tex":"Simplify.\n\n\\[8c - d - 3c + 3d\\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024OctNov-Paper12-Q09","paper":"2024OctNov-Paper12","qnum":9,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/24 Q09","year":2024,"session":"OctNov","tex":"The diagram shows an isosceles triangle.\n\n\\NotToScale\n\nFind the value of $x$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper12-Q10","paper":"2024OctNov-Paper12","qnum":10,"marks":3,"topics":["Number"],"s":"1.11","d":1,"cat":"number","topic":"Ratio and proportion","qtype":"ratio and proportion","g":"proportion","src":"0580/12/O/N/24 Q10","year":2024,"session":"OctNov","tex":"\\[ 0.25 \\quad 3.142 \\quad 3 \\quad -3 \\quad 24 \\quad -0.4 \\quad 1.2 \\quad -\\dfrac{1}{4} \\]\n\nComplete each statement with a number from the list.\n\n(a)  is a natural number.\n\n(b)  is an irrational number.\n\n(c)  is the reciprocal of 4.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"complete"},{"id":"0580-2024OctNov-Paper12-Q11","paper":"2024OctNov-Paper12","qnum":11,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/24 Q11","year":2024,"session":"OctNov","tex":"The temperature in town A is $-8^\\circ\\text{C}$ and the temperature in town B is $16^\\circ\\text{C}$.\n\n(a) Find the difference in these two temperatures.\n\n(b) The temperature in town A rises by $12^\\circ\\text{C}$.\\\\\nFind the temperature in town A now.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper12-Q12","paper":"2024OctNov-Paper12","qnum":12,"marks":3,"topics":["Geometry"],"s":"4.3","d":1,"cat":"geometry","topic":"Scale drawings and bearings","qtype":"scale drawings and bearings","g":"mixed","src":"0580/12/O/N/24 Q12","year":2024,"session":"OctNov","tex":"The scale drawing shows the positions of two ships, $A$ and $B$.\\\\\nThe scale is 1~cm represents 6~km.\n\n(a) Measure the bearing of ship $B$ from ship $A$.\n\n(b) Find the actual distance between the two ships.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper12-Q13","paper":"2024OctNov-Paper12","qnum":13,"marks":5,"topics":["Number","Statistics"],"s":"1.9","d":1,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/12/O/N/24 Q13","year":2024,"session":"OctNov","tex":"The scatter diagram shows the number of rooms and the number of people in each of eight buildings.\n\n(a) One of the buildings has 67 rooms.\\\\\nWrite down the number of people in this building.\n\n(b) In another building there are 42 people and 33 rooms.\\\\\nOn the scatter diagram, plot this point.\n\n(c) (i) (d) On the scatter diagram, draw a line of best fit.\n\n\n(e) There are 45 people in a different building.\\\\\n    Find an estimate for the number of rooms in this building.\n\n    \n\n(f) What type of correlation is shown in the scatter diagram?","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1},{"label":"(c)","marks":0},{"label":"(d)","marks":1},{"label":"(e)","marks":1},{"label":"(f)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"draw"},{"id":"0580-2024OctNov-Paper12-Q14","paper":"2024OctNov-Paper12","qnum":14,"marks":2,"topics":["Geometry","Mensuration"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/24 Q14","year":2024,"session":"OctNov","tex":"\\NotToScale\n\nThe area of the trapezium is $42~\\text{cm}^2$.\\\\\nCalculate the value of $x$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper12-Q15","paper":"2024OctNov-Paper12","qnum":15,"marks":2,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/12/O/N/24 Q15","year":2024,"session":"OctNov","tex":"In a league, teams gain 4 points for each win, 2 points for each draw and bonus points.\\\\\nA team has $x$ wins, $y$ draws and $b$ bonus points.\n\nWrite down an expression, in terms of $x$, $y$ and $b$, for the total number of points the team has.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"draw"},{"id":"0580-2024OctNov-Paper12-Q16","paper":"2024OctNov-Paper12","qnum":16,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/12/O/N/24 Q16","year":2024,"session":"OctNov","tex":"Dana invests \\$3600 at a rate of 3.8\\% per year compound interest.\n\nCalculate the value of her investment at the end of 5 years.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper12-Q17","paper":"2024OctNov-Paper12","qnum":17,"marks":4,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/24 Q17","year":2024,"session":"OctNov","tex":"The diagram shows a parallelogram.\n\n\\NotToScale\n\nWork out the size of the smallest interior angle of the parallelogram.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper12-Q18","paper":"2024OctNov-Paper12","qnum":18,"marks":2,"topics":["Algebra and graphs"],"s":"2.3","d":1,"cat":"algebra","topic":"Algebraic fractions","qtype":"algebraic fractions","g":"algebraic-fraction","src":"0580/12/O/N/24 Q18","year":2024,"session":"OctNov","tex":"Simplify.\n\n\\[\\frac{18x^6}{3x^2}\\]","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024OctNov-Paper12-Q19","paper":"2024OctNov-Paper12","qnum":19,"marks":1,"topics":["Transformations and vectors"],"s":"7.1","d":1,"cat":"vectors","topic":"Transformations","qtype":"transformations","g":"mixed","src":"0580/12/O/N/24 Q19","year":2024,"session":"OctNov","tex":"$ \\vec{AB} = \\begin{pmatrix} 3 \\\\ -2 \\end{pmatrix} $\n\nMark point $A$ on the grid.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"other"},{"id":"0580-2024OctNov-Paper12-Q20","paper":"2024OctNov-Paper12","qnum":20,"marks":3,"topics":["Geometry","Mensuration"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/12/O/N/24 Q20","year":2024,"session":"OctNov","tex":"Points $A$ and $B$ lie on a circle, centre $O$ and radius $r$.\n\nThe area of the circle is 120~cm$^2$.\\\\\nFind the area of the right-angled triangle $AOB$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper12-Q21","paper":"2024OctNov-Paper12","qnum":21,"marks":3,"topics":["Number"],"s":"1.4","d":1,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/12/O/N/24 Q21","year":2024,"session":"OctNov","tex":"Without using a calculator, work out $2\\dfrac{3}{4} \\times 1\\dfrac{1}{2}$.\\\\\nYou must show all your working and give your answer as a mixed number in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper12-Q22","paper":"2024OctNov-Paper12","qnum":22,"marks":4,"topics":["Algebra and graphs"],"s":"2.5","d":1,"cat":"algebra","topic":"Equations","qtype":"equations","g":"mixed","src":"0580/12/O/N/24 Q22","year":2024,"session":"OctNov","tex":"Solve the simultaneous equations.\\\\\nYou must show all your working.\n\\[ 2x + 7y = 34 \\]\n\\[ 3x + 5y = 18 \\]","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"solve"}]