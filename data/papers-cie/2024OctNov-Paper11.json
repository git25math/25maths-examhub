[{"id":"0580-2024OctNov-Paper11-Q01","paper":"2024OctNov-Paper11","qnum":1,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/11/O/N/24 Q01","year":2024,"session":"OctNov","tex":"Jacob is 10 years 8 months old.\\\\\nAmy is 15 months younger than Jacob.\\\\\nFind how old Amy is.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q02","paper":"2024OctNov-Paper11","qnum":2,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/11/O/N/24 Q02","year":2024,"session":"OctNov","tex":"Change 6.7 kilometres to metres.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"other"},{"id":"0580-2024OctNov-Paper11-Q03","paper":"2024OctNov-Paper11","qnum":3,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/11/O/N/24 Q03","year":2024,"session":"OctNov","tex":"(a) Measure angle $x$.\n\n(b) Write down the mathematical name for this type of angle.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":true,"cognitive":"recall","cmd":"write"},{"id":"0580-2024OctNov-Paper11-Q04","paper":"2024OctNov-Paper11","qnum":4,"marks":1,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/11/O/N/24 Q04","year":2024,"session":"OctNov","tex":"A concert starts at 19 50 and finishes 2 hours 42 minutes later.\\\\\nWork out the time the concert finishes.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper11-Q05","paper":"2024OctNov-Paper11","qnum":5,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/11/O/N/24 Q05","year":2024,"session":"OctNov","tex":"Use one of these symbols $<$, $>$ or $=$ to make each statement true.\\\\[0.3cm]\n$\\dfrac{2}{7}$ \\BlankInText $0.2861$\\\\[0.3cm]\n$\\dfrac{99}{900}$ \\BlankInText $11\\%$\\\\[0.3cm]\n$1^3$ \\BlankInText $4^0$","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"other"},{"id":"0580-2024OctNov-Paper11-Q06","paper":"2024OctNov-Paper11","qnum":6,"marks":2,"topics":["Statistics"],"s":"9.4","d":1,"cat":"statistics","topic":"Statistical charts and diagrams","qtype":"statistical charts","g":"mixed","src":"0580/11/O/N/24 Q06","year":2024,"session":"OctNov","tex":"The stem-and-leaf diagram shows the number of cars sold each day by a company.\n\n\\begin{tabular}{r | l}\n1 & 0, 3, 4, 5, 6, 7 \\\\\n2 & 1, 2, 2, 4, 7, 7, 7 \\\\\n3 & 0, 0, 1, 2, 2, 5, 6, 8 \\\\\n4 & 0, 1, 4, 6 \\\\\n5 & 1, 2, 4\n\\end{tabular}\nKey: 3 | 2 represents 32\n\n(a) Find the range.\n\n(b) Find the mode.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":1}],"hasFigure":false,"cognitive":"apply","cmd":"find","texHtml":"The stem-and-leaf diagram shows the number of cars sold each day by a company.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><td style=\"text-align:right\">1</td><td>0, 3, 4, 5, 6, 7</td></tr><tr><td style=\"text-align:right\">2</td><td>1, 2, 2, 4, 7, 7, 7</td></tr><tr><td style=\"text-align:right\">3</td><td>0, 0, 1, 2, 2, 5, 6, 8</td></tr><tr><td style=\"text-align:right\">4</td><td>0, 1, 4, 6</td></tr><tr><td style=\"text-align:right\">5</td><td>1, 2, 4</td></tr></table></div>\nKey: 3 | 2 represents 32\n\n(a) Find the range.\n\n(b) Find the mode."},{"id":"0580-2024OctNov-Paper11-Q07","paper":"2024OctNov-Paper11","qnum":7,"marks":1,"topics":["Number"],"s":"1.1","d":1,"cat":"number","topic":"Types of number","qtype":"types of number","g":"mixed","src":"0580/11/O/N/24 Q07","year":2024,"session":"OctNov","tex":"Find the reciprocal of $1\\dfrac{1}{4}$.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q08","paper":"2024OctNov-Paper11","qnum":8,"marks":2,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/11/O/N/24 Q08","year":2024,"session":"OctNov","tex":"\\NotToScale\n\nThe diagram shows a quadrilateral.\\\\\nFind the value of $y$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q09","paper":"2024OctNov-Paper11","qnum":9,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/11/O/N/24 Q09","year":2024,"session":"OctNov","tex":"Edith invests \\$3000 in a savings account.\\\\\nThe account pays simple interest at a rate of 2.6\\% per year.\\\\\nCalculate the total interest earned during the 3 years.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper11-Q10","paper":"2024OctNov-Paper11","qnum":10,"marks":3,"topics":["Algebra and graphs"],"s":"2.7","d":1,"cat":"algebra","topic":"Sequences","qtype":"sequences","g":"sequence","src":"0580/11/O/N/24 Q10","year":2024,"session":"OctNov","tex":"(a) These are the first four terms of a sequence.\n\\[ 10 \\quad 16 \\quad 22 \\quad 28 \\]\nWrite down the next term in the sequence.\n\n(b) The term to term rule for another sequence is multiply by 3 and subtract 1.\\\\\nThe fourth term in the sequence is 68.\\\\\nFind the third term in the sequence.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q11","paper":"2024OctNov-Paper11","qnum":11,"marks":3,"topics":["Mensuration"],"s":"5.3","d":1,"cat":"mensuration","topic":"Circles, arcs and sectors","qtype":"circles, arcs and sectors","g":"mixed","src":"0580/11/O/N/24 Q11","year":2024,"session":"OctNov","tex":"The circumference of a wheel is 198.55 cm.\\\\\nCalculate the diameter of the wheel.\\\\\nGive your answer in millimetres.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper11-Q12","paper":"2024OctNov-Paper11","qnum":12,"marks":2,"topics":["Geometry"],"s":"4.5","d":1,"cat":"geometry","topic":"Symmetry","qtype":"symmetry","g":"mixed","src":"0580/11/O/N/24 Q12","year":2024,"session":"OctNov","tex":"The grid shows half of a shape which has a line of symmetry, $L$.\\\\\nComplete the shape.","parts":[],"hasFigure":true,"cognitive":"recall","cmd":"complete"},{"id":"0580-2024OctNov-Paper11-Q13","paper":"2024OctNov-Paper11","qnum":13,"marks":4,"topics":["Number"],"s":"1.6","d":1,"cat":"number","topic":"The four operations","qtype":"four operations","g":"mixed","src":"0580/11/O/N/24 Q13","year":2024,"session":"OctNov","tex":"(a) Find the value of $6c + 7d$ when $c = 3$ and $d = -4$.\n\n(b) Solve.\n\\[ 6x + 8 = 11x + 4 \\]","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"apply","cmd":"solve"},{"id":"0580-2024OctNov-Paper11-Q14","paper":"2024OctNov-Paper11","qnum":14,"marks":1,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/11/O/N/24 Q14","year":2024,"session":"OctNov","tex":"Write 34 as a percentage of 80.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"write"},{"id":"0580-2024OctNov-Paper11-Q15","paper":"2024OctNov-Paper11","qnum":15,"marks":3,"topics":["Statistics"],"s":"9.3","d":1,"cat":"statistics","topic":"Averages and measures of spread","qtype":"averages and spread","g":"mixed","src":"0580/11/O/N/24 Q15","year":2024,"session":"OctNov","tex":"A bus stops 25 times on a journey.\\\\\nThe table shows the number of people who get on the bus at each stop.\n\n\\begin{tabular}{c | c}\nNumber of people & Frequency \\\\ \\hline\n0 & 1 \\\\\n1 & 6 \\\\\n2 & 7 \\\\\n3 & 4 \\\\\n4 & 5 \\\\\n5 & 2\n\\end{tabular}\nCalculate the mean.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate","texHtml":"A bus stops 25 times on a journey.\\\\\nThe table shows the number of people who get on the bus at each stop.\n\n<div class=\"pp-table-wrap\"><table class=\"pp-table\"><tr><td style=\"text-align:center\">Number of people</td><td style=\"text-align:center\">Frequency</td></tr><tr><td style=\"text-align:center\">0</td><td style=\"text-align:center\">1</td></tr><tr><td style=\"text-align:center\">1</td><td style=\"text-align:center\">6</td></tr><tr><td style=\"text-align:center\">2</td><td style=\"text-align:center\">7</td></tr><tr><td style=\"text-align:center\">3</td><td style=\"text-align:center\">4</td></tr><tr><td style=\"text-align:center\">4</td><td style=\"text-align:center\">5</td></tr><tr><td style=\"text-align:center\">5</td><td style=\"text-align:center\">2</td></tr></table></div>\nCalculate the mean."},{"id":"0580-2024OctNov-Paper11-Q16","paper":"2024OctNov-Paper11","qnum":16,"marks":2,"topics":["Geometry","Mensuration"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/11/O/N/24 Q16","year":2024,"session":"OctNov","tex":"\\NotToScale\n\nThe diagram shows a trapezium with parallel sides of length 12~cm and $w$~cm.\\\\\nThe height of the trapezium is 8~cm.\\\\\nThe area of the trapezium is 78~cm$^2$.\n\nFind the value of $w$.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q17","paper":"2024OctNov-Paper11","qnum":17,"marks":2,"topics":["Number"],"s":"1.9","d":1,"cat":"number","topic":"Estimation","qtype":"estimation and rounding","g":"mixed","src":"0580/11/O/N/24 Q17","year":2024,"session":"OctNov","tex":"A distance, $d$ metres, measures 34.6~m, correct to the nearest 0.1~m.\\\\\nComplete this statement about the value of $d$.","parts":[],"hasFigure":false,"cognitive":"recall","cmd":"complete"},{"id":"0580-2024OctNov-Paper11-Q18","paper":"2024OctNov-Paper11","qnum":18,"marks":4,"topics":["Coordinate geometry","Mensuration","Transformations and vectors"],"s":"3.1","d":1,"cat":"coord","topic":"Coordinates","qtype":"coordinates reading/plotting","g":"graph","src":"0580/11/O/N/24 Q18","year":2024,"session":"OctNov","tex":"The diagram shows a rectangle and two points, $P$ and $C$, on a 1~cm$^2$ grid.\n\n(a) Write down the coordinates of point $C$.\n\n(b) The rectangle is enlarged by scale factor 2 with centre of enlargement point $C$.\\\\\nFind the coordinates of the image of point $P$.\n\n(c) Find the area of the enlarged rectangle.","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"find"},{"id":"0580-2024OctNov-Paper11-Q19","paper":"2024OctNov-Paper11","qnum":19,"marks":4,"topics":["Number"],"s":"1.2","d":1,"cat":"number","topic":"Sets","qtype":"sets and Venn diagrams","g":"mixed","src":"0580/11/O/N/24 Q19","year":2024,"session":"OctNov","tex":"Jo asks some people if they own a car ($C$) and if they own a motorbike ($M$).\\\\\n86 people own a car.\\\\\n39 people own a motorbike.\\\\\n7 people do not own a car and do not own a motorbike.\n\n(a) Complete the Venn diagram.\n\n(b) Find the total number of people that Jo asks.\n\n(c) Write down $n(C \\cup M)$.","parts":[{"label":"(a)","marks":2},{"label":"(b)","marks":1},{"label":"(c)","marks":1}],"hasFigure":true,"cognitive":"apply","cmd":"complete"},{"id":"0580-2024OctNov-Paper11-Q20","paper":"2024OctNov-Paper11","qnum":20,"marks":2,"topics":["Number"],"s":"1.13","d":1,"cat":"number","topic":"Percentages","qtype":"percentages","g":"mixed","src":"0580/11/O/N/24 Q20","year":2024,"session":"OctNov","tex":"Josh buys a car for \\$7800 and sells it for \\$5265.\\\\\nCalculate his percentage loss.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper11-Q21","paper":"2024OctNov-Paper11","qnum":21,"marks":3,"topics":["Number","Algebra and graphs"],"s":"2.2","d":1,"cat":"algebra","topic":"Algebraic manipulation","qtype":"algebraic manipulation","g":"mixed","src":"0580/11/O/N/24 Q21","year":2024,"session":"OctNov","tex":"(a) Factorise.\n\\[ 28x - 35 \\]\n\n(b) Make $r$ the subject of the formula.\n\\[ T = \\dfrac{r}{4} - p \\]","parts":[{"label":"(a)","marks":1},{"label":"(b)","marks":2}],"hasFigure":false,"cognitive":"recall","cmd":"simplify"},{"id":"0580-2024OctNov-Paper11-Q22","paper":"2024OctNov-Paper11","qnum":22,"marks":3,"topics":["Algebra and graphs"],"s":"2.5","d":1,"cat":"algebra","topic":"Equations","qtype":"equations","g":"mixed","src":"0580/11/O/N/24 Q22","year":2024,"session":"OctNov","tex":"Solve the simultaneous equations.\\\\\nYou must show all your working.\n\\begin{align*}\n5x + 6y &= 9 \\\\\n3x - 2y &= -17\n\\end{align*}","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"solve"},{"id":"0580-2024OctNov-Paper11-Q23","paper":"2024OctNov-Paper11","qnum":23,"marks":3,"topics":["Number"],"s":"1.4","d":1,"cat":"number","topic":"Fractions, decimals, percentages","qtype":"fractions, decimals, percentages","g":"mixed","src":"0580/11/O/N/24 Q23","year":2024,"session":"OctNov","tex":"Without using a calculator, work out $5\\dfrac{1}{3} - 3\\dfrac{4}{7}$.\\\\\nYou must show all your working and give your answer as a mixed number in its simplest form.","parts":[],"hasFigure":false,"cognitive":"apply","cmd":"calculate"},{"id":"0580-2024OctNov-Paper11-Q24","paper":"2024OctNov-Paper11","qnum":24,"marks":3,"topics":["Geometry"],"s":"4.6","d":1,"cat":"geometry","topic":"Angles","qtype":"angle calculations","g":"mixed","src":"0580/11/O/N/24 Q24","year":2024,"session":"OctNov","tex":"\\NotToScale\n\nThe diagram shows part of a regular polygon.\\\\\nThe interior angle of the polygon is $132^\\circ$ larger than the exterior angle.\n\nCalculate the number of sides of this polygon.","parts":[],"hasFigure":true,"cognitive":"apply","cmd":"calculate"}]